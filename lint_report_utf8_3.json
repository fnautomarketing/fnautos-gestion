vaFacturaForm({ clientes, empresaId, empresaConfig: _empresaConfig }: NuevaFacturaFormProps) {\r\n    const router = useRouter()\r\n    const [isSubmitting, setIsSubmitting] = useState(false)\r\n    const [lineas, setLineas] = useState<any[]>([\r\n        { concepto: '', cantidad: 1, precio_unitario: 0, iva_porcentaje: 21, descuento_porcentaje: 0, subtotal: 0 }\r\n    ])\r\n\r\n    // Multi-company state (RFC-025)\r\n    const [selectedEmpresaId, setSelectedEmpresaId] = useState(empresaId)\r\n    const [selectedPlantillaId, setSelectedPlantillaId] = useState('')\r\n    const [showConfirmDialog, setShowConfirmDialog] = useState(false)\r\n\r\n    // Form state\r\n    const [clienteId, setClienteId] = useState('')\r\n    const [fechaEmision, setFechaEmision] = useState(new Date().toISOString().split('T')[0])\r\n    const [fechaVencimiento, setFechaVencimiento] = useState(\r\n        new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toISOString().split('T')[0]\r\n    )\r\n    const [notas, setNotas] = useState('')\r\n    const [descuentoTipo, setDescuentoTipo] = useState<'porcentaje' | 'fijo'>('porcentaje')\r\n    const [descuentoValor, setDescuentoValor] = useState(0)\r\n\r\n    // Divisa (RFC-029)\r\n    const [divisa, setDivisa] = useState('EUR')\r\n    const [tipoCambio, setTipoCambio] = useState(1.0)\r\n\r\n    const getSimboloDivisa = (cod: string) => {\r\n        switch (cod) {\r\n            case 'USD': return '$'\r\n            case 'GBP': return '┬ú'\r\n            default: return 'Ôé¼'\r\n        }\r\n    }\r\n\r\n    // Totales\r\n    const [totales, setTotales] = useState({\r\n        subtotal: 0,\r\n        base_imponible: 0,\r\n        iva: 0,\r\n        total: 0,\r\n        importe_descuento: 0\r\n    })\r\n\r\n    useEffect(() => {\r\n        const subtotal = lineas.reduce((acc, linea) => acc + (linea.cantidad * linea.precio_unitario), 0)\r\n        let importe_descuento = 0\r\n\r\n        if (descuentoTipo === 'porcentaje') {\r\n            importe_descuento = subtotal * (descuentoValor / 100)\r\n        } else {\r\n            importe_descuento = descuentoValor\r\n        }\r\n\r\n        const base_imponible = subtotal - importe_descuento\r\n        const iva = base_imponible * 0.21 // Simplificado para este ejemplo\r\n        const total = base_imponible + iva\r\n\r\n        setTotales({\r\n            subtotal,\r\n            base_imponible,\r\n            iva,\r\n            total,\r\n            importe_descuento\r\n        })\r\n    }, [lineas, descuentoTipo, descuentoValor])\r\n\r\n    const addLinea = () => {\r\n        setLineas([...lineas, { concepto: '', cantidad: 1, precio_unitario: 0, iva_porcentaje: 21, descuento_porcentaje: 0, subtotal: 0 }])\r\n    }\r\n\r\n    const removeLinea = (index: number) => {\r\n        if (lineas.length > 1) {\r\n            setLineas(lineas.filter((_, i) => i !== index))\r\n        }\r\n    }\r\n\r\n    const updateLinea = (index: number, field: string, value: any) => {\r\n        const newLineas = [...lineas]\r\n        newLineas[index][field] = value\r\n        setLineas(newLineas)\r\n    }\r\n\r\n    const validateAndShowConfirm = () => {\r\n        if (!clienteId) {\r\n            toast.error('Por favor, selecciona un cliente')\r\n            return\r\n        }\r\n        if (lineas.some(l => !l.concepto || l.precio_unitario <= 0)) {\r\n            toast.error('Completa todos los conceptos y precios')\r\n            return\r\n        }\r\n        setShowConfirmDialog(true)\r\n    }\r\n\r\n    const handleSubmit = async () => {\r\n\r\n        setIsSubmitting(true)\r\n        try {\r\n            const supabase = createClient()\r\n\r\n            // 1. Crear factura (RFC-025: usar selectedEmpresaId y plantilla)\r\n            const { data: factura, error: fError } = await supabase\r\n                .from('facturas')\r\n                .insert({\r\n                    empresa_id: selectedEmpresaId,\r\n                    cliente_id: clienteId,\r\n                    fecha_emision: fechaEmision,\r\n                    fecha_vencimiento: fechaVencimiento,\r\n                    subtotal: totales.subtotal,\r\n                    base_imponible: totales.base_imponible,\r\n                    iva: totales.iva,\r\n                    total: totales.total,\r\n                    descuento_tipo: descuentoTipo,\r\n                    descuento_valor: descuentoValor,\r\n                    importe_descuento: totales.importe_descuento,\r\n                    plantilla_pdf_id: selectedPlantillaId || null,\r\n                    notas,\r\n                    divisa,\r\n                    tipo_cambio: tipoCambio,\r\n                    estado: 'emitida'\r\n                })\r\n                .select()\r\n                .single()\r\n\r\n            if (fError) throw fError\r\n\r\n            // 2. Crear l├¡neas\r\n            const lineasInsert = lineas.map(l => ({\r\n                factura_id: factura.id,\r\n                concepto: l.concepto,\r\n                cantidad: l.cantidad,\r\n                precio_unitario: l.precio_unitario,\r\n                iva_porcentaje: l.iva_porcentaje,\r\n                descuento_porcentaje: l.descuento_porcentaje,\r\n                subtotal: l.cantidad * l.precio_unitario\r\n            }))\r\n\r\n            const { error: lError } = await supabase\r\n                .from('lineas_factura')\r\n                .insert(lineasInsert)\r\n\r\n            if (lError) throw lError\r\n\r\n            toast.success('Factura creada correctamente')\r\n            router.push('/ventas/facturas')\r\n            router.refresh()\r\n        } catch (error: any) {\r\n            console.error('Error al crear factura:', error)\r\n            toast.error(error.message || 'Error al crear la factura')\r\n        } finally {\r\n            setIsSubmitting(false)\r\n        }\r\n    }\r\n\r\n    return (\r\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8\">\r\n            {/* Formulario Principal (8/12) */}\r\n            <div className=\"lg:col-span-8 space-y-6\">\r\n                <Card className=\"shadow-sm\">\r\n                    <CardHeader className=\"bg-slate-50/50 border-b border-slate-100\">\r\n                        <CardTitle className=\"text-xl font-semibold text-slate-800 flex items-center gap-2\">\r\n                            <span className=\"text-primary\">­ƒôä</span> Datos de la Factura\r\n                        </CardTitle>\r\n                    </CardHeader>\r\n                    <CardContent className=\"pt-6 space-y-6\">\r\n                        {/* RFC-025: Empresa Emisora y Plantilla */}\r\n                        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6 p-4 bg-linear-to-r from-primary/5 to-transparent rounded-lg border border-primary/10\">\r\n                            <div className=\"space-y-2\">\r\n                                <Label className=\"flex items-center gap-2\">\r\n                                    <Building2 className=\"h-4 w-4 text-primary\" />\r\n                                    Empresa Emisora\r\n                                </Label>\r\n                                <EmpresaSelector\r\n                                    variant=\"form\"\r\n                                    selectedId={selectedEmpresaId}\r\n                                    onSelect={setSelectedEmpresaId}\r\n                                />\r\n                            </div>\r\n                            <div className=\"space-y-2\">\r\n                                <Label className=\"flex items-center gap-2\">\r\n                                    <FileText className=\"h-4 w-4 text-primary\" />\r\n                                    Plantilla PDF\r\n                                </Label>\r\n                                <PlantillaSelector\r\n                                    empresaId={selectedEmpresaId}\r\n                                    value={selectedPlantillaId}\r\n                                    onChange={setSelectedPlantillaId}\r\n                                />\r\n                            </div>\r\n                        </div>\r\n\r\n                        <Separator className=\"bg-slate-100\" />\r\n\r\n                        {/* Cliente y Fechas */}\r\n                        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\r\n                            <div className=\"space-y-2\">\r\n                                <Label htmlFor=\"cliente\">Cliente</Label>\r\n                                <Select value={clienteId} onValueChange={setClienteId}>\r\n                                    <SelectTrigger className=\"bg-white\">\r\n                                        <SelectValue placeholder=\"Seleccionar cliente...\" />\r\n                                    </SelectTrigger>\r\n                                    <SelectContent>\r\n                                        {clientes.map(c => (\r\n                                            <SelectItem key={c.id} value={c.id}>\r\n                                                {c.nombre_fiscal}\r\n                                            </SelectItem>\r\n                                        ))}\r\n                                    </SelectContent>\r\n                                </Select>\r\n                            </div>\r\n                            <div className=\"grid grid-cols-2 gap-4\">\r\n                                <div className=\"space-y-2\">\r\n                                    <Label>Emisi├│n</Label>\r\n                                    <Input\r\n                                        type=\"date\"\r\n                                        value={fechaEmision}\r\n                                        onChange={(e) => setFechaEmision(e.target.value)}\r\n                                        className=\"bg-white\"\r\n                                    />\r\n                                </div>\r\n                                <div className=\"space-y-2\">\r\n                                    <Label>Vencimiento</Label>\r\n                                    <Input\r\n                                        type=\"date\"\r\n                                        value={fechaVencimiento}\r\n                                        onChange={(e) => setFechaVencimiento(e.target.value)}\r\n                                        className=\"bg-white\"\r\n                                    />\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n\r\n                        {/* RFC-029: Divisa y Tipo de Cambio */}\r\n                        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6 p-4 bg-slate-50 rounded-lg border border-slate-200\">\r\n                            <div className=\"space-y-2\">\r\n                                <Label>Divisa</Label>\r\n                                <Select value={divisa} onValueChange={setDivisa}>\r\n                                    <SelectTrigger className=\"bg-white\">\r\n                                        <SelectValue />\r\n                                    </SelectTrigger>\r\n                                    <SelectContent>\r\n                                        <SelectItem value=\"EUR\">Euro (Ôé¼)</SelectItem>\r\n                                        <SelectItem value=\"USD\">D├│lar ($)</SelectItem>\r\n                                        <SelectItem value=\"GBP\">Libra (┬ú)</SelectItem>\r\n                                    </SelectContent>\r\n                                </Select>\r\n                            </div>\r\n                            {divisa !== 'EUR' && (\r\n                                <div className=\"space-y-2 md:col-span-2 animate-in slide-in-from-left-2\">\r\n                                    <Label>Tipo de Cambio (1 EUR = ? {divisa})</Label>\r\n                                    <div className=\"flex gap-4 items-center\">\r\n                                        <Input\r\n                                            type=\"number\"\r\n                                            step=\"0.0001\"\r\n                                            value={tipoCambio}\r\n                                            onChange={(e) => setTipoCambio(parseFloat(e.target.value))}\r\n                                            className=\"bg-white\"\r\n                                        />\r\n                                        <p className=\"text-xs text-slate-500 italic\">\r\n                                            Se utilizar├í para c├ílculos internos si fuera necesario.\r\n                                        </p>\r\n                                    </div>\r\n                                </div>\r\n                            )}\r\n                        </div>\r\n\r\n                        <Separator className=\"bg-slate-100\" />\r\n\r\n                        {/* L├¡neas de Factura */}\r\n                        <div className=\"space-y-4\">\r\n                            <div className=\"flex items-center justify-between\">\r\n                                <h3 className=\"text-sm font-bold uppercase tracking-wider text-slate-500\">L├¡neas de Concepto</h3>\r\n                                <Button\r\n                                    variant=\"outline\"\r\n                                    size=\"sm\"\r\n                                    onClick={addLinea}\r\n                                    className=\"h-8 text-primary border-primary/20 hover:bg-primary/5\"\r\n                                >\r\n                                    <Plus className=\"h-4 w-4 mr-1\" /> A├▒adir L├¡nea\r\n                                </Button>\r\n                            </div>\r\n\r\n                            <div className=\"space-y-3\">\r\n                                {lineas.map((linea, index) => (\r\n                                    <div key={index} className=\"flex gap-3 items-start animate-in fade-in slide-in-from-top-2 duration-300\">\r\n                                        <div className=\"flex-1\">\r\n                                            <Input\r\n                                                placeholder=\"Concepto / Servicio\"\r\n                                                value={linea.concepto}\r\n                                                onChange={(e) => updateLinea(index, 'concepto', e.target.value)}\r\n                                                className=\"bg-white\"\r\n                                            />\r\n                                        </div>\r\n                                        <div className=\"w-20\">\r\n                                            <Input\r\n                                                type=\"number\"\r\n                                                placeholder=\"Cant\"\r\n                                                value={linea.cantidad}\r\n                                                onChange={(e) => updateLinea(index, 'cantidad', parseFloat(e.target.value))}\r\n                                                className=\"bg-white text-center\"\r\n                                            />\r\n                                        </div>\r\n                                        <div className=\"w-32\">\r\n                                            <div className=\"relative\">\r\n                                                <Input\r\n                                                    type=\"number\"\r\n                                                    placeholder=\"Precio\"\r\n                                                    value={linea.precio_unitario}\r\n                                                    onChange={(e) => updateLinea(index, 'precio_unitario', parseFloat(e.target.value))}\r\n                                                    className=\"bg-white pl-7\"\r\n                                                />\r\n                                                <span className=\"absolute left-2.5 top-2.5 h-4 w-4 text-slate-400 font-medium\">{getSimboloDivisa(divisa)}</span>\r\n                                            </div>\r\n                                        </div>\r\n                                        <div className=\"w-32\">\r\n                                            <div className=\"h-10 flex items-center px-3 bg-slate-50 rounded-md border border-slate-200 font-medium text-slate-700\">\r\n                                                {(linea.cantidad * linea.precio_unitario).toFixed(2)}{getSimboloDivisa(divisa)}\r\n                                            </div>\r\n                                        </div>\r\n                                        {lineas.length > 1 && (\r\n                                            <Button\r\n                                                variant=\"ghost\"\r\n                                                size=\"icon\"\r\n                                                onClick={() => removeLinea(index)}\r\n                                                className=\"h-10 w-10 text-slate-400 hover:text-red-500 hover:bg-red-50\"\r\n                                            >\r\n                                                <Trash2 className=\"h-4 w-4\" />\r\n                                            </Button>\r\n                                        )}\r\n                                    </div>\r\n                                ))}\r\n                            </div>\r\n                        </div>\r\n\r\n                        <Separator className=\"bg-slate-100\" />\r\n\r\n                        {/* Notas */}\r\n                        <div className=\"space-y-2\">\r\n                            <Label htmlFor=\"notas\" className=\"flex items-center gap-2\">\r\n                                <span className=\"text-slate-400\">­ƒôØ</span> Notas / Clausulas Adicionales\r\n                            </Label>\r\n                            <Textarea\r\n                                id=\"notas\"\r\n                                placeholder=\"A├▒adir notas internas o para el cliente...\"\r\n                                value={notas}\r\n                                onChange={(e) => setNotas(e.target.value)}\r\n                                className=\"min-h-[100px] bg-white\"\r\n                            />\r\n                        </div>\r\n                    </CardContent>\r\n                </Card>\r\n            </div>\r\n\r\n            {/* Resumen y Guardado (4/12) */}\r\n            <div className=\"lg:col-span-4 space-y-6\">\r\n                <Card className=\"shadow-lg border-primary/10 overflow-hidden\">\r\n                    <CardHeader className=\"bg-primary text-primary-foreground py-4\">\r\n                        <CardTitle className=\"text-lg font-bold flex items-center justify-between\">\r\n                            Resumen Econ├│mico\r\n                            <span className=\"text-xs font-normal opacity-80 uppercase\">{divisa} ({getSimboloDivisa(divisa)})</span>\r\n                        </CardTitle>\r\n                    </CardHeader>\r\n                    <CardContent className=\"pt-6 space-y-4\">\r\n                        <div className=\"flex justify-between text-sm\">\r\n                            <span className=\"text-slate-500\">Subtotal</span>\r\n                            <span className=\"font-medium\">{totales.subtotal.toFixed(2)}{getSimboloDivisa(divisa)}</span>\r\n                        </div>\r\n\r\n                        {/* Descuento Global Segment */}\r\n                        <div className=\"space-y-2 pt-2 border-t border-slate-100\">\r\n                            <div className=\"flex items-center justify-between text-sm\">\r\n                                <Label className=\"text-slate-500 font-normal\">Descuento Global</Label>\r\n                                <div className=\"flex items-center rounded-md border border-slate-200 bg-slate-50\">\r\n                                    <button\r\n                                        type=\"button\"\r\n                                        onClick={() => setDescuentoTipo('porcentaje')}\r\n                                        className={`px-2 py-1 text-xs rounded-l-md ${descuentoTipo === 'porcentaje' ? 'bg-primary text-primary-foreground' : 'text-slate-500 hover:text-slate-900'}`}\r\n                                    >\r\n                                        <Percent className=\"h-3 w-3\" />\r\n                                    </button>\r\n                                    <button\r\n                                        type=\"button\"\r\n                                        onClick={() => setDescuentoTipo('fijo')}\r\n                                        className={`px-2 py-1 text-xs rounded-r-md ${descuentoTipo === 'fijo' ? 'bg-primary text-primary-foreground' : 'text-slate-500 hover:text-slate-900'}`}\r\n                                    >\r\n                                        <span className=\"font-bold text-[10px]\">{getSimboloDivisa(divisa)}</span>\r\n                                    </button>\r\n                                </div>\r\n                            </div>\r\n                            <div className=\"relative\">\r\n                                <Input\r\n                                    type=\"number\"\r\n                                    value={descuentoValor}\r\n                                    onChange={(e) => setDescuentoValor(parseFloat(e.target.value) || 0)}\r\n                                    className=\"bg-white h-9\"\r\n                                />\r\n                                <span className=\"absolute right-3 top-2.5 text-xs text-slate-400\">\r\n                                    {descuentoTipo === 'porcentaje' ? '%' : getSimboloDivisa(divisa)}\r\n                                </span>\r\n                            </div>\r\n                        </div>\r\n\r\n                        <Separator className=\"bg-slate-100\" />\r\n\r\n                        <div className=\"flex justify-between text-sm font-medium\">\r\n                            <span>Base Imponible</span>\r\n                            <span>{totales.base_imponible.toFixed(2)}{getSimboloDivisa(divisa)}</span>\r\n                        </div>\r\n\r\n                        <div className=\"flex justify-between text-sm\">\r\n                            <span className=\"text-slate-500\">IVA (21%)</span>\r\n                            <span>{totales.iva.toFixed(2)}{getSimboloDivisa(divisa)}</span>\r\n                        </div>\r\n\r\n                        <div className=\"bg-slate-50 -mx-6 p-6 space-y-2 border-y border-slate-200\">\r\n                            <div className=\"flex justify-between items-center\">\r\n                                <span className=\"text-lg font-bold text-slate-800 tracking-tight\">TOTAL</span>\r\n                                <span className=\"text-2xl font-black text-primary\">\r\n                                    {totales.total.toFixed(2)}{getSimboloDivisa(divisa)}\r\n                                </span>\r\n                            </div>\r\n                        </div>\r\n\r\n                        <Button\r\n                            className=\"w-full bg-linear-to-r from-primary to-yellow-600 hover:scale-[1.02] transition-all text-white font-bold h-12 text-lg shadow-md shadow-primary/20\"\r\n                            onClick={validateAndShowConfirm}\r\n                            disabled={isSubmitting}\r\n                        >\r\n                            {isSubmitting ? (\r\n                                <>\r\n                                    <Loader2 className=\"mr-2 h-5 w-5 animate-spin\" /> Procesando...\r\n                                </>\r\n                            ) : (\r\n                                'Emitir Factura'\r\n                            )}\r\n                        </Button>\r\n                        <Button\r\n                            variant=\"outline\"\r\n                            className=\"w-full h-10 text-slate-500 border-slate-200\"\r\n                            onClick={() => router.back()}\r\n                            disabled={isSubmitting}\r\n                        >\r\n                            Cancelar\r\n                        </Button>\r\n                    </CardContent>\r\n                </Card>\r\n\r\n                {/* Confirmation Dialog */}\r\n                <ConfirmDialog\r\n                    open={showConfirmDialog}\r\n                    onOpenChange={setShowConfirmDialog}\r\n                    title=\"Confirmar emisi├│n de factura\"\r\n                    description={`┬┐Est├ís seguro de emitir esta factura por ${totales.total.toFixed(2)}${getSimboloDivisa(divisa)}? Una vez emitida, no podr├í ser eliminada, solo rectificada.`}\r\n                    confirmText=\"S├¡, emitir factura\"\r\n                    cancelText=\"Revisar datos\"\r\n                    onConfirm={handleSubmit}\r\n                />\r\n\r\n                {/* Info Card */}\r\n                <div className=\"bg-amber-50 rounded-xl p-4 border border-amber-100 flex gap-3 shadow-sm\">\r\n                    <span className=\"text-xl\">­ƒÆí</span>\r\n                    <p className=\"text-xs text-amber-800 leading-relaxed\">\r\n                        Recuerda que una vez emitida, la factura tendr├í un n├║mero correlativo asignado autom├íticamente y no podr├í ser eliminada, solo rectificada.\r\n                    </p>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\components\\ventas\\pagos\\historial-pagos-card.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'CheckCircle2' is defined but never used.","line":4,"column":43,"nodeType":"Identifier","messageId":"unusedVar","endLine":4,"endColumn":55,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"CheckCircle2"},"fix":{"range":[194,208],"text":""},"desc":"Remove unused variable \"CheckCircle2\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card'\r\nimport { format } from 'date-fns'\r\nimport { es } from 'date-fns/locale'\r\nimport { Banknote, CreditCard, Building2, CheckCircle2 } from 'lucide-react'\r\n\r\nimport { PagoFactura } from '@/types/ventas'\r\n\r\ninterface HistorialPagosCardProps {\r\n    pagos: PagoFactura[]\r\n}\r\n\r\nexport function HistorialPagosCard({ pagos }: HistorialPagosCardProps) {\r\n    const formatCurrency = (amount: number) => {\r\n        return new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR' }).format(amount)\r\n    }\r\n\r\n    const getIcon = (metodo: string) => {\r\n        switch (metodo.toLowerCase()) {\r\n            case 'transferencia': return <Building2 className=\"w-4 h-4\" />\r\n            case 'tarjeta': return <CreditCard className=\"w-4 h-4\" />\r\n            default: return <Banknote className=\"w-4 h-4\" />\r\n        }\r\n    }\r\n\r\n    return (\r\n        <Card>\r\n            <CardHeader>\r\n                <CardTitle className=\"text-sm uppercase tracking-wider text-slate-500 font-bold\">Historial de Pagos</CardTitle>\r\n            </CardHeader>\r\n            <CardContent>\r\n                {pagos.length === 0 ? (\r\n                    <div className=\"text-center py-6 text-slate-500 text-sm\">\r\n                        No hay pagos registrados para esta factura.\r\n                    </div>\r\n                ) : (\r\n                    <div className=\"space-y-4\">\r\n                        {pagos.map((pago, index) => (\r\n                            <div key={pago.id} className=\"flex gap-3 items-start relative pb-4 border-b border-slate-100 last:border-0 last:pb-0\">\r\n                                <div className=\"mt-1 w-8 h-8 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center shrink-0\">\r\n                                    {getIcon(pago.metodo_pago)}\r\n                                </div>\r\n                                <div className=\"flex-1 space-y-1\">\r\n                                    <div className=\"flex justify-between\">\r\n                                        <p className=\"font-semibold text-slate-900\">{formatCurrency(pago.importe)}</p>\r\n                                        <span className=\"text-xs text-slate-500\">{format(new Date(pago.fecha_pago), 'dd MMM yyyy', { locale: es })}</span>\r\n                                    </div>\r\n                                    <p className=\"text-xs text-slate-600 capitalize flex items-center gap-1\">\r\n                                        {pago.metodo_pago}\r\n                                        {index === 0 && <span className=\"px-1.5 py-0.5 bg-green-100 text-green-700 text-[10px] rounded-full font-bold\">NUEVO</span>}\r\n                                    </p>\r\n                                    {pago.referencia && (\r\n                                        <p className=\"text-[10px] text-slate-400\">Ref: {pago.referencia}</p>\r\n                                    )}\r\n                                </div>\r\n                            </div>\r\n                        ))}\r\n                    </div>\r\n                )}\r\n            </CardContent>\r\n        </Card>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\components\\ventas\\pagos\\registrar-pago-form.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'empresaId' is defined but never used.","line":45,"column":48,"nodeType":"Identifier","messageId":"unusedVar","endLine":45,"endColumn":57},{"ruleId":"react-hooks/incompatible-library","severity":1,"message":"Compilation Skipped: Use of incompatible library\n\nThis API returns functions which cannot be memoized without leading to stale UI. To prevent this, by default React Compiler will skip memoizing this component/hook. However, you may see issues if values from this API are passed to other components/hooks that are memoized.\n\nC:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\components\\ventas\\pagos\\registrar-pago-form.tsx:151:42\n  149 |                                         )}\n  150 |                                     >\n> 151 |                                         {form.watch('fecha_pago') ? (\n      |                                          ^^^^ React Hook Form's `useForm()` API returns a `watch()` function which cannot be memoized safely.\n  152 |                                             format(form.watch('fecha_pago'), \"dd/MM/yyyy\")\n  153 |                                         ) : (\n  154 |                                             <span>Seleccionar fecha</span>","line":151,"column":42,"nodeType":null,"endLine":151,"endColumn":46}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useState, useEffect } from 'react'\r\nimport { useForm, useWatch } from 'react-hook-form'\r\nimport { zodResolver } from '@hookform/resolvers/zod'\r\nimport * as z from 'zod'\r\nimport { format } from 'date-fns'\r\nimport { CalendarIcon, Loader2, CheckCircle2 } from 'lucide-react'\r\nimport { toast } from 'sonner'\r\nimport { useRouter } from 'next/navigation'\r\n\r\nimport { Button } from '@/components/ui/button'\r\nimport { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card'\r\nimport { Input } from '@/components/ui/input'\r\nimport { Textarea } from '@/components/ui/textarea'\r\nimport { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select'\r\nimport { Checkbox } from '@/components/ui/checkbox'\r\nimport { Label } from '@/components/ui/label'\r\nimport { Popover, PopoverContent, PopoverTrigger } from '@/components/ui/popover'\r\nimport { Calendar } from '@/components/ui/calendar'\r\nimport { RadioGroup, RadioGroupItem } from '@/components/ui/radio-group'\r\nimport { cn } from '@/lib/utils'\r\nimport { registrarPagoAction } from '@/app/actions/pagos'\r\n\r\n// Basic schema\r\nconst formSchema = z.object({\r\n    importe: z.number().min(0.01, 'El importe debe ser mayor a 0'),\r\n    fecha_pago: z.date(),\r\n    metodo_pago: z.string().min(1, 'Selecciona un m├®todo'),\r\n    referencia: z.string().optional(),\r\n    asignacion: z.enum(['total', 'parcial']),\r\n    notas: z.string().optional(),\r\n    marcar_como_pagada: z.boolean(),\r\n})\r\n\r\ntype FormValues = z.infer<typeof formSchema>\r\n\r\ninterface RegistrarPagoFormProps {\r\n    facturaId: string\r\n    empresaId: string\r\n    pendienteActual: number\r\n    onImporteChange: (val: number) => void\r\n}\r\n\r\nexport function RegistrarPagoForm({ facturaId, empresaId, pendienteActual, onImporteChange }: RegistrarPagoFormProps) {\r\n    const router = useRouter()\r\n    const [sending, setSending] = useState(false)\r\n\r\n    // Form setup\r\n    const form = useForm<FormValues>({\r\n        resolver: zodResolver(formSchema),\r\n        defaultValues: {\r\n            importe: pendienteActual, // Default to full payment\r\n            fecha_pago: new Date(),\r\n            metodo_pago: 'Transferencia',\r\n            referencia: '',\r\n            asignacion: 'total',\r\n            notas: '',\r\n            marcar_como_pagada: true,\r\n        }\r\n    })\r\n\r\n    // Watch values to update UI logic\r\n    // Watch values to update UI logic\r\n    const importe = useWatch({ control: form.control, name: 'importe' })\r\n    const asignacion = useWatch({ control: form.control, name: 'asignacion' })\r\n    const fechaPago = useWatch({ control: form.control, name: 'fecha_pago' })\r\n\r\n    // Lift state up for the sidebar preview\r\n    useEffect(() => {\r\n        onImporteChange(importe || 0)\r\n    }, [importe, onImporteChange])\r\n\r\n    // Auto-switch assignment mode based on amount vs pending\r\n    useEffect(() => {\r\n        if (importe !== undefined) {\r\n            // Tolerance for floating point\r\n            if (importe >= pendienteActual - 0.01) {\r\n                form.setValue('asignacion', 'total')\r\n                form.setValue('marcar_como_pagada', true)\r\n            } else {\r\n                form.setValue('asignacion', 'parcial')\r\n                form.setValue('marcar_como_pagada', false)\r\n            }\r\n        }\r\n    }, [importe, pendienteActual, form])\r\n\r\n    async function onSubmit(data: FormValues) {\r\n        setSending(true)\r\n        const formData = new FormData()\r\n        formData.append('factura_id', facturaId)\r\n        formData.append('importe', data.importe.toString())\r\n        formData.append('fecha_pago', format(data.fecha_pago, 'yyyy-MM-dd'))\r\n        formData.append('metodo_pago', data.metodo_pago)\r\n        if (data.referencia) formData.append('referencia', data.referencia)\r\n        if (data.notas) formData.append('notas', data.notas)\r\n        formData.append('marcar_como_pagada', data.marcar_como_pagada.toString())\r\n\r\n        const result = await registrarPagoAction(formData)\r\n\r\n        if (result.success) {\r\n            toast.success('Pago registrado correctamente')\r\n            router.push(`/ventas/facturas/${facturaId}`)\r\n        } else {\r\n            toast.error(result.error)\r\n            setSending(false)\r\n        }\r\n    }\r\n\r\n    return (\r\n        <form onSubmit={form.handleSubmit(onSubmit)} className=\"space-y-6\">\r\n            <Card>\r\n                <CardHeader>\r\n                    <CardTitle>Datos del Pago</CardTitle>\r\n                    <CardDescription>Introduce los detalles del cobro recibido</CardDescription>\r\n                </CardHeader>\r\n                <CardContent className=\"space-y-6\">\r\n                    <div className=\"grid md:grid-cols-2 gap-6\">\r\n                        {/* Importe */}\r\n                        <div className=\"space-y-2\">\r\n                            <Label>Importe del Pago</Label>\r\n                            <div className=\"relative\">\r\n                                <span className=\"absolute left-3 top-2.5 text-slate-500 font-bold\">Ôé¼</span>\r\n                                <Input\r\n                                    type=\"number\"\r\n                                    step=\"0.01\"\r\n                                    className=\"pl-8 text-lg font-bold\"\r\n                                    {...form.register('importe', { valueAsNumber: true })}\r\n                                />\r\n                            </div>\r\n                            <p className=\"text-xs text-slate-500\">\r\n                                Importe pendiente: <span className=\"font-medium\">{new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR' }).format(pendienteActual)}</span>\r\n                            </p>\r\n                            {form.formState.errors.importe && (\r\n                                <p className=\"text-xs text-red-500\">{form.formState.errors.importe.message}</p>\r\n                            )}\r\n                        </div>\r\n\r\n                        {/* Fecha */}\r\n                        <div className=\"space-y-2 flex flex-col\">\r\n                            <Label>Fecha de Pago</Label>\r\n                            <Popover>\r\n                                <PopoverTrigger asChild>\r\n                                    <Button\r\n                                        variant={\"outline\"}\r\n                                        className={cn(\r\n                                            \"w-full pl-3 text-left font-normal\",\r\n                                            !fechaPago && \"text-muted-foreground\"\r\n                                        )}\r\n                                    >\r\n                                        {form.watch('fecha_pago') ? (\r\n                                            format(form.watch('fecha_pago'), \"dd/MM/yyyy\")\r\n                                        ) : (\r\n                                            <span>Seleccionar fecha</span>\r\n                                        )}\r\n                                        <CalendarIcon className=\"ml-auto h-4 w-4 opacity-50\" />\r\n                                    </Button>\r\n                                </PopoverTrigger>\r\n                                <PopoverContent className=\"w-auto p-0\" align=\"start\">\r\n                                    <Calendar\r\n                                        mode=\"single\"\r\n                                        selected={form.watch('fecha_pago')}\r\n                                        onSelect={(date) => date && form.setValue('fecha_pago', date)}\r\n                                        disabled={(date) =>\r\n                                            date > new Date() || date < new Date(\"1900-01-01\")\r\n                                        }\r\n                                        initialFocus\r\n                                    />\r\n                                </PopoverContent>\r\n                            </Popover>\r\n                        </div>\r\n                    </div>\r\n\r\n                    {/* Metodo Pago */}\r\n                    <div className=\"space-y-2\">\r\n                        <Label>M├®todo de Pago</Label>\r\n                        <Select\r\n                            onValueChange={(val) => form.setValue('metodo_pago', val)}\r\n                            defaultValue={form.watch('metodo_pago')}\r\n                        >\r\n                            <SelectTrigger>\r\n                                <SelectValue placeholder=\"Selecciona m├®todo\" />\r\n                            </SelectTrigger>\r\n                            <SelectContent>\r\n                                <SelectItem value=\"Transferencia\">Transferencia Bancaria</SelectItem>\r\n                                <SelectItem value=\"Tarjeta\">Tarjeta</SelectItem>\r\n                                <SelectItem value=\"Efectivo\">Efectivo</SelectItem>\r\n                                <SelectItem value=\"Domiciliacion\">Domiciliaci├│n</SelectItem>\r\n                                <SelectItem value=\"Cheque\">Cheque</SelectItem>\r\n                            </SelectContent>\r\n                        </Select>\r\n                    </div>\r\n\r\n                    {/* Referencia */}\r\n                    <div className=\"space-y-2\">\r\n                        <Label>Referencia de Pago</Label>\r\n                        <Input\r\n                            placeholder=\"Ej. Transferencia Ref: 123456\"\r\n                            {...form.register('referencia')}\r\n                        />\r\n                    </div>\r\n\r\n                    {/* Asignacion */}\r\n                    <div className=\"space-y-3 pt-2\">\r\n                        <Label>Tipo de Asignaci├│n</Label>\r\n                        <RadioGroup\r\n                            value={asignacion}\r\n                            onValueChange={(val: 'total' | 'parcial') => form.setValue('asignacion', val)}\r\n                            className=\"flex gap-4\"\r\n                        >\r\n                            <div className={`flex items-center space-x-2 border rounded-lg p-3 flex-1 cursor-pointer transition-colors ${asignacion === 'total' ? 'border-primary bg-primary/5' : 'border-slate-200'}`}>\r\n                                <RadioGroupItem value=\"total\" id=\"r1\" />\r\n                                <Label htmlFor=\"r1\" className=\"cursor-pointer\">Pago Total (Liquida factura)</Label>\r\n                            </div>\r\n                            <div className={`flex items-center space-x-2 border rounded-lg p-3 flex-1 cursor-pointer transition-colors ${asignacion === 'parcial' ? 'border-primary bg-primary/5' : 'border-slate-200'}`}>\r\n                                <RadioGroupItem value=\"parcial\" id=\"r2\" />\r\n                                <Label htmlFor=\"r2\" className=\"cursor-pointer\">Pago Parcial</Label>\r\n                            </div>\r\n                        </RadioGroup>\r\n                    </div>\r\n                </CardContent>\r\n            </Card>\r\n\r\n            <Card>\r\n                <CardHeader>\r\n                    <CardTitle>Notas Internas</CardTitle>\r\n                </CardHeader>\r\n                <CardContent>\r\n                    <Textarea\r\n                        placeholder=\"A├▒ade cualquier nota relevante sobre este cobro...\"\r\n                        className=\"min-h-[100px]\"\r\n                        {...form.register('notas')}\r\n                    />\r\n                </CardContent>\r\n            </Card>\r\n\r\n            <Card>\r\n                <CardHeader>\r\n                    <CardTitle>Opciones Post-Pago</CardTitle>\r\n                </CardHeader>\r\n                <CardContent className=\"space-y-4\">\r\n                    {/* Only show \"Mark as paid\" checkbox if partial payment, otherwise it's auto-checked/hidden-but-true */}\r\n                    {asignacion === 'total' && (\r\n                        <div className=\"flex items-center space-x-2 p-3 bg-green-50 text-green-700 rounded-lg border border-green-100\">\r\n                            <CheckCircle2 className=\"w-5 h-5\" />\r\n                            <span className=\"text-sm font-medium\">La factura se marcar├í autom├íticamente como PAGADA.</span>\r\n                        </div>\r\n                    )}\r\n\r\n                    {asignacion === 'parcial' && (\r\n                        <div className=\"flex items-center space-x-2\">\r\n                            <Checkbox\r\n                                id=\"markPaid\"\r\n                                checked={form.watch('marcar_como_pagada')}\r\n                                onCheckedChange={(chk) => form.setValue('marcar_como_pagada', !!chk)}\r\n                            />\r\n                            <label\r\n                                htmlFor=\"markPaid\"\r\n                                className=\"text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70\"\r\n                            >\r\n                                Marcar factura como Pagada (forzar cierre)\r\n                            </label>\r\n                        </div>\r\n                    )}\r\n                </CardContent>\r\n            </Card>\r\n\r\n            <div className=\"flex justify-end gap-3 pb-10\">\r\n                <Button type=\"button\" variant=\"outline\" onClick={() => router.back()}>\r\n                    Cancelar\r\n                </Button>\r\n                <Button type=\"submit\" disabled={sending} className=\"min-w-[200px] text-lg h-12\">\r\n                    {sending ? (\r\n                        <>\r\n                            <Loader2 className=\"mr-2 h-5 w-5 animate-spin\" />\r\n                            Registrando...\r\n                        </>\r\n                    ) : (\r\n                        'Guardar Pago'\r\n                    )}\r\n                </Button>\r\n            </div>\r\n        </form>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\components\\ventas\\pagos\\resumen-factura-pago.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'es' is defined but never used.","line":4,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":4,"endColumn":12,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"es"},"fix":{"range":[163,199],"text":""},"desc":"Remove unused import declaration."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card'\r\nimport { Badge } from '@/components/ui/badge'\r\nimport { format } from 'date-fns'\r\nimport { es } from 'date-fns/locale'\r\nimport { CheckCircle2 } from 'lucide-react'\r\n\r\ninterface ResumenFacturaPagoProps {\r\n    factura: {\r\n        serie: string\r\n        numero: string\r\n        cliente: { nombre_fiscal: string }\r\n        fecha_emision: string\r\n        total: number\r\n        estado: string\r\n    }\r\n    pagadoHastaHoy: number\r\n    importePagoActual: number\r\n}\r\n\r\nexport function ResumenFacturaPago({ factura, pagadoHastaHoy, importePagoActual }: ResumenFacturaPagoProps) {\r\n    const formatCurrency = (amount: number) => {\r\n        return new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR' }).format(amount)\r\n    }\r\n\r\n    const pendienteActual = Math.max(0, factura.total - pagadoHastaHoy)\r\n    const pendienteFinal = Math.max(0, pendienteActual - importePagoActual)\r\n\r\n    // Determine status badge color\r\n    const getStatusColor = (status: string) => {\r\n        switch (status) {\r\n            case 'pagada': return 'bg-green-100 text-green-700'\r\n            case 'parcial': return 'bg-orange-100 text-orange-700'\r\n            default: return 'bg-slate-100 text-slate-700'\r\n        }\r\n    }\r\n\r\n    return (\r\n        <Card>\r\n            <CardHeader className=\"flex flex-row items-center justify-between pb-2\">\r\n                <CardTitle className=\"text-sm uppercase tracking-wider text-slate-500 font-bold\">Resumen de la Factura</CardTitle>\r\n                <Badge variant=\"secondary\" className={`capitalize ${getStatusColor(factura.estado)} border-0`}>\r\n                    {factura.estado}\r\n                </Badge>\r\n            </CardHeader>\r\n            <CardContent className=\"space-y-4\">\r\n                <div className=\"space-y-1\">\r\n                    <p className=\"text-xs text-slate-400 font-semibold uppercase\">Cliente</p>\r\n                    <p className=\"font-medium text-slate-900 truncate\">{factura.cliente.nombre_fiscal}</p>\r\n                </div>\r\n\r\n                <div className=\"grid grid-cols-2 gap-4\">\r\n                    <div className=\"space-y-1\">\r\n                        <p className=\"text-xs text-slate-400 font-semibold uppercase\">N┬║ Factura</p>\r\n                        <p className=\"font-medium text-slate-700\">{factura.serie}-{factura.numero}</p>\r\n                    </div>\r\n                    <div className=\"space-y-1 text-right\">\r\n                        <p className=\"text-xs text-slate-400 font-semibold uppercase\">Emisi├│n</p>\r\n                        <p className=\"font-medium text-slate-700\">{format(new Date(factura.fecha_emision), 'dd/MM/yyyy')}</p>\r\n                    </div>\r\n                </div>\r\n\r\n                <div className=\"pt-2 border-t border-slate-100 dark:border-slate-800 space-y-2\">\r\n                    <div className=\"flex justify-between text-sm\">\r\n                        <span className=\"text-slate-500\">Total Factura</span>\r\n                        <span className=\"font-semibold\">{formatCurrency(factura.total)}</span>\r\n                    </div>\r\n                    <div className=\"flex justify-between text-sm\">\r\n                        <span className=\"text-slate-500\">Pagado hasta hoy</span>\r\n                        <span className=\"font-medium text-slate-700\">{formatCurrency(pagadoHastaHoy)}</span>\r\n                    </div>\r\n                    <div className=\"flex justify-between text-sm\">\r\n                        <span className=\"text-slate-500\">Pendiente actual</span>\r\n                        <span className=\"font-bold text-red-600\">{formatCurrency(pendienteActual)}</span>\r\n                    </div>\r\n                </div>\r\n\r\n                <div className=\"bg-slate-900 rounded-xl p-4 text-white mt-4\">\r\n                    <p className=\"text-xs text-slate-400 font-semibold uppercase mb-1\">Despu├®s de este pago</p>\r\n                    <div className=\"flex justify-between items-end\">\r\n                        <div>\r\n                            <p className=\"text-xs text-slate-400\">Importe pendiente</p>\r\n                            <p className=\"text-2xl font-bold\">{formatCurrency(pendienteFinal)}</p>\r\n                        </div>\r\n                        {pendienteFinal === 0 && (\r\n                            <div className=\"flex items-center gap-1 text-green-400 text-xs font-bold bg-green-400/10 px-2 py-1 rounded\">\r\n                                <CheckCircle2 className=\"w-3 h-3\" />\r\n                                PAGADA\r\n                            </div>\r\n                        )}\r\n                    </div>\r\n                </div>\r\n            </CardContent>\r\n        </Card>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\components\\ventas\\pdf\\pdf-document.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'BRAND_GOLD' is assigned a value but never used.","line":173,"column":11,"nodeType":"Identifier","messageId":"unusedVar","endLine":173,"endColumn":21}],"suppressedMessages":[{"ruleId":"jsx-a11y/alt-text","severity":1,"message":"Image elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","line":271,"column":29,"nodeType":"JSXOpeningElement","endLine":271,"endColumn":72,"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"/* eslint-disable jsx-a11y/alt-text */\r\nimport { Document, Page, Text, View, Image } from '@react-pdf/renderer'\r\nimport { format } from 'date-fns'\r\nimport { es, enUS, fr } from 'date-fns/locale'\r\nimport type { Factura, Cliente, LineaFactura } from '@/types/ventas'\r\n\r\nexport interface FacturaWithRelations extends Factura {\r\n    cliente: Cliente\r\n    lineas: LineaFactura[]\r\n    es_rectificativa: boolean | null\r\n    factura_rectificada_id: string | null\r\n    motivo_rectificacion: string | null\r\n}\r\n\r\nexport interface Empresa {\r\n    nombre_fiscal: string\r\n    direccion: string\r\n    ciudad: string\r\n    codigo_postal: string\r\n    cif: string\r\n}\r\n\r\nexport interface PdfOptions {\r\n    plantilla: 'estandar' | 'simple' | 'internacional'\r\n    idioma: 'es' | 'en' | 'fr'\r\n    incluirLogo: boolean\r\n    incluirDatosBancarios: boolean\r\n    notasPie: string\r\n    colorAcento?: string\r\n}\r\n\r\nexport interface FacturaPdfDocumentProps {\r\n    factura: FacturaWithRelations\r\n    empresa: Empresa\r\n    // We merge plantilla and options for simplicity in this component\r\n    options: PdfOptions\r\n    logoUrl?: string // Passed explicitly to handle server/client path differences\r\n}\r\n\r\n// Helper for currency\r\nconst formatCurrency = (amount: number, divisa: string = 'EUR') => {\r\n    return new Intl.NumberFormat('es-ES', { style: 'currency', currency: divisa }).format(amount)\r\n}\r\n\r\n// Helper for dates\r\nconst formatDate = (date: string, lang: string = 'es') => {\r\n    const locale = lang === 'en' ? enUS : lang === 'fr' ? fr : es\r\n    return format(new Date(date), 'dd MMM, yyyy', { locale })\r\n}\r\n\r\n// Translations\r\nconst i18n = {\r\n    es: {\r\n        factura: 'FACTURA',\r\n        facturaRectificativa: 'FACTURA RECTIFICATIVA',\r\n        rectifica: 'Rectifica a factura',\r\n        facturarA: 'Facturar A',\r\n        detalles: 'Detalles',\r\n        fechaEmision: 'Fecha de Emisi├│n',\r\n        fechaVencimiento: 'Fecha de Vencimiento',\r\n        concepto: 'Concepto',\r\n        cant: 'Cant.',\r\n        precio: 'Precio',\r\n        iva: 'IVA',\r\n        total: 'Total',\r\n        subtotal: 'Subtotal',\r\n        descuento: 'Descuento',\r\n        baseImponible: 'Base Imponible',\r\n        recargoEq: 'Recargo Eq.',\r\n        retencion: 'Retenci├│n IRPF',\r\n        datosBancarios: 'Datos Bancarios',\r\n        notas: 'Notas'\r\n    },\r\n    en: {\r\n        factura: 'INVOICE',\r\n        facturaRectificativa: 'CREDIT NOTE',\r\n        rectifica: 'Rectifies invoice',\r\n        facturarA: 'Bill To',\r\n        detalles: 'Details',\r\n        fechaEmision: 'Issue Date',\r\n        fechaVencimiento: 'Due Date',\r\n        concepto: 'Description',\r\n        cant: 'Qty',\r\n        precio: 'Price',\r\n        iva: 'VAT',\r\n        total: 'Total',\r\n        subtotal: 'Subtotal',\r\n        descuento: 'Discount',\r\n        baseImponible: 'Tax Base',\r\n        recargoEq: 'Eq. Surcharge',\r\n        retencion: 'Withholding Tax',\r\n        datosBancarios: 'Bank Details',\r\n        notas: 'Notes'\r\n    },\r\n    fr: {\r\n        factura: 'FACTURE',\r\n        facturaRectificativa: 'AVOIR',\r\n        rectifica: 'Rectifie la facture',\r\n        facturarA: 'Facturer ├á',\r\n        detalles: 'D├®tails',\r\n        fechaEmision: 'Date d\\'├®mission',\r\n        fechaVencimiento: 'Date d\\'├®ch├®ance',\r\n        concepto: 'Description',\r\n        cant: 'Qt├®',\r\n        precio: 'Prix',\r\n        iva: 'TVA',\r\n        total: 'Total',\r\n        subtotal: 'Sous-total',\r\n        descuento: 'Remise',\r\n        baseImponible: 'Base Imposable',\r\n        recargoEq: 'Surcharge Eq.',\r\n        retencion: 'Retenue ├á la source',\r\n        datosBancarios: 'Coordonn├®es Bancaires',\r\n        notas: 'Notes'\r\n    }\r\n}\r\n\r\n// Base styles common to all variants - defined outside to be static\r\nconst baseStyles = {\r\n    page: {\r\n        padding: 40,\r\n        fontSize: 10,\r\n        fontFamily: 'Helvetica',\r\n        color: '#334155',\r\n        backgroundColor: '#ffffff'\r\n    },\r\n    infoRow: {\r\n        flexDirection: 'row' as const,\r\n        marginTop: 20,\r\n        justifyContent: 'space-between' as const\r\n    },\r\n    infoCol: { width: '45%' },\r\n    text: { fontSize: 10, marginBottom: 2, color: '#475569' },\r\n    textLg: { fontSize: 11, fontWeight: 'bold' as const, color: '#1e293b' },\r\n    // Columns\r\n    colConcepto: { width: '45%' },\r\n    colCant: { width: '10%', textAlign: 'center' as const },\r\n    colPrecio: { width: '15%', textAlign: 'right' as const },\r\n    colIva: { width: '10%', textAlign: 'center' as const },\r\n    colTotal: { width: '20%', textAlign: 'right' as const },\r\n    td: { fontSize: 10, color: '#334155' },\r\n    totalsSection: { marginTop: 20, alignItems: 'flex-end' as const },\r\n    totalRow: {\r\n        flexDirection: 'row' as const,\r\n        justifyContent: 'space-between' as const,\r\n        width: 220,\r\n        marginBottom: 5,\r\n        paddingVertical: 2\r\n    },\r\n    totalLabel: { fontSize: 10, color: '#64748b' },\r\n    // Logo\r\n    logo: { width: 60, height: 60, objectFit: 'contain' as const, marginBottom: 10 },\r\n    subtitle: { fontSize: 10, color: '#64748b', marginTop: 4 },\r\n    footer: {\r\n        position: 'absolute' as const,\r\n        bottom: 40,\r\n        left: 40,\r\n        right: 40,\r\n        borderTopWidth: 1,\r\n        borderTopColor: '#f1f5f9',\r\n        paddingTop: 20,\r\n    }\r\n}\r\n\r\nexport function FacturaPdfDocument({ factura, empresa, options, logoUrl }: FacturaPdfDocumentProps) {\r\n    const t = i18n[options.idioma || 'es']\r\n    // Ensure validated variant\r\n    const variant = options.plantilla || 'estandar'\r\n\r\n    // Brand Colors from Login Screen\r\n    // Primary (Gold): hsl(45, 96%, 45%) -> #E1AD0F (Approx) -> used #E0A904 from calculation\r\n    // Secondary (Dark Slate): hsl(215, 28%, 17%) -> #1F2937\r\n    const BRAND_GOLD = '#E0A904'\r\n    const BRAND_DARK = '#1F2937'\r\n\r\n    const colorPrimary = options.colorAcento || (variant === 'estandar' ? BRAND_DARK : variant === 'internacional' ? '#4338ca' : '#171717')\r\n    const colorPrimary = options.colorAcento || (variant === 'estandar' ? BRAND_DARK : variant === 'internacional' ? '#4338ca' : '#171717')\r\n\r\n    // specific overrides\r\n    // We calculate styles directly to avoid hook issues in server-side rendering (renderToStream)\r\n    const isInternacional = variant === 'internacional'\r\n    const isSimple = variant === 'simple'\r\n    const isEstandar = variant === 'estandar'\r\n\r\n    const styles = {\r\n        ...baseStyles,\r\n        header: {\r\n            flexDirection: 'row' as const,\r\n            justifyContent: 'space-between' as const,\r\n            marginBottom: 30,\r\n            // Explicitly set border props\r\n            borderBottomWidth: isInternacional ? 2 : 0,\r\n            borderBottomColor: isInternacional ? colorPrimary : 'transparent',\r\n            paddingBottom: isInternacional ? 20 : 0\r\n        },\r\n        titleContainer: {\r\n            alignItems: isEstandar ? 'flex-start' : 'flex-end',\r\n        },\r\n        title: {\r\n            fontSize: isSimple ? 20 : 24,\r\n            fontWeight: 'bold' as const,\r\n            color: colorPrimary,\r\n            textTransform: 'uppercase' as const,\r\n            letterSpacing: isInternacional ? 2 : 0\r\n        },\r\n        sectionTitle: {\r\n            fontSize: 9,\r\n            fontWeight: 'black' as const,\r\n            color: isSimple ? '#000000' : '#64748b',\r\n            textTransform: 'uppercase' as const,\r\n            marginBottom: 8,\r\n            borderBottomWidth: isSimple ? 1 : 0,\r\n            borderBottomColor: '#e5e7eb',\r\n            paddingBottom: isSimple ? 4 : 0\r\n        },\r\n        table: {\r\n            marginTop: 40,\r\n            // Fix: Ensure we don't pass undefined or conflicting borders\r\n            borderWidth: isSimple ? 0 : 1,\r\n            borderColor: '#e2e8f0',\r\n            borderRadius: isEstandar ? 6 : 0,\r\n        },\r\n        tableHeader: {\r\n            flexDirection: 'row' as const,\r\n            backgroundColor: isEstandar ? '#f8fafc' : (isInternacional ? colorPrimary : 'transparent'),\r\n            borderBottomWidth: 1,\r\n            borderBottomColor: isInternacional ? colorPrimary : '#e2e8f0',\r\n            padding: 8,\r\n        },\r\n        th: {\r\n            fontSize: 9,\r\n            fontWeight: 'bold' as const,\r\n            color: isInternacional ? '#ffffff' : (isEstandar ? '#475569' : '#000000'),\r\n            textTransform: 'uppercase' as const,\r\n        },\r\n        tableRow: {\r\n            flexDirection: 'row' as const,\r\n            borderBottomWidth: 1,\r\n            borderBottomColor: '#f1f5f9',\r\n            padding: 8,\r\n            paddingVertical: 10,\r\n        },\r\n        totalValue: { fontSize: 10, fontWeight: 'bold' as const, color: '#1e293b', textAlign: 'right' as const },\r\n        grandTotal: {\r\n            borderTopWidth: 2,\r\n            borderTopColor: isInternacional ? colorPrimary : '#e2e8f0',\r\n            marginTop: 5,\r\n            paddingTop: 8,\r\n        },\r\n        grandTotalValue: { fontSize: 16, color: colorPrimary, fontWeight: 'bold' as const },\r\n        notesBox: {\r\n            marginTop: 40,\r\n            padding: 15,\r\n            backgroundColor: isEstandar ? '#f8fafc' : '#ffffff',\r\n            borderWidth: isSimple ? 1 : 0,\r\n            borderColor: '#e2e8f0',\r\n            borderRadius: 4\r\n        }\r\n    }\r\n\r\n    const descuentoTotal = factura.importe_descuento || factura.descuento || 0\r\n\r\n    return (\r\n        <Document>\r\n            <Page size=\"A4\" style={styles.page}>\r\n                {/* HEADER */}\r\n                <View style={styles.header}>\r\n                    {/* Left Side: Logo/Company (Estandar) or Company (Internacional/Simple) */}\r\n                    <View style={{ width: '50%' }}>\r\n                        {variant === 'estandar' && options.incluirLogo && logoUrl && (\r\n                            <Image src={logoUrl} style={styles.logo} />\r\n                        )}\r\n                        {/* If no logo or not estandar, show company name prominent */}\r\n                        {(!options.incluirLogo || variant !== 'estandar' || !logoUrl) && (\r\n                            <Text style={[styles.title, { fontSize: 18, marginBottom: 5 }]}>{empresa.nombre_fiscal}</Text>\r\n                        )}\r\n\r\n                        <View style={{ marginTop: 5 }}>\r\n                            <Text style={styles.text}>{empresa.direccion}</Text>\r\n                            <Text style={styles.text}>{empresa.ciudad}, {empresa.codigo_postal}</Text>\r\n                            <Text style={styles.text}>{empresa.cif}</Text>\r\n                        </View>\r\n                    </View>\r\n\r\n                    {/* Right Side: Invoice Info */}\r\n                    <View style={{ width: '50%', alignItems: 'flex-end' }}>\r\n                        <Text style={styles.title}>{factura.es_rectificativa ? t.facturaRectificativa : t.factura}</Text>\r\n                        <Text style={[styles.subtitle, { fontSize: 12, color: colorPrimary }]}>{factura.serie}-{factura.numero}</Text>\r\n                        <View style={{ marginTop: 10 }}>\r\n                            <Text style={styles.text}>{t.fechaEmision}: {formatDate(factura.fecha_emision, options.idioma)}</Text>\r\n                            {factura.fecha_vencimiento && (\r\n                                <Text style={styles.text}>{t.fechaVencimiento}: {formatDate(factura.fecha_vencimiento, options.idioma)}</Text>\r\n                            )}\r\n                        </View>\r\n                    </View>\r\n                </View>\r\n\r\n                {/* INFO BLOCKS */}\r\n                <View style={styles.infoRow}>\r\n                    <View style={styles.infoCol}>\r\n                        <Text style={styles.sectionTitle}>{t.facturarA}</Text>\r\n                        <Text style={styles.textLg}>{factura.cliente.nombre_fiscal}</Text>\r\n                        <Text style={styles.text}>{factura.cliente.cif}</Text>\r\n                        <Text style={styles.text}>{factura.cliente.direccion}</Text>\r\n                        <Text style={styles.text}>{factura.cliente.ciudad}, {factura.cliente.codigo_postal}</Text>\r\n                        <Text style={styles.text}>{factura.cliente.email_principal}</Text>\r\n                    </View>\r\n\r\n                    {/* Decorative Element for Internacional */}\r\n                    {variant === 'internacional' && (\r\n                        <View style={{ height: '100%', width: 2, backgroundColor: '#f1f5f9' }} />\r\n                    )}\r\n\r\n                    <View style={[styles.infoCol, { alignItems: variant === 'estandar' ? 'flex-end' : 'flex-start' }]}>\r\n                        {/* Additional info or shipping details could go here */}\r\n                        {/* Keeping it simple for now */}\r\n                    </View>\r\n                </View>\r\n\r\n                {/* TABLE */}\r\n                <View style={styles.table}>\r\n                    <View style={styles.tableHeader}>\r\n                        <Text style={[styles.th, styles.colConcepto]}>{t.concepto}</Text>\r\n                        <Text style={[styles.th, styles.colCant]}>{t.cant}</Text>\r\n                        <Text style={[styles.th, styles.colPrecio]}>{t.precio}</Text>\r\n                        <Text style={[styles.th, styles.colIva]}>{t.iva}</Text>\r\n                        <Text style={[styles.th, styles.colTotal]}>{t.total}</Text>\r\n                    </View>\r\n                    {factura.lineas.map((linea, i) => (\r\n                        <View key={i} style={[styles.tableRow, i === factura.lineas.length - 1 ? { borderBottomWidth: 0 } : {}]}>\r\n                            <View style={styles.colConcepto}>\r\n                                <Text style={[styles.td, { fontWeight: 'bold' }]}>{linea.concepto}</Text>\r\n                                <Text style={{ fontSize: 9, color: '#64748b' }}>{linea.descripcion}</Text>\r\n                            </View>\r\n                            <Text style={[styles.td, styles.colCant]}>{linea.cantidad}</Text>\r\n                            <Text style={[styles.td, styles.colPrecio]}>{formatCurrency(linea.precio_unitario)}</Text>\r\n                            <Text style={[styles.td, styles.colIva]}>{linea.iva_porcentaje}%</Text>\r\n                            <Text style={[styles.td, styles.colTotal]}>{formatCurrency(linea.subtotal)}</Text>\r\n                        </View>\r\n                    ))}\r\n                </View>\r\n\r\n                {/* TOTALS */}\r\n                <View style={styles.totalsSection}>\r\n                    <View>\r\n                        <View style={styles.totalRow}>\r\n                            <Text style={styles.totalLabel}>{t.subtotal}</Text>\r\n                            <Text style={styles.totalValue}>{formatCurrency(factura.subtotal)}</Text>\r\n                        </View>\r\n                        {descuentoTotal > 0 && (\r\n                            <View style={styles.totalRow}>\r\n                                <Text style={styles.totalLabel}>{t.descuento}</Text>\r\n                                <Text style={[styles.totalValue, { color: '#16a34a' }]}>-{formatCurrency(descuentoTotal)}</Text>\r\n                            </View>\r\n                        )}\r\n                        <View style={styles.totalRow}>\r\n                            <Text style={styles.totalLabel}>{t.iva}</Text>\r\n                            <Text style={styles.totalValue}>{formatCurrency(factura.iva)}</Text>\r\n                        </View>\r\n                        {factura.importe_retencion && factura.importe_retencion > 0 && (\r\n                            <View style={styles.totalRow}>\r\n                                <Text style={styles.totalLabel}>{t.retencion}</Text>\r\n                                <Text style={styles.totalValue}>-{formatCurrency(factura.importe_retencion)}</Text>\r\n                            </View>\r\n                        )}\r\n                        <View style={[styles.totalRow, styles.grandTotal]}>\r\n                            <Text style={[styles.totalLabel, { fontSize: 12, fontWeight: 'bold', color: colorPrimary }]}>{t.total}</Text>\r\n                            <Text style={styles.grandTotalValue}>{formatCurrency(factura.total)}</Text>\r\n                        </View>\r\n                    </View>\r\n                </View>\r\n\r\n                {/* FOOTER / NOTES */}\r\n                <View style={styles.footer}>\r\n                    <View style={{ flexDirection: 'row', justifyContent: 'space-between' }}>\r\n                        {(options.incluirDatosBancarios) && (\r\n                            <View style={{ width: '50%' }}>\r\n                                <Text style={[styles.sectionTitle, { marginBottom: 4 }]}>{t.datosBancarios}</Text>\r\n                                <Text style={styles.text}>IBAN: ES98 1234 5678 9012 3456 7890</Text>\r\n                                <Text style={styles.text}>Bank: STV Bank</Text>\r\n                            </View>\r\n                        )}\r\n                        <View style={{ width: '45%' }}>\r\n                            {options.notasPie && (\r\n                                <View>\r\n                                    <Text style={[styles.sectionTitle, { marginBottom: 4 }]}>{t.notas}</Text>\r\n                                    <Text style={[styles.text, { fontStyle: 'italic' }]}>{options.notasPie}</Text>\r\n                                </View>\r\n                            )}\r\n                        </View>\r\n                    </View>\r\n                    <View style={{ marginTop: 20, paddingTop: 10, borderTopWidth: 1, borderTopColor: '#f1f5f9' }}>\r\n                        <Text style={{ fontSize: 8, color: '#94a3b8', textAlign: 'center' }}>\r\n                            {empresa.nombre_fiscal} - {empresa.cif} - {empresa.ciudad}\r\n                        </Text>\r\n                    </View>\r\n                </View>\r\n            </Page>\r\n        </Document>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\components\\ventas\\pdf\\pdf-layout-preview.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":49,"column":45,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":49,"endColumn":48,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1753,1756],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1753,1756],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":63,"column":27,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":63,"endColumn":30,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[2196,2199],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[2196,2199],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useState, useEffect } from 'react'\r\nimport { Skeleton } from '@/components/ui/skeleton'\r\nimport type { Empresa, PdfOptions } from './pdf-document'\r\nimport type { Factura, Cliente, LineaFactura } from '@/types/ventas'\r\nimport { Loader2, AlertCircle } from 'lucide-react'\r\n\r\n// We need to import the component but @react-pdf/renderer must be loaded dynamically\r\nimport { FacturaPdfDocument } from './pdf-document'\r\n\r\ninterface FacturaPreview extends Factura {\r\n    cliente: Cliente\r\n    lineas: LineaFactura[]\r\n    es_rectificativa: boolean | null\r\n    factura_rectificada_id: string | null\r\n    motivo_rectificacion: string | null\r\n}\r\n\r\ninterface PdfLayoutPreviewProps {\r\n    factura: FacturaPreview\r\n    empresa: Empresa\r\n    options: PdfOptions\r\n}\r\n\r\nexport function PdfLayoutPreview({ factura, empresa, options }: PdfLayoutPreviewProps) {\r\n    const [url, setUrl] = useState<string | null>(null)\r\n    const [loading, setLoading] = useState(true)\r\n    const [error, setError] = useState<string | null>(null)\r\n\r\n    useEffect(() => {\r\n        let isMounted = true\r\n        let objectUrl: string | null = null\r\n\r\n        const generatePdf = async () => {\r\n            try {\r\n                setLoading(true)\r\n                setError(null)\r\n\r\n                // Dynamically load the renderer to ensure it runs only on client\r\n                const { pdf } = await import('@react-pdf/renderer')\r\n\r\n                // Construct logo URL safely\r\n                const logoUrl = typeof window !== 'undefined' ? `${window.location.origin}/logo-stv.svg` : undefined\r\n\r\n                // Prepare the document instance\r\n                const doc = (\r\n                    <FacturaPdfDocument\r\n                        factura={factura as any}\r\n                        empresa={empresa}\r\n                        options={options}\r\n                        logoUrl={logoUrl}\r\n                    />\r\n                )\r\n\r\n                // Generate blob\r\n                const blob = await pdf(doc).toBlob()\r\n                objectUrl = URL.createObjectURL(blob)\r\n\r\n                if (isMounted) {\r\n                    setUrl(objectUrl)\r\n                }\r\n            } catch (err: any) {\r\n                console.error('PDF Generation failed:', err)\r\n                if (isMounted) {\r\n                    setError(err.message || 'Error desconocido al generar PDF')\r\n                }\r\n            } finally {\r\n                if (isMounted) {\r\n                    setLoading(false)\r\n                }\r\n            }\r\n        }\r\n\r\n        // Debounce slightly to avoid rapid regenerations if props change fast? \r\n        // For now direct call.\r\n        generatePdf()\r\n\r\n        return () => {\r\n            isMounted = false\r\n            if (objectUrl) {\r\n                URL.revokeObjectURL(objectUrl)\r\n            }\r\n        }\r\n    }, [factura, empresa, options]) // Re-run when props change\r\n\r\n    // Initial server render placeholder\r\n    if (loading && !url && !error) {\r\n        return <div className=\"w-full h-[700px] bg-slate-100 dark:bg-slate-900 rounded-xl flex items-center justify-center\"><Skeleton className=\"w-full h-full\" /></div>\r\n    }\r\n\r\n    return (\r\n        <div className=\"w-full h-[700px] border border-slate-200 dark:border-slate-800 rounded-xl overflow-hidden bg-slate-100 dark:bg-slate-900 shadow-sm relative group\">\r\n            {loading && (\r\n                <div className=\"absolute inset-0 z-10 bg-white/50 dark:bg-black/50 flex flex-col items-center justify-center backdrop-blur-sm\">\r\n                    <Loader2 className=\"h-8 w-8 animate-spin text-primary\" />\r\n                    <span className=\"text-sm font-medium text-slate-700 dark:text-slate-200 mt-2\">Generando vista previa...</span>\r\n                </div>\r\n            )}\r\n\r\n            {error ? (\r\n                <div className=\"flex flex-col items-center justify-center h-full text-red-500 gap-4 p-8 text-center\">\r\n                    <AlertCircle className=\"h-12 w-12\" />\r\n                    <div>\r\n                        <h3 className=\"font-bold text-lg mb-1\">Error de previsualizaci├│n</h3>\r\n                        <p className=\"text-sm opacity-80\">{error}</p>\r\n                    </div>\r\n                </div>\r\n            ) : (\r\n                url && (\r\n                    <iframe\r\n                        src={url}\r\n                        className=\"w-full h-full border-none bg-white\"\r\n                        title=\"PDF Preview\"\r\n                    />\r\n                )\r\n            )}\r\n        </div>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\components\\ventas\\pdf\\pdf-options-panel.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":32,"column":57,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":32,"endColumn":60,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1179,1182],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1179,1182],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card'\r\nimport { Label } from '@/components/ui/label'\r\nimport { Switch } from '@/components/ui/switch'\r\nimport { Switch } from '@/components/ui/switch'\r\nimport { Textarea } from '@/components/ui/textarea'\r\nimport { Button } from '@/components/ui/button'\r\nimport { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select'\r\nimport { Download, Mail, Printer, Settings2 } from 'lucide-react'\r\nimport { toast } from 'sonner'\r\n\r\nexport type PdfOptions = {\r\n    plantilla: 'estandar' | 'simple' | 'internacional'\r\n    idioma: 'es' | 'en' | 'fr'\r\n    formatoPagina: 'A4-vertical' | 'A4-horizontal'\r\n    incluirLogo: boolean\r\n    mostrarDesgloseIva: boolean\r\n    colorAcento: string\r\n    notasPie: string\r\n    incluirTerminos: boolean\r\n    incluirDatosBancarios: boolean\r\n}\r\n\r\ninterface PdfOptionsPanelProps {\r\n    options: PdfOptions\r\n    onChange: (options: PdfOptions) => void\r\n    onDownload: () => void\r\n}\r\n\r\nexport function PdfOptionsPanel({ options, onChange, onDownload }: PdfOptionsPanelProps) {\r\n    const handleChange = (key: keyof PdfOptions, value: any) => {\r\n        onChange({ ...options, [key]: value })\r\n    }\r\n\r\n    return (\r\n        <div className=\"space-y-6\">\r\n            <Card>\r\n                <CardHeader>\r\n                    <CardTitle className=\"text-lg flex items-center gap-2\">\r\n                        <Settings2 className=\"h-5 w-5 text-slate-500\" />\r\n                        Configuraci├│n\r\n                    </CardTitle>\r\n                </CardHeader>\r\n                <CardContent className=\"space-y-6\">\r\n                    <div className=\"space-y-2\">\r\n                        <Label>Plantilla</Label>\r\n                        <Select value={options.plantilla} onValueChange={(val) => handleChange('plantilla', val)}>\r\n                            <SelectTrigger>\r\n                                <SelectValue placeholder=\"Selecciona plantilla\" />\r\n                            </SelectTrigger>\r\n                            <SelectContent>\r\n                                <SelectItem value=\"estandar\">Corporativa Est├índar</SelectItem>\r\n                                <SelectItem value=\"simple\">Minimalista</SelectItem>\r\n                                <SelectItem value=\"internacional\">Internacional</SelectItem>\r\n                            </SelectContent>\r\n                        </Select>\r\n                    </div>\r\n\r\n                    <div className=\"grid grid-cols-2 gap-4\">\r\n                        <div className=\"space-y-2\">\r\n                            <Label>Idioma</Label>\r\n                            <Select value={options.idioma} onValueChange={(val) => handleChange('idioma', val)}>\r\n                                <SelectTrigger>\r\n                                    <SelectValue />\r\n                                </SelectTrigger>\r\n                                <SelectContent>\r\n                                    <SelectItem value=\"es\">Espa├▒ol</SelectItem>\r\n                                    <SelectItem value=\"en\">Ingl├®s</SelectItem>\r\n                                    <SelectItem value=\"fr\">Franc├®s</SelectItem>\r\n                                </SelectContent>\r\n                            </Select>\r\n                        </div>\r\n                        <div className=\"space-y-2\">\r\n                            <Label>Formato</Label>\r\n                            <Select value={options.formatoPagina} onValueChange={(val) => handleChange('formatoPagina', val)}>\r\n                                <SelectTrigger>\r\n                                    <SelectValue />\r\n                                </SelectTrigger>\r\n                                <SelectContent>\r\n                                    <SelectItem value=\"A4-vertical\">A4 Vertical</SelectItem>\r\n                                    <SelectItem value=\"A4-horizontal\">A4 Horiz.</SelectItem>\r\n                                </SelectContent>\r\n                            </Select>\r\n                        </div>\r\n                    </div>\r\n\r\n                    <div className=\"space-y-4 pt-2\">\r\n                        <div className=\"flex items-center justify-between\">\r\n                            <Label className=\"flex flex-col gap-1\">\r\n                                <span>Incluir Logo</span>\r\n                                <span className=\"font-normal text-xs text-slate-500\">Muestra el logo de la empresa</span>\r\n                            </Label>\r\n                            <Switch\r\n                                checked={options.incluirLogo}\r\n                                onCheckedChange={(checked) => handleChange('incluirLogo', checked)}\r\n                            />\r\n                        </div>\r\n\r\n                        <div className=\"flex items-center justify-between\">\r\n                            <Label className=\"flex flex-col gap-1\">\r\n                                <span>Datos Bancarios</span>\r\n                                <span className=\"font-normal text-xs text-slate-500\">IBAN y Banco en el pie</span>\r\n                            </Label>\r\n                            <Switch\r\n                                checked={options.incluirDatosBancarios}\r\n                                onCheckedChange={(checked) => handleChange('incluirDatosBancarios', checked)}\r\n                            />\r\n                        </div>\r\n                    </div>\r\n\r\n                    <div className=\"space-y-2\">\r\n                        <Label>Notas al pie</Label>\r\n                        <Textarea\r\n                            value={options.notasPie}\r\n                            onChange={(e) => handleChange('notasPie', e.target.value)}\r\n                            placeholder=\"Gracias por su confianza...\"\r\n                            className=\"h-20 resize-none text-xs\"\r\n                        />\r\n                    </div>\r\n                </CardContent>\r\n            </Card>\r\n\r\n            <Card>\r\n                <CardHeader>\r\n                    <CardTitle className=\"text-lg\">Acciones</CardTitle>\r\n                </CardHeader>\r\n                <CardContent className=\"grid gap-3\">\r\n                    <Button onClick={onDownload} className=\"w-full\">\r\n                        <Download className=\"mr-2 h-4 w-4\" />\r\n                        Descargar PDF\r\n                    </Button>\r\n                    <div className=\"grid grid-cols-2 gap-3\">\r\n                        <Button variant=\"outline\" onClick={() => toast.info('Env├¡o de email pr├│ximamente')}>\r\n                            <Mail className=\"mr-2 h-4 w-4\" />\r\n                            Email\r\n                        </Button>\r\n                        <Button variant=\"outline\" onClick={() => window.print()}>\r\n                            <Printer className=\"mr-2 h-4 w-4\" />\r\n                            Imprimir\r\n                        </Button>\r\n                    </div>\r\n                </CardContent>\r\n            </Card>\r\n        </div>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\components\\ventas\\resumen-financiero.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\components\\ventas\\timeline-eventos.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\De