      if (value !== 'todas') {\r\n            params.set('estado', value)\r\n        } else {\r\n            params.delete('estado')\r\n        }\r\n\r\n        params.delete('page')\r\n\r\n        startTransition(() => {\r\n            router.push(`/ventas/facturas?${params.toString()}`)\r\n        })\r\n    }\r\n\r\n    const handleLimpiar = () => {\r\n        setBusqueda('')\r\n        setEstado('todas')\r\n        startTransition(() => {\r\n            router.push('/ventas/facturas')\r\n        })\r\n    }\r\n\r\n    const handleKeyPress = (e: React.KeyboardEvent) => {\r\n        if (e.key === 'Enter') {\r\n            handleBuscar()\r\n        }\r\n    }\r\n\r\n    return (\r\n        <Card className=\"border-white/20 bg-white/70 backdrop-blur-xl dark:border-white/10 dark:bg-slate-900/60\">\r\n            <CardContent className=\"p-6\">\r\n                <div className=\"flex flex-col gap-4 sm:flex-row sm:items-center\">\r\n                    {/* B├║squeda */}\r\n                    <div className=\"relative flex-1 group\">\r\n                        <Search className=\"absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400 group-hover:text-primary transition-colors duration-300\" />\r\n                        <Input\r\n                            placeholder=\"Buscar por cliente, factura o importe...\"\r\n                            value={busqueda}\r\n                            onChange={(e) => setBusqueda(e.target.value)}\r\n                            onKeyPress={handleKeyPress}\r\n                            className=\"pl-10 bg-white/50 dark:bg-slate-800/50 border-slate-200 dark:border-slate-700 focus:ring-primary/20 transition-all duration-300\"\r\n                            disabled={isPending}\r\n                        />\r\n                    </div>\r\n\r\n                    {/* Estado */}\r\n                    <Select value={estado} onValueChange={handleEstado} disabled={isPending}>\r\n                        <SelectTrigger className