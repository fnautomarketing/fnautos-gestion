                           <Label className=\"text-sm font-medium uppercase text-slate-500\">\r\n                                    Fecha de Emisi├│n\r\n                                </Label>\r\n                                <RadioGroup value={tipoFechaEmision} onValueChange={(v: any) => setTipoFechaEmision(v)}>\r\n                                    <div className=\"flex items-center space-x-2\">\r\n                                        <RadioGroupItem value=\"hoy\" id=\"fecha-hoy\" />\r\n                                        <Label htmlFor=\"fecha-hoy\" className=\"font-normal cursor-pointer\">\r\n                                            Hoy ({format(new Date(), 'dd MMM yyyy', { locale: es })})\r\n                                        </Label>\r\n                                    </div>\r\n                                    <div className=\"flex items-center space-x-2\">\r\n                                        <RadioGroupItem value=\"personalizada\" id=\"fecha-personalizada\" />\r\n                                        <Label htmlFor=\"fecha-personalizada\" className=\"font-normal cursor-pointer\">\r\n                                            Personalizada\r\n                                        </Label>\r\n                                    </div>\r\n                                </RadioGroup>\r\n\r\n                                {tipoFechaEmision === 'personalizada' && (\r\n                                    <Popover>\r\n                                        <PopoverTrigger asChild>\r\n                                            <Button variant=\"outline\" className=\"w-full justify-start text-left\">\r\n                                                {format(fechaEmisionPersonalizada, 'dd/MM/yyyy', { locale: es })}\r\n                                            </Button>\r\n                                        </PopoverTrigger>\r\n                                        <PopoverContent className=\"w-auto p-0\">\r\n                                            <Calendar\r\n                                                mode=\"single\"\r\n                                                selected={fechaEmisionPersonalizada}\r\n                                                onSelect={(date) => date && setFechaEmisionPersonalizada(date)}\r\n                                            />\r\n                                        </PopoverContent>\r\n                                    </Popover>\r\n                                )}\r\n                            </div>\r\n\r\n                            <div className=\"space-y-3\">\r\n                                <Label className=\"text-sm font-medium uppercase text-slate-500\">\r\n                                    Vencimiento\r\n                                </Label>\r\n                                <RadioGroup\r\n                                    value={tipoFechaVencimiento}\r\n                                    onValueChange={(v: any) => setTipoFechaVencimiento(v)}\r\n                                >\r\n                                    <div className=\"flex items-center space-x-2\">\r\n                                        <RadioGroupItem value=\"30dias\" id=\"venc-30\" />\r\n                                        <Label htmlFor=\"venc-30\" className=\"font-normal cursor-pointer\">\r\n                                            +30 d├¡as ({format(addDays(getFechaEmision(), 30), 'dd MMM yyyy', { locale: es })})\r\n                                        </Label>\r\n                                    </div>\r\n                                    <div className=\"flex items-center space-x-2\">\r\n                                        <RadioGroupItem value=\"personalizada\" id=\"venc-personalizada\" />\r\n                                        <Label htmlFor=\"venc-personalizada\" className=\"font-normal cursor-pointer\">\r\n                                            Personalizada\r\n                                        </Label>\r\n                                    </div>\r\n                                </RadioGroup>\r\n\r\n                                {tipoFechaVencimiento === 'personalizada' && (\r\n                                    <Popover>\r\n                                        <PopoverTrigger asChild>\r\n                                            <Button variant=\"outline\" className=\"w-full justify-start text-left\">\r\n                                                {format(fechaVencimientoPersonalizada, 'dd/MM/yyyy', { locale: es })}\r\n                                            </Button>\r\n                                        </PopoverTrigger>\r\n                                        <PopoverContent className=\"w-auto p-0\">\r\n                                            <Calendar\r\n                                                mode=\"single\"\r\n                                                selected={fechaVencimientoPersonalizada}\r\n                                                onSelect={(date) => date && setFechaVencimientoPersonalizada(date)}\r\n                                            />\r\n                                        </PopoverContent>\r\n                                    </Popover>\r\n                                )}\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n\r\n                    {/* Serie de facturaci├│n */}\r\n                    <div className=\"space-y-2\">\r\n                        <Label className=\"text-sm font-medium uppercase text-slate-500\">\r\n                            Serie de Facturaci├│n\r\n                        </Label>\r\n                        <Select value={serieSeleccionada} onValueChange={setSerieSeleccionada}>\r\n                            <SelectTrigger>\r\n                                <SelectValue />\r\n                            </SelectTrigger>\r\n                            <SelectContent>\r\n                                <SelectItem value=\"FAC-2024\">Serie General (FAC)</SelectItem>\r\n                                <SelectItem value=\"RECT-2024\">Rectificativa (RECT)</SelectItem>\r\n                                <SelectItem value=\"EXP-2024\">Exportaci├│n (EXP)</SelectItem>\r\n                            </SelectContent>\r\n                        </Select>\r\n                        <p className=\"text-xs text-slate-500\">El n├║mero se generar├í autom├íticamente</p>\r\n                    </div>\r\n\r\n                    {/* Vista previa */}\r\n                    <div className=\"rounded-lg bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 p-4\">\r\n                        <p className=\"text-xs uppercase text-green-700 dark:text-green-400 mb-2 font-semibold\">\r\n                            Vista Previa\r\n                        </p>\r\n                        <div className=\"space-y-1 text-sm\">\r\n                            <p>\r\n                                <span className=\"text-slate-500\">Nueva factura:</span>{' '}\r\n                                <strong>{serieSeleccionada}-XXX</strong> (en borrador)\r\n                            </p>\r\n                            {mantenerCliente && (\r\n                                <p>\r\n                                    <span className=\"text-slate-500\">Cliente:</span>{' '}\r\n                                    <strong>{factura.cliente.nombre_fiscal}</strong>\r\n                                </p>\r\n                            )}\r\n                            <p>\r\n                                <span className=\"text-slate-500\">Fecha emisi├│n:</span>{' '}\r\n                                <strong>{format(getFechaEmision(), 'dd MMM yyyy', { locale: es })}</strong>\r\n                            </p>\r\n                            {copiarLineas && (\r\n                                <p>\r\n                                    <span className=\"text-slate-500\">L├¡neas:</span>{' '}\r\n                                    <strong>{factura.lineas?.length || 0} copiadas</strong>\r\n                                </p>\r\n                            )}\r\n                            <p>\r\n                                <span className=\"text-slate-500\">Total estimado:</span>{' '}\r\n                                <strong className=\"text-green-600\">{formatCurrency(factura.total)}</strong>\r\n                            </p>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n\r\n                {/* Footer con botones */}\r\n                <div className=\"flex justify-end gap-3 mt-6\">\r\n                    <Button variant=\"outline\" onClick={() => onOpenChange(false)} disabled={isSubmitting}>\r\n                        Cancelar\r\n                    </Button>\r\n                    <Button onClick={handleDuplicar} disabled={isSubmitting}>\r\n                        {isSubmitting ? 'Duplicando...' : 'Duplicar y Editar'}\r\n                    </Button>\r\n                </div>\r\n            </DialogContent>\r\n        </Dialog>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\components\\ventas\\editar-factura-form.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Loader2' is defined but never used.","line":8,"column":36,"nodeType":"Identifier","messageId":"unusedVar","endLine":8,"endColumn":43,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Loader2"},"fix":{"range":[253,262],"text":""},"desc":"Remove unused variable \"Loader2\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'setLineas' is assigned a value but never used.","line":116,"column":20,"nodeType":"Identifier","messageId":"unusedVar","endLine":116,"endColumn":29},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'getSimboloDivisa' is assigned a value but never used.","line":127,"column":11,"nodeType":"Identifier","messageId":"unusedVar","endLine":127,"endColumn":27},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":210,"column":33,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":210,"endColumn":36,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[8803,8806],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[8803,8806],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":211,"column":37,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":211,"endColumn":40,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[8865,8868],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[8865,8868],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useState, useEffect, useMemo } from 'react'\r\nimport { useRouter } from 'next/navigation'\r\nimport { format } from 'date-fns'\r\nimport { es } from 'date-fns/locale'\r\nimport { toast } from 'sonner'\r\nimport { Lock, Info, CalendarIcon, Loader2, Percent, Euro } from 'lucide-react'\r\nimport { createClient } from '@/lib/supabase/client'\r\n\r\nimport { Button } from '@/components/ui/button'\r\nimport { Input } from '@/components/ui/input'\r\nimport { Label } from '@/components/ui/label'\r\nimport { Textarea } from '@/components/ui/textarea'\r\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card'\r\nimport { Badge } from '@/components/ui/badge'\r\nimport { Alert, AlertDescription } from '@/components/ui/alert'\r\nimport { Calendar } from '@/components/ui/calendar'\r\nimport { Popover, PopoverContent, PopoverTrigger } from '@/components/ui/popover'\r\nimport { Switch } from '@/components/ui/switch'\r\nimport { Separator } from '@/components/ui/separator'\r\nimport { cn } from '@/lib/utils'\r\nimport {\r\n    Select,\r\n    SelectContent,\r\n    SelectItem,\r\n    SelectTrigger,\r\n    SelectValue,\r\n} from '@/components/ui/select'\r\n\r\nimport { editarFacturaAction } from '@/app/actions/ventas'\r\nimport { PlantillaSelector } from '@/components/plantilla-selector'\r\nimport { HistorialCambiosCard } from './historial-cambios-card'\r\n\r\nimport type { Factura, Cliente, LineaFactura, Cambio, Serie } from '@/types/ventas'\r\n\r\ninterface FacturaWithRelations extends Factura {\r\n    cliente: Cliente\r\n    lineas: LineaFactura[]\r\n    serie_id: string | null\r\n}\r\n\r\ninterface EditarFacturaFormProps {\r\n    factura: FacturaWithRelations\r\n    empresaId: string\r\n    cambios: Cambio[]\r\n}\r\n\r\nexport function EditarFacturaForm({ factura, empresaId, cambios }: EditarFacturaFormProps) {\r\n    const router = useRouter()\r\n    const [isSubmitting, setIsSubmitting] = useState(false)\r\n    const [series, setSeries] = useState<Serie[]>([])\r\n    const [serieSeleccionada, setSerieSeleccionada] = useState<string>(factura.serie_id || '')\r\n    const [selectedPlantillaId, setSelectedPlantillaId] = useState<string>(factura.plantilla_pdf_id || '')\r\n    const [loadingSeries, setLoadingSeries] = useState(true)\r\n\r\n    // Cargar series al iniciar\r\n    useEffect(() => {\r\n        const fetchSeries = async () => {\r\n            const { data } = await createClient()\r\n                .from('series_facturacion')\r\n                .select('*')\r\n                .eq('empresa_id', empresaId)\r\n                .eq('activo', true)\r\n                .order('predeterminada', { ascending: false })\r\n\r\n            if (data) {\r\n                setSeries(data)\r\n                if (!serieSeleccionada && data.length > 0) {\r\n                    const defaultSerie = data.find(s => s.predeterminada) || data[0]\r\n                    setSerieSeleccionada(defaultSerie.id)\r\n                }\r\n            }\r\n            setLoadingSeries(false)\r\n        }\r\n        fetchSeries()\r\n    }, [empresaId, serieSeleccionada])\r\n\r\n    // Determinar qu├® se puede editar seg├║n estado\r\n    type Permisos = {\r\n        todo?: boolean\r\n        fechaVencimiento?: boolean\r\n        notas?: boolean\r\n        mensaje: string\r\n    }\r\n\r\n    const estadoEditable: Record<string, Permisos> = {\r\n        borrador: {\r\n            todo: true,\r\n            mensaje: 'Esta factura est├í en borrador. Puedes modificar todos los campos libremente.',\r\n        },\r\n        emitida: {\r\n            fechaVencimiento: true,\r\n            notas: true,\r\n            mensaje:\r\n                'Esta factura est├í emitida. Solo puedes modificar las notas internas y fechas de vencimiento. Para cambios mayores, considera crear una nota de cr├®dito.',\r\n        },\r\n        pagada: {\r\n            notas: true,\r\n            mensaje:\r\n                'Esta factura est├í pagada. Solo puedes modificar las notas internas. Para cambios mayores, crea una nota de cr├®dito.',\r\n        },\r\n    }\r\n\r\n    const permisos = estadoEditable[factura.estado] || {\r\n        mensaje: 'Esta factura no puede ser editada.',\r\n    }\r\n\r\n    const [fechaVencimiento, setFechaVencimiento] = useState<Date | undefined>(\r\n        factura.fecha_vencimiento ? new Date(factura.fecha_vencimiento) : undefined\r\n    )\r\n    const [notas, setNotas] = useState<string>(factura.notas || '')\r\n    // Mantener estado de l├¡neas (aunque edici├│n completa de l├¡neas se hace mejor en otra pantalla o componente dedicado si es complejo, \r\n    // aqu├¡ asumimos que lineas es est├ítico a menos que habilitemos edici├│n completa. \r\n    // Para simplificar, usamos las l├¡neas existentes para recalcular totales)\r\n    const [lineas, setLineas] = useState(factura.lineas || [])\r\n\r\n    // Estados para nuevos campos\r\n    const [descuentoTipo, setDescuentoTipo] = useState<'porcentaje' | 'fijo'>(factura.descuento_tipo || 'porcentaje')\r\n    const [descuentoValor, setDescuentoValor] = useState<number>(factura.descuento_valor || 0)\r\n    const [recargoEquivalencia, setRecargoEquivalencia] = useState<boolean>(factura.recargo_equivalencia || false)\r\n    const [recargoPorcentaje, setRecargoPorcentaje] = useState<number>(factura.recargo_porcentaje || 5.2)\r\n    const [retencionPorcentaje, setRetencionPorcentaje] = useState<number>(factura.retencion_porcentaje || 0)\r\n    const [divisa, setDivisa] = useState<string>(factura.divisa || 'EUR')\r\n    const [tipoCambio, setTipoCambio] = useState<number>(factura.tipo_cambio || 1.0)\r\n\r\n    const getSimboloDivisa = (cod: string) => {\r\n        switch (cod) {\r\n            case 'USD': return '$'\r\n            case 'GBP': return '┬ú'\r\n            default: return 'Ôé¼'\r\n        }\r\n    }\r\n\r\n    // Calcular Totales (Memoized)\r\n    const totales = useMemo(() => {\r\n        // Calcular subtotal de l├¡neas (por si acaso cambi├│ cantidad/precio en futuro)\r\n        // Por ahora usamos las l├¡neas tal cual.\r\n        // Nota: Si linea.subtotal viene de base, confiamos en ├®l, pero para recalcular descuentos globales necesitamos iterar.\r\n\r\n        let subtotal = 0\r\n        const lineasCalculadas = lineas.map(linea => {\r\n            // Re-calcular subtotal de l├¡nea para asegurar consistencia\r\n            const st = linea.cantidad * linea.precio_unitario * (1 - (linea.descuento_porcentaje || 0) / 100)\r\n            subtotal += st\r\n            return { ...linea, subtotalCalculado: st }\r\n        })\r\n\r\n        let descuentoGlobalMonto = 0\r\n        if (descuentoTipo === 'porcentaje') {\r\n            descuentoGlobalMonto = (subtotal * descuentoValor) / 100\r\n        } else {\r\n            descuentoGlobalMonto = descuentoValor\r\n        }\r\n        if (descuentoGlobalMonto > subtotal) descuentoGlobalMonto = subtotal\r\n\r\n        const baseImponible = subtotal - descuentoGlobalMonto\r\n\r\n        // Agrupar IVA\r\n        const ivasPorPorcentaje: Record<number, number> = {}\r\n        let totalIva = 0\r\n\r\n        lineasCalculadas.forEach(linea => {\r\n            // Prorrateo del descuento global\r\n            const ratioDescuento = subtotal > 0 ? descuentoGlobalMonto / subtotal : 0\r\n            const baseLinea = linea.subtotalCalculado * (1 - ratioDescuento)\r\n            const ivaLinea = baseLinea * (linea.iva_porcentaje / 100)\r\n\r\n            if (!ivasPorPorcentaje[linea.iva_porcentaje]) {\r\n                ivasPorPorcentaje[linea.iva_porcentaje] = 0\r\n            }\r\n            ivasPorPorcentaje[linea.iva_porcentaje] += ivaLinea\r\n            totalIva += ivaLinea\r\n        })\r\n\r\n        // Recargo\r\n        let importeRecargo = 0\r\n        if (recargoEquivalencia) {\r\n            importeRecargo = (baseImponible * recargoPorcentaje) / 100\r\n        }\r\n\r\n        // Retenci├│n\r\n        const importeRetencion = (baseImponible * retencionPorcentaje) / 100\r\n\r\n        const total = baseImponible + totalIva + importeRecargo - importeRetencion\r\n\r\n        return {\r\n            subtotal,\r\n            descuentoGlobalMonto,\r\n            baseImponible,\r\n            ivasPorPorcentaje,\r\n            totalIva,\r\n            importeRecargo,\r\n            importeRetencion,\r\n            total\r\n        }\r\n    }, [lineas, descuentoTipo, descuentoValor, recargoEquivalencia, recargoPorcentaje, retencionPorcentaje])\r\n\r\n    // Detectar cambios\r\n    const hayCambios =\r\n        (fechaVencimiento && format(fechaVencimiento, 'yyyy-MM-dd') !== factura.fecha_vencimiento) ||\r\n        notas !== (factura.notas || '') ||\r\n        serieSeleccionada !== (factura.serie_id || '') ||\r\n        selectedPlantillaId !== (factura.plantilla_pdf_id || '') ||\r\n        descuentoTipo !== (factura.descuento_tipo || 'porcentaje') ||\r\n        descuentoValor !== (factura.descuento_valor || 0) ||\r\n        recargoEquivalencia !== (factura.recargo_equivalencia || false) ||\r\n        recargoPorcentaje !== (factura.recargo_porcentaje || 5.2) ||\r\n        retencionPorcentaje !== (factura.retencion_porcentaje || 0) ||\r\n        divisa !== ((factura as any).divisa || 'EUR') ||\r\n        tipoCambio !== ((factura as any).tipo_cambio || 1.0)\r\n\r\n    const handleGuardar = async () => {\r\n        if (!hayCambios) {\r\n            toast.info('No hay cambios para guardar')\r\n            return\r\n        }\r\n\r\n        setIsSubmitting(true)\r\n\r\n        const formData = new FormData()\r\n        formData.append('factura_id', factura.id)\r\n        formData.append('empresa_id', empresaId)\r\n        if (fechaVencimiento) {\r\n            formData.append('fecha_vencimiento', format(fechaVencimiento, 'yyyy-MM-dd'))\r\n        }\r\n        formData.append('notas', notas)\r\n\r\n        // Siempre enviar plantilla si cambi├│\r\n        if (selectedPlantillaId !== (factura.plantilla_pdf_id || '')) {\r\n            formData.append('plantilla_pdf_id', selectedPlantillaId)\r\n        }\r\n\r\n        // Si es borrador, enviar tambi├®n las l├¡neas (si se editaran) y config financiera\r\n        if (permisos.todo) {\r\n            formData.append('serie', serieSeleccionada)\r\n            // Nuevos campos\r\n            formData.append('descuento_tipo', descuentoTipo)\r\n            formData.append('descuento_valor', descuentoValor.toString())\r\n            formData.append('recargo_equivalencia', recargoEquivalencia.toString())\r\n            formData.append('recargo_porcentaje', recargoPorcentaje.toString())\r\n            formData.append('retencion_porcentaje', retencionPorcentaje.toString())\r\n            formData.append('divisa', divisa)\r\n            formData.append('tipo_cambio', tipoCambio.toString())\r\n\r\n            // Si permitimos editar lineas, a├▒adirlas aqui\r\n            // formData.append('lineas', JSON.stringify(lineas))\r\n        }\r\n\r\n        const result = await editarFacturaAction(formData)\r\n\r\n        setIsSubmitting(false)\r\n\r\n        if (!result) {\r\n            toast.error('Error desconocido al actualizar factura')\r\n            return\r\n        }\r\n\r\n        if (result.success) {\r\n            toast.success('Factura actualizada correctamente')\r\n            router.refresh()\r\n        } else {\r\n            toast.error(result.error || 'Error al actualizar factura')\r\n        }\r\n    }\r\n\r\n    const getEstadoBadge = (estado: string) => {\r\n        const variants: Record<string, { label: string; className: string }> = {\r\n            borrador: { label: 'Borrador', className: 'bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300' },\r\n            emitida: { label: 'Emitida', className: 'bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300' },\r\n            pagada: { label: 'Pagada', className: 'bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300' },\r\n            anulada: { label: 'Anulada', className: 'bg-red-100 text-red-700 dark:bg-red-900 dark:text-red-300' },\r\n        }\r\n        const variant = variants[estado] || variants.borrador\r\n        return <Badge className={variant.className}>{variant.label}</Badge>\r\n    }\r\n\r\n    const formatCurrency = (amount: number) => {\r\n        return new Intl.NumberFormat('es-ES', {\r\n            style: 'currency',\r\n            currency: divisa,\r\n        }).format(amount)\r\n    }\r\n\r\n    return (\r\n        <div className=\"space-y-6\">\r\n            {/* Header */}\r\n            <div className=\"flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between\">\r\n                <div>\r\n                    <div className=\"flex items-center gap-3 mb-2\">\r\n                        <h1 className=\"text-3xl font-serif font-bold text-slate-900 dark:text-slate-100\">\r\n                            Editar Factura\r\n                        </h1>\r\n                        {getEstadoBadge(factura.estado)}\r\n                    </div>\r\n                    <p className=\"text-slate-600 dark:text-slate-400\">\r\n                        {factura.serie}-{factura.numero} ┬À {factura.cliente.nombre_fiscal}\r\n                    </p>\r\n                </div>\r\n\r\n                <div className=\"flex gap-2\">\r\n                    <Button\r\n                        variant=\"outline\"\r\n                        onClick={() => router.push(`/ventas/facturas/${factura.id}`)}\r\n                        disabled={isSubmitting}\r\n                    >\r\n                        Cancelar\r\n                    </Button>\r\n                    <Button onClick={handleGuardar} disabled={isSubmitting || !hayCambios}>\r\n                        {isSubmitting ? 'Guardando...' : 'Guardar Cambios'}\r\n                    </Button>\r\n                </div>\r\n            </div>\r\n\r\n            {/* Alert de restricciones */}\r\n            <Alert className=\"bg-blue-50 border-blue-200 dark:bg-blue-900/20 dark:border-blue-800\">\r\n                <Info className=\"h-4 w-4 text-blue-600\" />\r\n                <AlertDescription className=\"text-blue-900 dark:text-blue-100\">\r\n                    {permisos.mensaje}\r\n                </AlertDescription>\r\n            </Alert>\r\n\r\n            {/* Contenido en 2 columnas */}\r\n            <div className=\"grid gap-6 lg:grid-cols-3\">\r\n                {/* Columna Principal (2/3) */}\r\n                <div className=\"lg:col-span-2 space-y-6\">\r\n                    {/* Datos de la Factura */}\r\n                    <Card>\r\n                        <CardHeader>\r\n                            <CardTitle className=\"flex items-center gap-2\">\r\n                                <span className=\"text-slate-400\">­ƒôä</span>\r\n                                Datos de la Factura\r\n                            </CardTitle>\r\n                        </CardHeader>\r\n                        <CardContent className=\"space-y-4\">\r\n                            <div className=\"grid gap-4 sm:grid-cols-2\">\r\n                                {permisos.todo ? (\r\n                                    <Select value={serieSeleccionada} onValueChange={setSerieSeleccionada} disabled={loadingSeries}>\r\n                                        <SelectTrigger>\r\n                                            <SelectValue placeholder={loadingSeries ? \"Cargando...\" : \"Seleccionar serie\"} />\r\n                                        </SelectTrigger>\r\n                                        <SelectContent>\r\n                                            {series.map(s => (\r\n                                                <SelectItem key={s.id} value={s.id}>\r\n                                                    {s.nombre} ({s.codigo})\r\n                                                </SelectItem>\r\n                                            ))}\r\n                                        </SelectContent>\r\n                                    </Select>\r\n                                ) : (\r\n                                    <div className=\"space-y-2\">\r\n                                        <Label>Serie</Label>\r\n                                        <div className=\"flex items-center gap-2 p-2 bg-slate-50 border rounded-md\">\r\n                                            <Lock className=\"h-3 w-3 text-slate-400\" />\r\n                                            <span className=\"text-sm font-medium\">\r\n                                                {series.find(s => s.id === serieSeleccionada)?.codigo || factura.serie}\r\n                                            </span>\r\n                                        </div>\r\n                                    </div>\r\n                                )}\r\n\r\n                                <div className=\"space-y-2\">\r\n                                    <Label className=\"flex items-center gap-2\">\r\n                                        N├║mero\r\n                                        <Lock className=\"h-3 w-3 text-slate-400\" />\r\n                                    </Label>\r\n                                    <Input value={factura.numero} disabled className=\"bg-slate-50\" />\r\n                                </div>\r\n\r\n                                <div className=\"space-y-2\">\r\n                                    <Label className=\"flex items-center gap-2\">\r\n                                        Fecha Emisi├│n\r\n                                        <Lock className=\"h-3 w-3 text-slate-400\" />\r\n                                    </Label>\r\n                                    <Input\r\n                                        value={format(new Date(factura.fecha_emision), 'dd/MM/yyyy', { locale: es })}\r\n                                        disabled\r\n                                        className=\"bg-slate-50\"\r\n                                    />\r\n                                </div>\r\n\r\n                                <div className=\"space-y-2\">\r\n                                    <Label>Fecha Vencimiento</Label>\r\n                                    {permisos.fechaVencimiento ? (\r\n                                        <Popover>\r\n                                            <PopoverTrigger asChild>\r\n                                                <Button variant=\"outline\" className={cn(\"w-full justify-start text-left font-normal\", !fechaVencimiento && \"text-muted-foreground\")}>\r\n                                                    <CalendarIcon className=\"mr-2 h-4 w-4\" />\r\n                                                    {fechaVencimiento ? format(fechaVencimiento, \"dd/MM/yyyy\") : <span>Seleccionar fecha</span>}\r\n                                                </Button>\r\n                                            </PopoverTrigger>\r\n                                            <PopoverContent className=\"w-auto p-0\">\r\n                                                <Calendar\r\n                                                    mode=\"single\"\r\n                                                    selected={fechaVencimiento}\r\n                                                    onSelect={(date) => date && setFechaVencimiento(date)}\r\n                                                    initialFocus\r\n                                                />\r\n                                            </PopoverContent>\r\n                                        </Popover>\r\n                                    ) : (\r\n                                        <Input\r\n                                            value={fechaVencimiento ? format(fechaVencimiento, 'dd/MM/yyyy', { locale: es }) : '-'}\r\n                                            disabled\r\n                                            className=\"bg-slate-50\"\r\n                                        />\r\n                                    )}\r\n                                </div>\r\n\r\n                                {/* Selecci├│n de Plantilla PDF */}\r\n                                <div className=\"space-y-2\">\r\n                                    <Label>Plantilla PDF</Label>\r\n                                    <PlantillaSelector\r\n                                        empresaId={empresaId}\r\n                                        value={selectedPlantillaId}\r\n                                        onChange={setSelectedPlantillaId}\r\n                                    />\r\n                                </div>\r\n                            </div>\r\n                        </CardContent>\r\n                    </Card>\r\n\r\n                    {/* RFC-029: Divisa y Tipo de Cambio */}\r\n                    <Card>\r\n                        <CardHeader>\r\n                            <CardTitle className=\"flex items-center gap-2\">\r\n                                <span className=\"text-slate-400\">­ƒÆ▒</span>\r\n                                Divisa y Cambio\r\n                                {!permisos.todo && <Lock className=\"h-3 w-3 text-slate-400\" />}\r\n                            </CardTitle>\r\n                        </CardHeader>\r\n                        <CardContent className=\"space-y-4\">\r\n                            <div className=\"space-y-2\">\r\n                                <Label>Divisa de la Factura</Label>\r\n                                <Select\r\n                                    value={divisa}\r\n                                    onValueChange={setDivisa}\r\n                                    disabled={!permisos.todo}\r\n                                >\r\n                                    <SelectTrigger className=\"bg-white\">\r\n                                        <SelectValue />\r\n                                    </SelectTrigger>\r\n                                    <SelectContent>\r\n                                        <SelectItem value=\"EUR\">Euro (Ôé¼)</SelectItem>\r\n                                        <SelectItem value=\"USD\">D├│lar ($)</SelectItem>\r\n                                        <SelectItem value=\"GBP\">Libra (┬ú)</SelectItem>\r\n                                    </SelectContent>\r\n                                </Select>\r\n                            </div>\r\n                            {divisa !== 'EUR' && (\r\n                                <div className=\"space-y-2 animate-in slide-in-from-left-2\">\r\n                                    <Label>Tipo de Cambio (1 EUR = ? {divisa})</Label>\r\n                                    <Input\r\n                                        type=\"number\"\r\n                                        step=\"0.0001\"\r\n                                        value={tipoCambio}\r\n                                        onChange={(e) => setTipoCambio(parseFloat(e.target.value))}\r\n                                        disabled={!permisos.todo}\r\n                                        className=\"bg-white\"\r\n                                    />\r\n                                    <p className=\"text-[10px] text-slate-500 italic\">\r\n                                        Solo para referencia contable interna.\r\n                                    </p>\r\n                                </div>\r\n                            )}\r\n                        </CardContent>\r\n                    </Card>\r\n\r\n                    {/* Cliente */}\r\n                    <Card>\r\n                        <CardHeader>\r\n                            <CardTitle className=\"flex items-center gap-2\">\r\n                                <span className=\"text-slate-400\">­ƒæñ</span>\r\n                                Cliente\r\n                                <Lock className=\"h-3 w-3 text-slate-400\" />\r\n                            </CardTitle>\r\n                        </CardHeader>\r\n                        <CardContent>\r\n                            <div className=\"rounded-lg bg-slate-50 dark:bg-slate-800 p-4\">\r\n                                <div className=\"flex items-center gap-3 mb-2\">\r\n                                    <div className=\"h-10 w-10 rounded-full bg-slate-200 dark:bg-slate-700 flex items-center justify-center font-semibold\">\r\n                                        {factura.cliente.nombre_fiscal.substring(0, 2).toUpperCase()}\r\n                                    </div>\r\n                                    <div>\r\n                                        <p className=\"font-semibold\">{factura.cliente.nombre_fiscal}</p>\r\n                                        <p className=\"text-sm text-slate-600 dark:text-slate-400\">\r\n                                            CIF: {factura.cliente.cif} ┬À {factura.cliente.direccion || 'Sin direcci├│n'}\r\n                                        </p>\r\n                                    </div>\r\n                                </div>\r\n                            </div>\r\n                        </CardContent>\r\n                    </Card>\r\n\r\n                    {/* L├¡neas de Factura */}\r\n                    <Card>\r\n                        <CardHeader>\r\n                            <CardTitle className=\"flex items-center justify-between\">\r\n                                <span className=\"flex items-center gap-2\">\r\n                                    <span className=\"text-slate-400\">­ƒôï</span>\r\n                                    L├¡neas de Factura\r\n                                </span>\r\n                                {!permisos.todo && (\r\n                                    <span className=\"text-xs text-slate-500 font-normal\">\r\n                                        No puedes modificar l├¡neas de una factura emitida\r\n                                    </span>\r\n                                )}\r\n                            </CardTitle>\r\n                        </CardHeader>\r\n                        <CardContent>\r\n                            <div className=\"overflow-x-auto\">\r\n                                <table className=\"w-full\">\r\n                                    <thead>\r\n                                        <tr className=\"border-b\">\r\n                                            <th className=\"text-left p-2 text-sm font-medium\">Concepto</th>\r\n                                            <th className=\"text-center p-2 text-sm font-medium w-20\">Cantidad</th>\r\n                                            <th className=\"text-right p-2 text-sm font-medium w-28\">Precio</th>\r\n                                            <th className=\"text-center p-2 text-sm font-medium w-20\">IVA</th>\r\n                                            <th className=\"text-right p-2 text-sm font-medium w-28\">Total</th>\r\n                                        </tr>\r\n                                    </thead>\r\n                                    <tbody>\r\n                                        {lineas.map((linea, index) => (\r\n                                            <tr key={index} className=\"border-b\">\r\n                                                <td className=\"p-2\">\r\n                                                    <div>\r\n                                                        <p className=\"font-medium\">{linea.concepto}</p>\r\n                                                        {linea.descripcion && (\r\n                                                            <p className=\"text-xs text-slate-500\">{linea.descripcion}</p>\r\n                                                        )}\r\n                                                    </div>\r\n                                                </td>\r\n                                                <td className=\"p-2 text-center\">{linea.cantidad}</td>\r\n                                                <td className=\"p-2 text-right\">{formatCurrency(linea.precio_unitario)}</td>\r\n                                                <td className=\"p-2 text-center\">{linea.iva_porcentaje}%</td>\r\n                                                <td className=\"p-2 text-right font-semibold\">\r\n                                                    {formatCurrency(linea.cantidad * linea.precio_unitario * (1 - (linea.descuento_porcentaje || 0) / 100))}\r\n                                                </td>\r\n                                            </tr>\r\n                                        ))}\r\n                                    </tbody>\r\n                                </table>\r\n                            </div>\r\n                        </CardContent>\r\n                    </Card>\r\n                </div>\r\n\r\n                {/* Columna Lateral (1/3) */}\r\n                <div className=\"space-y-6\">\r\n                    {/* Resumen Econ├│mico */}\r\n                    <Card className=\"bg-slate-50 dark:bg-slate-800\">\r\n                        <CardHeader>\r\n                            <CardTitle className=\"text-sm\">Resumen Econ├│mico</CardTitle>\r\n                        </CardHeader>\r\n                        <CardContent className=\"space-y-3\">\r\n                            <div className=\"flex justify-between text-sm\">\r\n                                <span className=\"text-slate-600 dark:text-slate-400\">Subtotal</span>\r\n                                <span className=\"font-medium\">{formatCurrency(totales.subtotal)}</span>\r\n                            </div>\r\n\r\n                            {/* Descuento Global */}\r\n                            <div className=\"space-y-3 pt-2 border-t\">\r\n                                <div className=\"flex items-center justify-between text-sm\">\r\n                                    <Label className=\"text-slate-600 font-normal\">Descuento Global</Label>\r\n                                    {permisos.todo ? (\r\n                                        <div className=\"flex gap-2\">\r\n                                            <div className=\"flex items-center rounded-md border border-slate-200 bg-white\">\r\n                                                <button\r\n                                                    type=\"button\"\r\n                                                    onClick={() => setDescuentoTipo('porcentaje')}\r\n                                                    className={`px-2 py-1 text-xs rounded-l-md ${descuentoTipo === 'porcentaje' ? 'bg-primary text-primary-foreground' : 'text-slate-500 hover:text-slate-900'}`}\r\n                                                >\r\n                                                    <Percent className=\"h-3 w-3\" />\r\n                                                </button>\r\n                                                <button\r\n                                                    type=\"button\"\r\n                                                    onClick={() => setDescuentoTipo('fijo')}\r\n                                                    className={`px-2 py-1 text-xs rounded-r-md ${descuentoTipo === 'fijo' ? 'bg-primary text-primary-foreground' : 'text-slate-500 hover:text-slate-900'}`}\r\n                                                >\r\n                                                    <Euro className=\"h-3 w-3\" />\r\n                                                </button>\r\n                                            </div>\r\n                                            <Input\r\n                                                type=\"number\"\r\n                                                min=\"0\"\r\n                                                value={descuentoValor}\r\n                                                onChange={(e) => setDescuentoValor(parseFloat(e.target.value) || 0)}\r\n                                                className=\"w-20 h-8 text-right bg-white\"\r\n                                            />\r\n                                        </div>\r\n                                    ) : (\r\n                                        <span className=\"text-sm font-medium text-slate-700\">\r\n                                            {totales.descuentoGlobalMonto > 0 ? `-${formatCurrency(totales.descuentoGlobalMonto)}` : '-'}\r\n                                        </span>\r\n                                    )}\r\n                                </div>\r\n                                {permisos.todo && totales.descuentoGlobalMonto > 0 && (\r\n                                    <div className=\"flex justify-between text-sm text-green-600\">\r\n                                        <span>Descuento aplicado</span>\r\n                                        <span>-{formatCurrency(totales.descuentoGlobalMonto)}</span>\r\n                                    </div>\r\n                                )}\r\n                            </div>\r\n\r\n                            <Separator />\r\n\r\n                            <div className=\"flex justify-between text-sm\">\r\n                                <span className=\"text-slate-600 dark:text-slate-400\">Base Imponible</span>\r\n                                <span className=\"font-medium\">{formatCurrency(totales.baseImponible)}</span>\r\n                            </div>\r\n\r\n                            {Object.entries(totales.ivasPorPorcentaje).map(([porcentaje, monto]) => (\r\n                                <div key={porcentaje} className=\"flex justify-between text-sm\">\r\n                                    <span className=\"text-slate-600 dark:text-slate-400\">IVA ({porcentaje}%)</span>\r\n                                    <span>{formatCurrency(monto)}</span>\r\n                                </div>\r\n                            ))}\r\n\r\n                            {/* Recargo */}\r\n                            <div className=\"space-y-3 pt-2 border-t\">\r\n                                <div className=\"flex items-center justify-between text-sm\">\r\n                                    <div className=\"flex items-center gap-2\">\r\n                                        <Label htmlFor=\"recargo\" className=\"text-slate-600 font-normal\">Recargo Eq.</Label>\r\n                                        {permisos.todo ? (\r\n                                            <Switch id=\"recargo\" checked={recargoEquivalencia} onCheckedChange={setRecargoEquivalencia} />\r\n                                        ) : recargoEquivalencia ? <Badge variant=\"outline\">S├¡</Badge> : null}\r\n                                    </div>\r\n                                    {recargoEquivalencia && (\r\n                                        <div className=\"flex items-center gap-1 text-xs text-slate-500\">\r\n                                            {permisos.todo ? (\r\n                                                <Input\r\n                                                    type=\"number\"\r\n                                                    value={recargoPorcentaje}\r\n                                                    onChange={(e) => setRecargoPorcentaje(parseFloat(e.target.value) || 0)}\r\n                                                    className=\"w-16 h-7 text-right\"\r\n                                                />\r\n                                            ) : (\r\n                                                <span>{recargoPorcentaje}%</span>\r\n                                            )}\r\n                                        </div>\r\n                                    )}\r\n                                </div>\r\n                                {recargoEquivalencia && totales.importeRecargo > 0 && (\r\n                                    <div className=\"flex justify-between text-sm\">\r\n                                        <span className=\"text-slate-600\">Recargo ({recargoPorcentaje}%)</span>\r\n                                        <span>{formatCurrency(totales.importeRecargo)}</span>\r\n                                    </div>\r\n                                )}\r\n                            </div>\r\n\r\n                            {/* Retenci├│n */}\r\n                            <div className=\"space-y-3 pt-2 border-t\">\r\n                                <div className=\"flex items-center justify-between text-sm\">\r\n                                    <Label className=\"text-slate-600 font-normal\">Retenci├│n IRPF (%)</Label>\r\n                                    {permisos.todo ? (\r\n                                        <Input\r\n                                            type=\"number\"\r\n                                            min=\"0\"\r\n                                            max=\"100\"\r\n                                            value={retencionPorcentaje}\r\n                                            onChange={(e) => setRetencionPorcentaje(parseFloat(e.target.value) || 0)}\r\n                                            className=\"w-20 h-8 text-right bg-white\"\r\n                                        />\r\n                                    ) : (\r\n                                        <span className=\"font-medium\">{retencionPorcentaje}%</span>\r\n                                    )}\r\n                                </div>\r\n                                {retencionPorcentaje > 0 && (\r\n                                    <div className=\"flex justify-between text-sm text-orange-600\">\r\n                                        <span>Retenci├│n (-{retencionPorcentaje}%)</span>\r\n                                        <span>-{formatCurrency(totales.importeRetencion)}</span>\r\n                                    </div>\r\n                                )}\r\n                            </div>\r\n\r\n                            <div className=\"flex justify-between items-center pt-2 border-t mt-4\">\r\n                                <span className=\"font-semibold\">Total</span>\r\n                                <span className=\"text-2xl font-bold text-primary\">\r\n                                    {formatCurrency(totales.total)}\r\n                                </span>\r\n                            </div>\r\n                        </CardContent>\r\n                    </Card>\r\n\r\n                    {/* Notas Internas */}\r\n                    <Card>\r\n                        <CardHeader>\r\n                            <CardTitle className=\"flex items-center gap-2 text-sm\">\r\n                                <span className=\"text-slate-400\">­ƒôØ</span>\r\n                                Notas Internas\r\n                            </CardTitle>\r\n                        </CardHeader>\r\n                        <CardContent>\r\n                            <Textarea\r\n                                value={notas}\r\n                                onChange={(e) => setNotas(e.target.value)}\r\n                                placeholder=\"A├▒adir nota privada sobre esta factura...\"\r\n                                rows={4}\r\n                                disabled={!permisos.notas && !permisos.todo}\r\n                            />\r\n                            <p className=\"text-xs text-slate-500 mt-2\">\r\n                                Solo visible para personal administrativo\r\n                            </p>\r\n                        </CardContent>\r\n                    </Card>\r\n\r\n                    {/* Historial de Cambios */}\r\n                    <HistorialCambiosCard cambios={cambios} />\r\n                </div>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\components\\ventas\\email\\email-activity-card.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":7,"column":16,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":7,"endColumn":19,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[284,287],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[284,287],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card'\r\nimport { formatDistanceToNow } from 'date-fns'\r\nimport { es } from 'date-fns/locale'\r\nimport { Mail, AlertCircle, CheckCircle2 } from 'lucide-react'\r\n\r\ninterface EmailActivityCardProps {\r\n    historial: any[]\r\n}\r\n\r\nexport function EmailActivityCard({ historial }: EmailActivityCardProps) {\r\n    return (\r\n        <Card>\r\n            <CardHeader>\r\n                <CardTitle className=\"text-sm uppercase tracking-wider text-slate-500 font-bold\">Historial de actividad</CardTitle>\r\n            </CardHeader>\r\n            <CardContent>\r\n                {historial.length === 0 ? (\r\n                    <div className=\"text-center py-8 text-slate-500 text-sm\">\r\n                        No hay actividad de emails registrada.\r\n                    </div>\r\n                ) : (\r\n                    <div className=\"space-y-4\">\r\n                        {historial.map((email) => (\r\n                            <div key={email.id} className=\"flex gap-3 items-start\">\r\n                                <div className={`mt-0.5 w-6 h-6 rounded-full flex items-center justify-center shrink-0 ${email.estado === 'enviado' ? 'bg-green-100 text-green-600' :\r\n                                        email.estado === 'error' ? 'bg-red-100 text-red-600' : 'bg-slate-100 text-slate-600'\r\n                                    }`}>\r\n                                    {email.estado === 'enviado' ? <CheckCircle2 className=\"w-3.5 h-3.5\" /> :\r\n                                        email.estado === 'error' ? <AlertCircle className=\"w-3.5 h-3.5\" /> : <Mail className=\"w-3.5 h-3.5\" />}\r\n                                </div>\r\n                                <div className=\"space-y-1\">\r\n                                    <p className=\"text-sm font-medium text-slate-900 dark:text-slate-100\">\r\n                                        {email.estado === 'enviado' ? 'Email enviado' : 'Error en env├¡o'}\r\n                                    </p>\r\n                                    <p className=\"text-xs text-slate-500\">\r\n                                        Para: {email.para.join(', ')}\r\n                                    </p>\r\n                                    <p className=\"text-[10px] text-slate-400\">\r\n                                        {formatDistanceToNow(new Date(email.created_at), { addSuffix: true, locale: es })}\r\n                                    </p>\r\n                                </div>\r\n                            </div>\r\n                        ))}\r\n                    </div>\r\n                )}\r\n            </CardContent>\r\n        </Card>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\components\\ventas\\email\\email-send-form.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":17,"column":14,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":17,"endColumn":17,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[669,672],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[669,672],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":18,"column":14,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":18,"endColumn":17,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[687,690],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[687,690],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'_incluirLogo' is defined but never used.","line":23,"column":81,"nodeType":"Identifier","messageId":"unusedVar","endLine":23,"endColumn":93},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'_error' is defined but never used.","line":58,"column":18,"nodeType":"Identifier","messageId":"unusedVar","endLine":58,"endColumn":24}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useState } from 'react'\r\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card'\r\nimport { Button } from '@/components/ui/button'\r\nimport { Input } from '@/components/ui/input'\r\nimport { Textarea } from '@/components/ui/textarea'\r\nimport { Label } from '@/components/ui/label'\r\nimport { Badge } from '@/components/ui/badge'\r\nimport { Checkbox } from '@/components/ui/checkbox'\r\nimport { Send, FileText, Loader2 } from 'lucide-react'\r\nimport { sendFacturaEmailAction } from '@/app/actions/email'\r\nimport { toast } from 'sonner'\r\nimport { useRouter } from 'next/navigation'\r\n\r\ninterface EmailSendFormProps {\r\n    factura: any\r\n    cliente: any\r\n    messageTemplate: string\r\n    incluirLogo: boolean\r\n}\r\n\r\nexport function EmailSendForm({ factura, cliente, messageTemplate, incluirLogo: _incluirLogo }: EmailSendFormProps) {\r\n    const router = useRouter()\r\n    const [sending, setSending] = useState(false)\r\n    const [to, setTo] = useState(cliente.email || '')\r\n    const [cc, setCC] = useState('')\r\n    const [subject, setSubject] = useState(`Factura ${factura.serie}-${factura.numero} - STV Logistics`)\r\n    const [message, setMessage] = useState(messageTemplate)\r\n    const [sendCopy, setSendCopy] = useState(true)\r\n\r\n    // Update message when template changes (if simple implementation)\r\n    // In a real app, use useEffect with care to not overwrite user edits\r\n\r\n    const handleSubmit = async (e: React.FormEvent) => {\r\n        e.preventDefault()\r\n        setSending(true)\r\n\r\n        const formData = new FormData()\r\n        formData.append('facturaId', factura.id)\r\n        formData.append('to', to)\r\n        formData.append('cc', cc)\r\n        formData.append('subject', subject)\r\n        formData.append('message', message)\r\n        if (sendCopy) formData.append('sendCopy', 'on')\r\n        // incluirLogo logic handled in template rendering or just stored in DB\r\n\r\n        try {\r\n            const result = await sendFacturaEmailAction(formData)\r\n\r\n            if (result.success) {\r\n                toast.success('Factura enviada correctamente')\r\n                router.refresh()\r\n                router.push(`/ventas/facturas/${factura.id}`)\r\n            } else {\r\n                toast.error('Error al enviar el email: ' + result.error)\r\n            }\r\n        } catch (_error) {\r\n            toast.error('Ocurri├│ un error inesperado')\r\n        } finally {\r\n            setSending(false)\r\n        }\r\n    }\r\n\r\n    return (\r\n        <form onSubmit={handleSubmit} className=\"space-y-6\">\r\n            <Card>\r\n                <CardHeader>\r\n                    <CardTitle className=\"text-lg flex items-center gap-2\">\r\n                        <Send className=\"h-5 w-5 text-slate-500\" />\r\n                        Datos del env├¡o\r\n                    </CardTitle>\r\n                </CardHeader>\r\n                <CardContent className=\"space-y-4\">\r\n                    <div className=\"space-y-2\">\r\n                        <Label>Para</Label>\r\n                        <div className=\"flex flex-wrap gap-2 mb-2\">\r\n                            {cliente.email && (\r\n                                <Badge variant=\"secondary\" className=\"px-3 py-1 bg-primary/10 text-primary border-primary/20 hover:bg-primary/20\">\r\n                                    {cliente.email}\r\n                                    <span className=\"ml-2 text-[10px] font-bold opacity-60\">RECOMENDADO</span>\r\n                                </Badge>\r\n                            )}\r\n                        </div>\r\n                        <Input\r\n                            value={to}\r\n                            onChange={(e) => setTo(e.target.value)}\r\n                            placeholder=\"ej. cliente@empresa.com, contabilidad@empresa.com\"\r\n                        />\r\n                        <p className=\"text-[10px] text-slate-400\">Separa m├║ltiples direcciones con comas</p>\r\n                    </div>\r\n\r\n                    <div className=\"space-y-2\">\r\n                        <Label>CC</Label>\r\n                        <Input\r\n                            value={cc}\r\n                            onChange={(e) => setCC(e.target.value)}\r\n                            placeholder=\"Copia a...\"\r\n                        />\r\n                    </div>\r\n\r\n                    <div className=\"space-y-2\">\r\n                        <Label>Asunto</Label>\r\n                        <Input\r\n                            value={subject}\r\n                            onChange={(e) => setSubject(e.target.value)}\r\n                        />\r\n                    </div>\r\n\r\n                    <div className=\"space-y-2\">\r\n                        <Label>Mensaje</Label>\r\n                        <Textarea\r\n                            value