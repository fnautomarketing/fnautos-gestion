      </Card>\r\n\r\n                        <Card>\r\n                            <CardHeader>\r\n                                <CardTitle>Estado y Visibilidad</CardTitle>\r\n                            </CardHeader>\r\n                            <CardContent className=\"space-y-4\">\r\n                                <FormField\r\n                                    control={form.control}\r\n                                    name=\"activo\"\r\n                                    render={({ field }) => (\r\n                                        <FormItem className=\"flex flex-row items-start space-x-3 space-y-0 rounded-md border p-4\">\r\n                                            <FormControl>\r\n                                                <Checkbox\r\n                                                    checked={field.value}\r\n                                                    onCheckedChange={field.onChange}\r\n                                                />\r\n                                            </FormControl>\r\n                                            <div className=\"space-y-1 leading-none\">\r\n                                                <FormLabel>\r\n                                                    Activo\r\n                                                </FormLabel>\r\n                                                <FormDescription>\r\n                                                    Visible en el selector de facturas.\r\n                                                </FormDescription>\r\n                                            </div>\r\n                                        </FormItem>\r\n                                    )}\r\n                                />\r\n                                <FormField\r\n                                    control={form.control}\r\n                                    name=\"destacado\"\r\n                                    render={({ field }) => (\r\n                                        <FormItem className=\"flex flex-row items-start space-x-3 space-y-0 rounded-md border p-4\">\r\n                                            <FormControl>\r\n                                                <Checkbox\r\n                                                    checked={field.value}\r\n                                                    onCheckedChange={field.onChange}\r\n                                                />\r\n                                            </FormControl>\r\n                                            <div className=\"space-y-1 leading-none\">\r\n                                                <FormLabel>\r\n                                                    Destacado\r\n                                                </FormLabel>\r\n                                                <FormDescription>\r\n                                                    Aparece al inicio de las listas.\r\n                                                </FormDescription>\r\n                                            </div>\r\n                                        </FormItem>\r\n                                    )}\r\n                                />\r\n                            </CardContent>\r\n                        </Card>\r\n                    </div>\r\n                </div>\r\n            </form>\r\n        </Form>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\components\\conceptos\\conceptos-stats.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\components\\conceptos\\conceptos-tabla.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":16,"column":16,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":16,"endColumn":19,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[760,763],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[760,763],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useState } from 'react'\r\nimport { useRouter, useSearchParams } from 'next/navigation'\r\nimport { Button } from '@/components/ui/button'\r\nimport { Badge } from '@/components/ui/badge'\r\nimport { Input } from '@/components/ui/input'\r\nimport { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select'\r\nimport { DropdownMenu, DropdownMenuContent, DropdownMenuItem, DropdownMenuTrigger } from '@/components/ui/dropdown-menu'\r\nimport { MoreVertical, Edit, Copy, Trash2, TrendingUp } from 'lucide-react'\r\nimport { toast } from 'sonner'\r\nimport { eliminarConceptoAction, duplicarConceptoAction } from '@/app/actions/conceptos'\r\nimport Link from 'next/link'\r\n\r\ninterface ConceptosTablaProps {\r\n    conceptos: any[]\r\n}\r\n\r\nexport function ConceptosTabla({ conceptos }: ConceptosTablaProps) {\r\n    const router = useRouter()\r\n    const searchParams = useSearchParams()\r\n    const [search, setSearch] = useState(searchParams.get('search') || '')\r\n\r\n    const getCategoriaColor = (categoria: string) => {\r\n        const colores: Record<string, string> = {\r\n            transporte: 'bg-blue-100 text-blue-700 hover:bg-blue-100/80',\r\n            almacenaje: 'bg-green-100 text-green-700 hover:bg-green-100/80',\r\n            logistica: 'bg-purple-100 text-purple-700 hover:bg-purple-100/80',\r\n            material: 'bg-orange-100 text-orange-700 hover:bg-orange-100/80',\r\n            otros: 'bg-slate-100 text-slate-700 hover:bg-slate-100/80',\r\n        }\r\n        return colores[categoria] || colores.otros\r\n    }\r\n\r\n    const getCategoriaIcon = (categoria: string) => {\r\n        const iconos: Record<string, string> = {\r\n            transporte: '­ƒÜÜ',\r\n            almacenaje: '­ƒôª',\r\n            logistica: '­ƒôï',\r\n            material: '­ƒöº',\r\n            otros: '­ƒôä',\r\n        }\r\n        return iconos[categoria] || '­ƒôä'\r\n    }\r\n\r\n    const handleDuplicar = async (conceptoId: string) => {\r\n        const result = await duplicarConceptoAction(conceptoId)\r\n        if (result.success) {\r\n            toast.success('Concepto duplicado')\r\n            router.refresh()\r\n        } else {\r\n            toast.error(result.error)\r\n        }\r\n    }\r\n\r\n    const handleEliminar = async (conceptoId: string) => {\r\n        if (!confirm('┬┐Eliminar este concepto? Esta acci├│n no se puede deshacer.')) return\r\n\r\n        const result = await eliminarConceptoAction(conceptoId)\r\n        if (result.success) {\r\n            toast.success('Concepto eliminado')\r\n            router.refresh()\r\n        } else {\r\n            toast.error(result.error)\r\n        }\r\n    }\r\n\r\n    // Handle filters update\r\n    const updateFilters = (key: string, value: string) => {\r\n        const params = new URLSearchParams(searchParams.toString())\r\n        if (value && value !== 'todas' && value !== 'todos') {\r\n            params.set(key, value)\r\n        } else {\r\n            params.delete(key)\r\n        }\r\n        router.push(`?${params.toString()}`)\r\n    }\r\n\r\n    // Handle search with debounce ideally, but direct push for now\r\n    const handleSearch = (e: React.KeyboardEvent<HTMLInputElement>) => {\r\n        if (e.key === 'Enter') {\r\n            updateFilters('search', search)\r\n        }\r\n    }\r\n\r\n    return (\r\n        <div className=\"space-y-4\">\r\n            {/* Filtros */}\r\n            <div className=\"flex flex-wrap gap-4 items-center bg-white p-4 rounded-xl shadow-sm border border-slate-100 dark:bg-slate-900 dark:border-slate-800\">\r\n                <div className=\"flex-1 min-w-[200px]\">\r\n                    <Input\r\n                        placeholder=\"Buscar por c├│digo, concepto...\"\r\n                        value={search}\r\n                        onChange={(e) => setSearch(e.target.value)}\r\n                        onKeyDown={handleSearch}\r\n                        className=\"w-full\"\r\n                    />\r\n                </div>\r\n\r\n                <Select\r\n                    defaultValue={searchParams.get('categoria') || 'todas'}\r\n                    onValueChange={(val) => updateFilters('categoria', val)}\r\n                >\r\n                    <SelectTrigger className=\"w-[180px]\">\r\n                        <SelectValue placeholder=\"Categor├¡a\" />\r\n                    </SelectTrigger>\r\n                    <SelectContent>\r\n                        <SelectItem value=\"todas\">Todas</SelectItem>\r\n                        <SelectItem value=\"transporte\">Transporte</SelectItem>\r\n                        <SelectItem value=\"almacenaje\">Almacenaje</SelectItem>\r\n                        <SelectItem value=\"logistica\">Log├¡stica</SelectItem>\r\n                        <SelectItem value=\"material\">Material</SelectItem>\r\n                        <SelectItem value=\"otros\">Otros</SelectItem>\r\n                    </SelectContent>\r\n                </Select>\r\n\r\n                <Select\r\n                    defaultValue={searchParams.get('tipo') || 'todos'}\r\n                    onValueChange={(val) => updateFilters('tipo', val)}\r\n                >\r\n                    <SelectTrigger className=\"w-[150px]\">\r\n                        <SelectValue placeholder=\"Tipo\" />\r\n                    </SelectTrigger>\r\n                    <SelectContent>\r\n                        <SelectItem value=\"todos\">Todos</SelectItem>\r\n                        <SelectItem value=\"servicio\">Servicio</SelectItem>\r\n                        <SelectItem value=\"producto\">Producto</SelectItem>\r\n                    </SelectContent>\r\n                </Select>\r\n\r\n                <Button\r\n                    variant=\"ghost\"\r\n                    size=\"sm\"\r\n                    onClick={() => {\r\n                        setSearch('')\r\n                        router.push('?')\r\n                    }}\r\n                >\r\n                    Limpiar Filtros\r\n                </Button>\r\n            </div>\r\n\r\n            {/* Tabla */}\r\n            <div className=\"rounded-2xl bg-white border border-slate-200 overflow-hidden shadow-sm dark:bg-slate-900 dark:border-slate-800\">\r\n                <table className=\"w-full\">\r\n                    <thead className=\"bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-800\">\r\n                        <tr>\r\n                            <th className=\"p-4 text-left text-xs font-semibold uppercase tracking-wide text-slate-500\">C├│digo</th>\r\n                            <th className=\"p-4 text-left text-xs font-semibold uppercase tracking-wide text-slate-500\">Concepto</th>\r\n                            <th className=\"p-4 text-left text-xs font-semibold uppercase tracking-wide text-slate-500\">Categor├¡a</th>\r\n                            <th className=\"p-4 text-left text-xs font-semibold uppercase tracking-wide text-slate-500\">Tipo</th>\r\n                            <th className=\"p-4 text-right text-xs font-semibold uppercase tracking-wide text-slate-500\">Precio Base</th>\r\n                            <th className=\"p-4 text-center text-xs font-semibold uppercase tracking-wide text-slate-500\">IVA</th>\r\n                            <th className=\"p-4 text-right text-xs font-semibold uppercase tracking-wide text-slate-500\">Total</th>\r\n                            <th className=\"p-4 text-center text-xs font-semibold uppercase tracking-wide text-slate-500\">Usado</th>\r\n                            <th className=\"p-4 text-center text-xs font-semibold uppercase tracking-wide text-slate-500\">Acciones</th>\r\n                        </tr>\r\n                    </thead>\r\n                    <tbody className=\"divide-y divide-slate-100 dark:divide-slate-800\">\r\n                        {conceptos.map((concepto) => {\r\n                            const precioTotal = (concepto.precio_base || 0) * (1 + (concepto.iva_porcentaje || 0) / 100)\r\n                            return (\r\n                                <tr key={concepto.id} className=\"hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors group\">\r\n                                    <td className=\"p-4 font-mono text-sm text-slate-500\">{concepto.codigo}</td>\r\n                                    <td className=\"p-4\">\r\n                                        <p className=\"font-semibold text-slate-900 dark:text-slate-100\">{concepto.nombre}</p>\r\n                                        {concepto.descripcion && <p className=\"text-sm text-slate-500 line-clamp-1\">{concepto.descripcion}</p>}\r\n                                    </td>\r\n                                    <td className=\"p-4\">\r\n                                        <Badge variant=\"secondary\" className={`font-medium border-0 ${getCategoriaColor(concepto.categoria)}`}>\r\n                                            <span className=\"mr-1\">{getCategoriaIcon(concepto.categoria)}</span> {concepto.categoria}\r\n                                        </Badge>\r\n                                    </td>\r\n                                    <td className=\"p-4 capitalize text-sm text-slate-600 dark:text-slate-400\">{concepto.tipo}</td>\r\n                                    <td className=\"p-4 text-right font-medium text-slate-700 dark:text-slate-300\">\r\n                                        {(concepto.precio_base || 0).toLocaleString('es-ES', { minimumFractionDigits: 2 })}Ôé¼\r\n                                    </td>\r\n                                    <td className=\"p-4 text-center text-sm text-slate-500\">{concepto.iva_porcentaje}%</td>\r\n                                    <td className=\"p-4 text-right font-bold text-slate-900 dark:text-slate-100\">\r\n                                        {precioTotal.toLocaleString('es-ES', { minimumFractionDigits: 2 })}Ôé¼\r\n                                    </td>\r\n                                    <td className=\"p-4 text-center\">\r\n                                        <div className=\"flex justify-center\">\r\n                                            <Badge variant=\"outline\" className=\"flex items-center gap-1 font-normal bg-slate-50 dark:bg-slate-900\">\r\n                                                <TrendingUp className=\"h-3 w-3 text-slate-400\" />\r\n                                                {concepto.veces_usado || 0}\r\n                                            </Badge>\r\n                                        </div>\r\n                                    </td>\r\n                                    <td className=\"p-4 text-center\">\r\n                                        <DropdownMenu>\r\n                                            <DropdownMenuTrigger asChild>\r\n                                                <Button variant=\"ghost\" size=\"icon\" className=\"h-8 w-8 opacity-0 group-hover:opacity-100 transition-opacity\">\r\n                                                    <MoreVertical className=\"h-4 w-4\" />\r\n                                                </Button>\r\n                                            </DropdownMenuTrigger>\r\n                                            <DropdownMenuContent align=\"end\">\r\n                                                <DropdownMenuItem asChild>\r\n                                                    <Link href={`/ventas/configuracion/conceptos/${concepto.id}/editar`} className=\"cursor-pointer font-medium\">\r\n                                                        <Edit className=\"h-4 w-4 mr-2\" /> Editar\r\n                                                    </Link>\r\n                                                </DropdownMenuItem>\r\n                                                <DropdownMenuItem onClick={() => handleDuplicar(concepto.id)} className=\"cursor-pointer\">\r\n                                                    <Copy className=\"h-4 w-4 mr-2\" /> Duplicar\r\n                                                </DropdownMenuItem>\r\n                                                <DropdownMenuItem className=\"text-red-600 cursor-pointer focus:text-red-600 focus:bg-red-50\" onClick={() => handleEliminar(concepto.id)}>\r\n                                                    <Trash2 className=\"h-4 w-4 mr-2\" /> Eliminar\r\n                                                </DropdownMenuItem>\r\n                                            </DropdownMenuContent>\r\n                                        </DropdownMenu>\r\n                                    </td>\r\n                                </tr>\r\n                            )\r\n                        })}\r\n                    </tbody>\r\n                </table>\r\n\r\n                {conceptos.length === 0 && (\r\n                    <div className=\"text-center py-12 text-slate-500\">\r\n                        <div className=\"inline-flex items-center justify-center p-4 bg-slate-100 rounded-full mb-4\">\r\n                            <span className=\"text-2xl\">­ƒöì</span>\r\n                        </div>\r\n                        <p className=\"text-lg font-medium text-slate-900\">No se encontraron conceptos</p>\r\n                        <p className=\"text-sm mt-1\">Intenta ajustar los filtros de b├║squeda</p>\r\n                    </div>\r\n                )}\r\n            </div>\r\n\r\n            <div className=\"flex justify-end text-xs text-slate-400\">\r\n                Mostrando {conceptos.length} conceptos\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\components\\configuracion\\empresa-form.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'series' is defined but never used.","line":52,"column":69,"nodeType":"Identifier","messageId":"unusedVar","endLine":52,"endColumn":75},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'plantillas' is defined but never used.","line":52,"column":77,"nodeType":"Identifier","messageId":"unusedVar","endLine":52,"endColumn":87}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useState, useTransition } from 'react'\r\nimport { useRouter } from 'next/navigation'\r\nimport Image from 'next/image'\r\nimport { Button } from '@/components/ui/button'\r\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card'\r\nimport { Input } from '@/components/ui/input'\r\nimport { Label } from '@/components/ui/label'\r\nimport { Textarea } from '@/components/ui/textarea'\r\nimport { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select'\r\nimport { Switch } from '@/components/ui/switch'\r\nimport { toast } from 'sonner'\r\nimport {\r\n    Building2, MapPin, Phone, CreditCard, FileText, Upload, X, CheckCircle2, AlertCircle, Euro\r\n} from 'lucide-react'\r\nimport { actualizarEmpresaAction, subirLogoEmpresaAction, eliminarLogoEmpresaAction } from '@/app/actions/empresa'\r\nimport type { Empresa } from '@/types/empresa'\r\n\r\nconst TIPOS_EMPRESA = [\r\n    { value: 'autonomo', label: 'Aut├│nomo' },\r\n    { value: 'sl', label: 'Sociedad Limitada (S.L.)' },\r\n    { value: 'sa', label: 'Sociedad An├│nima (S.A.)' },\r\n    { value: 'cooperativa', label: 'Cooperativa' },\r\n    { value: 'asociacion', label: 'Asociaci├│n' },\r\n    { value: 'fundacion', label: 'Fundaci├│n' },\r\n    { value: 'comunidad_bienes', label: 'Comunidad de Bienes' },\r\n    { value: 'otro', label: 'Otro' },\r\n]\r\n\r\nconst REGIMENES_IVA = [\r\n    { value: 'general', label: 'R├®gimen General' },\r\n    { value: 'simplificado', label: 'R├®gimen Simplificado' },\r\n    { value: 'recargo_equivalencia', label: 'Recargo de Equivalencia' },\r\n    { value: 'exento', label: 'Exento de IVA' },\r\n]\r\n\r\nconst PROVINCIAS_ESPANA = [\r\n    '├ülava', 'Albacete', 'Alicante', 'Almer├¡a', 'Asturias', '├üvila', 'Badajoz', 'Barcelona', 'Burgos', 'C├íceres', 'C├ídiz', 'Cantabria',\r\n    'Castell├│n', 'Ciudad Real', 'C├│rdoba', 'Cuenca', 'Girona', 'Granada', 'Guadalajara', 'Guip├║zcoa', 'Huelva', 'Huesca', 'Islas Baleares',\r\n    'Ja├®n', 'La Coru├▒a', 'La Rioja', 'Las Palmas', 'Le├│n', 'L├®rida', 'Lugo', 'Madrid', 'M├ílaga', 'Murcia', 'Navarra', 'Orense', 'Palencia',\r\n    'Pontevedra', 'Salamanca', 'Santa Cruz de Tenerife', 'Segovia', 'Sevilla', 'Soria', 'Tarragona', 'Teruel', 'Toledo', 'Valencia',\r\n    'Valladolid', 'Vizcaya', 'Zamora', 'Zaragoza'\r\n]\r\n\r\ninterface Props {\r\n    empresa: Empresa\r\n    series: Array<{ id: string; nombre: string; prefijo: string }>\r\n    plantillas: Array<{ id: string; nombre: string }>\r\n}\r\n\r\nexport function ConfiguracionEmpresaForm({ empresa: empresaInicial, series, plantillas }: Props) {\r\n    const router = useRouter()\r\n    const [isPending, startTransition] = useTransition()\r\n    const [empresa, setEmpresa] = useState(empresaInicial)\r\n    const [cifValido, setCifValido] = useState<boolean | null>(null)\r\n    const [ibanValido, setIbanValido] = useState<boolean | null>(null)\r\n    const [subiendoLogo, setSubiendoLogo] = useState(false)\r\n\r\n    // Validar CIF en tiempo real\r\n    const validarCIF = (cif: string) => {\r\n        const regex = /^[A-Z][0-9]{7}[A-Z0-9]$/\r\n        setCifValido(regex.test(cif))\r\n    }\r\n\r\n    // Validar IBAN en tiempo real\r\n    const validarIBAN = (iban: string) => {\r\n        if (!iban) {\r\n            setIbanValido(null)\r\n            return\r\n        }\r\n        const regex = /^ES[0-9]{22}$/\r\n        setIbanValido(regex.test(iban.replace(/\\s/g, '')))\r\n    }\r\n\r\n    const handleSubmit = async (e: React.FormEvent<HTMLFormElement>) => {\r\n        e.preventDefault()\r\n\r\n        if (cifValido === false) {\r\n            toast.error('El CIF no es v├ílido')\r\n            return\r\n        }\r\n\r\n        if (empresa.iban && ibanValido === false) {\r\n            toast.error('El IBAN no es v├ílido')\r\n            return\r\n        }\r\n\r\n        const formData = new FormData(e.currentTarget)\r\n\r\n        startTransition(async () => {\r\n            const result = await actualizarEmpresaAction(formData)\r\n\r\n            if (result.success) {\r\n                toast.success('Configuraci├│n actualizada correctamente')\r\n                router.refresh()\r\n            } else {\r\n                toast.error(result.error || 'Error al actualizar')\r\n            }\r\n        })\r\n    }\r\n\r\n    const handleLogoUpload = async (e: React.ChangeEvent<HTMLInputElement>) => {\r\n        const file = e.target.files?.[0]\r\n        if (!file) return\r\n\r\n        setSubiendoLogo(true)\r\n\r\n        const formData = new FormData()\r\n        formData.append('logo', file)\r\n\r\n        const result = await subirLogoEmpresaAction(formData)\r\n\r\n        setSubiendoLogo(false)\r\n\r\n        if (result.success && result.data) {\r\n            toast.success('Logo actualizado')\r\n            setEmpresa({ ...empresa, logo_url: result.data.url })\r\n            router.refresh()\r\n        } else {\r\n            toast.error(result.error || 'Error al subir logo')\r\n        }\r\n    }\r\n\r\n    const handleLogoDelete = async () => {\r\n        const result = await eliminarLogoEmpresaAction()\r\n\r\n        if (result.success) {\r\n            toast.success('Logo eliminado')\r\n            setEmpresa({ ...empresa, logo_url: undefined })\r\n            router.refresh()\r\n        } else {\r\n            toast.error(result.error || 'Error al eliminar logo')\r\n        }\r\n    }\r\n\r\n    return (\r\n        <form onSubmit={handleSubmit} className=\"space-y-6\">\r\n            <div className=\"flex justify-end gap-2 text-right mb-4 sticky top-4 z-10\">\r\n                <Button type=\"button\" variant=\"outline\" onClick={() => router.back()}>\r\n                    Cancelar\r\n                </Button>\r\n                <Button type=\"submit\" disabled={isPending}>\r\n                    <CheckCircle2 className=\"h-4 w-4 mr-2\" />\r\n                    Guardar Cambios\r\n                </Button>\r\n            </div>\r\n\r\n            <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\r\n                {/* DATOS FISCALES */}\r\n                <Card>\r\n                    <CardHeader>\r\n                        <CardTitle className=\"flex items-center gap-2\">\r\n                            <Building2 className=\"h-5 w-5 text-yellow-600\" />\r\n                            Datos Fiscales\r\n                        </CardTitle>\r\n                    </CardHeader>\r\n                    <CardContent className=\"space-y-4\">\r\n                        {/* Logo */}\r\n                        <div>\r\n                            <Label>Logotipo de la empresa</Label>\r\n                            <p className=\"text-sm text-slate-500 mb-2\">\r\n                                Este logo aparecer├í en todas las facturas, albaranes y documentos generados por el sistema.\r\n                                Se recomienda formato PNG con fondo transparente.\r\n                            </p>\r\n\r\n                            <div className=\"flex items-center gap-4\">\r\n                                <div className=\"border-2 border-dashed border-slate-200 dark:border-slate-700 rounded-lg p-4 w-48 h-48 flex items-center justify-center bg-slate-50 dark:bg-slate-900 overflow-hidden relative\">\r\n                                    {empresa.logo_url ? (\r\n                                        <div className=\"relative w-full h-full\">\r\n                                            <Image\r\n                                                src={empresa.logo_url}\r\n                                                alt=\"Logo\"\r\n                                                fill\r\n                                                className=\"object-contain\"\r\n                                                sizes=\"(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw\"\r\n                                            />\r\n                                            <button\r\n                                                type=\"button\"\r\n                                                onClick={handleLogoDelete}\r\n                                                className=\"absolute -top-2 -right-2 bg-red-500 text-white rounded-full p-1 hover:bg-red-600 z-10\"\r\n                                            >\r\n                                                <X className=\"h-3 w-3\" />\r\n                                            </button>\r\n                                        </div>\r\n                                    ) : (\r\n                                        <div className=\"text-center\">\r\n                                            <Upload className=\"h-12 w-12 mx-auto text-slate-400 mb-2\" />\r\n                                            <p className=\"text-sm text-slate-500\">Subir Logo</p>\r\n                                            <p className=\"text-xs text-slate-400\">(200x200px)</p>\r\n                                        </div>\r\n                                    )}\r\n                                </div>\r\n\r\n                                <div className=\"flex flex-col gap-2\">\r\n                                    <input\r\n                                        type=\"file\"\r\n                                        id=\"logo-upload\"\r\n                                        accept=\"image/png,image/jpeg,image/jpg\"\r\n                                        onChange={handleLogoUpload}\r\n                                        className=\"hidden\"\r\n                                    />\r\n                                    <Button\r\n                                        type=\"button\"\r\n                                        variant=\"outline\"\r\n                                        size=\"sm\"\r\n                                        disabled={subiendoLogo}\r\n                                        onClick={() => document.getElementById('logo-upload')?.click()}\r\n                                    >\r\n                                        <Upload className=\"h-4 w-4 mr-2\" />\r\n                                        {subiendoLogo ? 'Subiendo...' : 'Cambiar Logo'}\r\n                                    </Button>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n\r\n                        {/* Raz├│n Social */}\r\n                        <div>\r\n                            <Label htmlFor=\"razon_social\">Raz├│n Social *</Label>\r\n                            <Input\r\n                                id=\"razon_social\"\r\n                                name=\"razon_social\"\r\n                                defaultValue={empresa.razon_social}\r\n                                required\r\n                                placeholder=\"Ej. STVLS Logistics S.L.\"\r\n                                onChange={(e) => setEmpresa({ ...empresa, razon_social: e.target.value })}\r\n                            />\r\n                        </div>\r\n\r\n                        {/* Nombre Comercial */}\r\n                        <div>\r\n                            <Label htmlFor=\"nombre_comercial\">Nombre Comercial</Label>\r\n                            <Input\r\n                                id=\"nombre_comercial\"\r\n                                name=\"nombre_comercial\"\r\n                                defaultValue={empresa.nombre_comercial || ''}\r\n                                placeholder=\"Ej. STVLS\"\r\n                            />\r\n                        </div>\r\n\r\n                        {/* CIF/NIF */}\r\n                        <div className=\"grid grid-cols-2 gap-4\">\r\n                            <div>\r\n                                <Label htmlFor=\"cif\">CIF/NIF *</Label>\r\n                                <div className=\"relative\">\r\n                                    <Input\r\n                                        id=\"cif\"\r\n                                        name=\"cif\"\r\n                                        defaultValue={empresa.cif}\r\n                                        required\r\n                                        placeholder=\"B12345678\"\r\n                                        onChange={(e) => {\r\n                                            const val = e.target.value.toUpperCase();\r\n                                            validarCIF(val);\r\n                                            setEmpresa({ ...empresa, cif: val });\r\n                                        }}\r\n                                        className={\r\n                                            cifValido === null ? '' :\r\n                                                cifValido ? 'border-green-500' : 'border-red-500'\r\n                                        }\r\n                                    />\r\n                                    {cifValido !== null && (\r\n                                        <div className=\"absolute right-2 top-1/2 -translate-y-1/2\">\r\n                                            {cifValido ? (\r\n                                                <CheckCircle2 className=\"h-5 w-5 text-green-500\" />\r\n                                            ) : (\r\n                                                <AlertCircle className=\"h-5 w-5 text-red-500\" />\r\n                                            )}\r\n                                        </div>\r\n                                    )}\r\n                                </div>\r\n                            </div>\r\n\r\n                            <div>\r\n                                <Label htmlFor=\"tipo_empresa\">Tipo de empresa</Label>\r\n                                <Select name=\"tipo_empresa\" defaultValue={empresa.tipo_empresa}>\r\n                                    <SelectTrigger>\r\n                                        <SelectValue />\r\n                                    </SelectTrigger>\r\n                                    <SelectContent>\r\n                                        {TIPOS_EMPRESA.map((tipo) => (\r\n                                            <SelectItem key={tipo.value} value={tipo.value}>\r\n                                                {tipo.label}\r\n                                            </SelectItem>\r\n                                        ))}\r\n                                    </SelectContent>\r\n                                </Select>\r\n                            </div>\r\n                        </div>\r\n                    </CardContent>\r\n                </Card>\r\n\r\n                {/* DIRECCI├ôN */}\r\n                <Card>\r\n                    <CardHeader>\r\n                        <CardTitle className=\"flex items-center gap-2\">\r\n                            <MapPin className=\"h-5 w-5 text-orange-600\" />\r\n                            Direcci├│n\r\n                        </CardTitle>\r\n                    </CardHeader>\r\n                    <CardContent className=\"space-y-4\">\r\n                        {/* Direcci├│n completa */}\r\n                        <div>\r\n                            <Label htmlFor=\"direccion\">Direcci├│n completa</Label>\r\n                            <Input\r\n                                id=\"direccion\"\r\n                                name=\"direccion\"\r\n                                defaultValue={empresa.direccion || ''}\r\n                                placeholder=\"C/ Ejemplo, 123, Pol├¡gono Industrial\"\r\n                            />\r\n                        </div>\r\n\r\n                        {/* CP y Ciudad */}\r\n                        <div className=\"grid grid-cols-3 gap-4\">\r\n                            <div>\r\n                                <Label htmlFor=\"codigo_postal\">C├│digo Postal</Label>\r\n                                <Input\r\n                                    id=\"codigo_postal\"\r\n                                    name=\"codigo_postal\"\r\n                                    defaultValue={empresa.codigo_postal || ''}\r\n                                    placeholder=\"28001\"\r\n                                    maxLength={5}\r\n                                />\r\n                            </div>\r\n\r\n                            <div className=\"col-span-2\">\r\n                                <Label htmlFor=\"ciudad\">Ciudad</Label>\r\n                                <Input\r\n                                    id=\"ciudad\"\r\n                                    name=\"ciudad\"\r\n                                    defaultValue={empresa.ciudad || ''}\r\n                                    placeholder=\"Madrid\"\r\n                                />\r\n                            </div>\r\n                        </div>\r\n\r\n                        {/* Provincia y Pa├¡s */}\r\n                        <div className=\"grid grid-cols-2 gap-4\">\r\n                            <div>\r\n                                <Label htmlFor=\"provincia\">Provincia</Label>\r\n                                <Select name=\"provincia\" defaultValue={empresa.provincia || ''}>\r\n                                    <SelectTrigger>\r\n                                        <SelectValue placeholder=\"Seleccionar\" />\r\n                                    </SelectTrigger>\r\n                                    <SelectContent>\r\n                                        {PROVINCIAS_ESPANA.map((prov) => (\r\n                                            <SelectItem key={prov} value={prov}>\r\n                                                {prov}\r\n                                            </SelectItem>\r\n                                        ))}\r\n                                    </SelectContent>\r\n                                </Select>\r\n                            </div>\r\n\r\n                            <div>\r\n                                <Label htmlFor=\"pais\">Pa├¡s</Label>\r\n                                <Select name=\"pais\" defaultValue={empresa.pais}>\r\n                                    <SelectTrigger>\r\n                                        <SelectValue />\r\n                                    </SelectTrigger>\r\n                                    <SelectContent>\r\n                                        <SelectItem value=\"Espa├▒a\">Espa├▒a</SelectItem>\r\n                                        <SelectItem value=\"Portugal\">Portugal</SelectItem>\r\n                                        <SelectItem value=\"Francia\">Francia</SelectItem>\r\n                                        <SelectItem value=\"Alemania\">Alemania</SelectItem>\r\n                                        <SelectItem value=\"Italia\">Italia</SelectItem>\r\n                                    </SelectContent>\r\n                                </Select>\r\n                            </div>\r\n                        </div>\r\n                    </CardContent>\r\n                </Card>\r\n\r\n                {/* CONTACTO */}\r\n                <Card>\r\n                    <CardHeader>\r\n                        <CardTitle className=\"flex items-center gap-2\">\r\n                            <Phone className=\"h-5 w-5 text-blue-600\" />\r\n                            Contacto\r\n                        </CardTitle>\r\n                    </CardHeader>\r\n                    <CardContent className=\"space-y-4\">\r\n                        <div>\r\n                            <Label htmlFor=\"telefono\">Tel├®fono</Label>\r\n                            <Input\r\n                                id=\"telefono\"\r\n                                name=\"telefono\"\r\n                                defaultValue={empresa.telefono || ''}\r\n                                placeholder=\"+34 900 000 000\"\r\n                            />\r\n                        </div>\r\n                        <div>\r\n                            <Label htmlFor=\"email\">Email</Label>\r\n                            <Input\r\n                                id=\"email\"\r\n                                name=\"email\"\r\n                                type=\"email\"\r\n                                defaultValue={empresa.email || ''}\r\n                                placeholder=\"info@empresa.com\"\r\n                            />\r\n                        </div>\r\n                        <div>\r\n                            <Label htmlFor=\"web\">Sitio Web</Label>\r\n                            <Input\r\n                                id=\"web\"\r\n                                name=\"web\"\r\n                                defaultValue={empresa.web || ''}\r\n                                placeholder=\"www.empresa.com\"\r\n                            />\r\n                        </div>\r\n                    </CardContent>\r\n                </Card>\r\n\r\n                {/* DATOS BANCARIOS */}\r\n                <Card>\r\n                    <CardHeader>\r\n                        <CardTitle className=\"flex items-center gap-2\">\r\n                            <CreditCard className=\"h-5 w-5 text-purple-600\" />\r\n                            Datos Bancarios\r\n                        </CardTitle>\r\n                    </CardHeader>\r\n                    <CardContent className=\"space-y-4\">\r\n                        <div>\r\n                            <Label htmlFor=\"banco\">Nombre del Banco</Label>\r\n                            <Input\r\n                                id=\"banco\"\r\n                                name=\"banco\"\r\n                                defaultValue={empresa.banco || ''}\r\n                                placeholder=\"Ej. BBVA\"\r\n                            />\r\n                        </div>\r\n                        <div>\r\n                            <Label htmlFor=\"titular_cuenta\">Titular de la cuenta</Label>\r\n                            <Input\r\n                                id=\"titular_cuenta\"\r\n                                name=\"titular_cuenta\"\r\n                                defaultValue={empresa.titular_cuenta || ''}\r\n                                placeholder=\"Nombre del titular\"\r\n                            />\r\n                        </div>\r\n                        <div>\r\n                            <Label htmlFor=\"iban\">IBAN</Label>\r\n                            <div className=\"relative\">\r\n                                <Input\r\n                                    id=\"iban\"\r\n                                    name=\"iban\"\r\n                                    defaultValue={empresa.iban || ''}\r\n                                    placeholder=\"ES00 0000 0000 0000 0000 0000\"\r\n                                    onChange={(e) => {\r\n                                        const val = e.target.value;\r\n                                        validarIBAN(val);\r\n                                        setEmpresa({ ...empresa, iban: val });\r\n                                    }}\r\n                                    className={\r\n                                        ibanValido === null ? '' :\r\n                                            ibanValido ? 'border-green-500' : 'border-red-500'\r\n                                    }\r\n                                />\r\n                                {ibanValido !== null && (\r\n                                    <div className=\"absolute right-2 top-1/2 -translate-y-1/2\">\r\n                                        {ibanValido ? (\r\n                                            <CheckCircle2 className=\"h-5 w-5 text-green-500\" />\r\n                                        ) : (\r\n                                            <AlertCircle className=\"h-5 w-5 text-red-500\" />\r\n                                        )}\r\n                                    </div>\r\n                                )}\r\n                            </div>\r\n                        </div>\r\n                        <div>\r\n                            <Label htmlFor=\"swift\">SWIFT / BIC</Label>\r\n                            <Input\r\n                                id=\"swift\"\r\n                                name=\"swift\"\r\n                                defaultValue={empresa.swift || ''}\r\n                                placeholder=\"BBVAESMM\"\r\n                            />\r\n                        </div>\r\n                    </CardContent>\r\n                </Card>\r\n\r\n                {/* CONFIGURACI├ôN FISCAL */}\r\n                <Card>\r\n                    <CardHeader>\r\n                        <CardTitle className=\"flex items-center gap-2\">\r\n                            <Euro className=\"h-5 w-5 text-green-600\" />\r\n                            Configuraci├│n Fiscal\r\n                        </CardTitle>\r\n                    </CardHeader>\r\n                    <CardContent className=\"space-y-4\">\r\n                        <div className=\"grid grid-cols-2 gap-4\">\r\n                            <div>\r\n                                <Label htmlFor=\"iva_predeterminado\">IVA Predeterminado (%)</Label>\r\n                                <Input\r\n                                    id=\"iva_predeterminado\"\r\n                                    name=\"iva_predeterminado\"\r\n                                    type=\"number\"\r\n                                    step=\"0.01\"\r\n                                    defaultValue={empresa.iva_predeterminado}\r\n                                />\r\n                            </div>\r\n                            <div>\r\n                                <Label htmlFor=\"retencion_predeterminada\">Retenci├│n IRPF (%)</Label>\r\n                                <Input\r\n                                    id=\"retencion_predeterminada\"\r\n                                    name=\"retencion_predeterminada\"\r\n                                    type=\"number\"\r\n                                    step=\"0.01\"\r\n                                    defaultValue={empresa.retencion_predeterminada}\r\n                                />\r\n                            </div>\r\n                        </div>\r\n\r\n                        <div>\r\n                            <Label htmlFor=\"regimen_iva\">R├®gimen IVA</Label>\r\n                            <Select name=\"regimen_iva\" defaultValue={empresa.regimen_iva}>\r\n                                <SelectTrigger>\r\n                                    <SelectValue />\r\n                                </SelectTrigger>\r\n                                <SelectContent>\r\n                                    {REGIMENES_IVA.map((reg) => (\r\n                                        <SelectItem key={reg.value} value={reg.value}>\r\n                                            {reg.label}\r\n                                        </SelectItem>\r\n                                    ))}\r\n                                </SelectContent>\r\n                            </Select>\r\n                        </div>\r\n\r\n                        <div className=\"flex items-center justify-between border p-3 rounded-lg\">\r\n                            <div className=\"space-y-0.5\">\r\n                                <Label>Recargo de Equivalencia</Label>\r\n                                <p className=\"text-sm text-slate-500\">\r\n                                    Aplicar recargo de equivalencia por defecto\r\n                                </p>\r\n                            </div>\r\n                            <Switch\r\n                                name=\"aplica_recargo_equivalencia\"\r\n                                defaultChecked={empresa.aplica_recargo_equivalencia}\r\n                                value=\"true\"\r\n                            />\r\n                        </div>\r\n\r\n                        {/* Note: Switch component in forms often doesn't submit value unless explicitly handled or using a hidden input. \r\n                 Shadcn Switch usually works with libs like RHF. Here using native FormData, \r\n                 we might need a hidden input or the Switch's name/value handling.*/}\r\n                        {/* Workaround for native form submission with Shadcn Switch if it doesn't support name attribute fully natively or just to be safe */}\r\n                        <input type=\"hidden\" name=\"aplica_recargo_equivalencia\" value={empresa.aplica_recargo_equivalencia ? 'true' : 'false'} />\r\n\r\n                        <div>\r\n                            <Label htmlFor=\"recargo_porcentaje\">Porcentaje Recargo (%)</Label>\r\n                            <Input\r\n                                id=\"recargo_porcentaje\"\r\n                                name=\"recargo_porcentaje\"\r\n                                type=\"number\"\r\n                                step=\"0.01\"\r\n                                defaultValue={empresa.recargo_porcentaje}\r\n                            />\r\n                        </div>\r\n\r\n                    </CardContent>\r\n                </Card>\r\n\r\n                {/* TEXTOS LEGALES */}\r\n                <Card className=\"lg:col-span-2\">\r\n                    <CardHeader>\r\n                        <CardTitle className=\"flex items-center gap-2\">\r\n                            <FileText className=\"h-5 w-5 text-slate-600\" />\r\n                            Textos Legales\r\n                        </CardTitle>\r\n                    </CardHeader>\r\n                    <CardContent className=\"space-y-4\">\r\n                        <div>\r\n                            <Label htmlFor=\"pie_factura\">Pie de Factura (Texto corto)</Label>\r\n                            <p className=\"text-sm text-slate-500 mb-2\">Aparece al final de todas las facturas</p>\r\n                            <Textarea\r\n                                id=\"pie_factura\"\r\n                                name=\"pie_factura\"\r\n                                defaultValue={empresa.pie_factura || ''}\r\n                                placeholder=\"Ej. Registro Mercantil de Madrid, Tomo 1234, Folio 12...\"\r\n                                rows={2}\r\n                            />\r\n                        </div>\r\n                        <div>\r\n                            <Label htmlFor=\"clausulas_generales\">Cl├íusulas Generales / Notas Legales</Label>\r\n                            <p className=\"text-sm text-slate-500 mb-2\">Aparece en una p├ígina anexa o al final del documento</p>\r\n                            <Textarea\r\n                                id=\"clausulas_generales\"\r\n                                name=\"clausulas_generales\"\r\n                                defaultValue={empresa.clausulas_generales || ''}\r\n                                placeholder=\"T├®rminos y condiciones, protecci├│n de datos, etc...\"\r\n                                rows={4}\r\n                            />\r\n                        </div>\r\n                    </CardContent>\r\n                </Card>\r\n            </div>\r\n        </form>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\components\\configuracion\\gestion-empresas-client.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\components\\dashboard\\navbar.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Command' is defined but never used.","line":4,"column":41,"nodeType":"Identifier","messageId":"unusedVar","endLine":4,"endColumn":48,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Command"},"fix":{"range":[88,97],"text":""},"desc":"Remove unused variable \"Command\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useState } from 'react'\r\nimport { Search, Bell, Moon, Sun, Menu, Command } from 'lucide-react'\r\nimport { Button } from '@/components/ui/button'\r\nimport { Input } from '@/components/ui/input'\r\nimport { Sheet, SheetContent, SheetTrigger, SheetTitle } from '@/components/ui/sheet'\r\nimport { Sidebar } from './sidebar'\r\nimport { UserDropdown } from './user-dropdown'\r\nimport { EmpresaSelector } from '@/components/empresa-selector'\r\nimport type { User } from '@supabase/supabase-js'\r\n\r\ninterface NavbarProps {\r\n    user: User\r\n}\r\n\r\nexport function Navbar({ user }: NavbarProps) {\r\n    const [isDark, setIsDark] = useState(false)\r\n\r\n    const toggleTheme = () => {\r\n        setIsDark(!isDark)\r\n        document.documentElement.classList.toggle('dark')\r\n    }\r\n\r\n    return (\r\n        <header className=\"sticky top-0 z-30 flex h-20 items-center gap-4 bg-white/60 dark:bg-slate-900/60 backdrop-blur-2xl px-4 shadow-[0_1px_2px_rgba(0,0,0,0.05)] border-b border-slate-200/50 dark:border-white/5 lg:px-8 transition-all duration-500\">\r\n            {/* Mobile Menu */}\r\n            <Sheet>\r\n                <SheetTrigger asChild>\r\n                    <Button variant=\"ghost\" size=\"icon\" className=\"lg:hidden hover:bg-slate-100 dark:hover:bg-white/5 transition-colors\">\r\n                        <Menu className=\"h-6 w-6 text-slate-600 dark:text-slate-300\" />\r\n                        <span className=\"sr-only\">Toggle menu</span>\r\n                    </Button>\r\n                </SheetTrigger>\r\n                <SheetContent side=\"left\" className=\"p-0 border-r-white/5 bg-[#1a2332] w-72\">\r\n                    <SheetTitle className=\"sr-only\">Men├║ de navegaci├│n</SheetTitle>\r\n                    <Sidebar className=\"static w-full h-full border-none shadow-none\" userEmail={user?.email} />\r\n                </SheetContent>\r\n            </Sheet>\r\n\r\n            {/* Search Input - Ultra Premium Style */}\r\n            <div className=\"flex-1 max-w-xl hidden md:block\">\r\n                <div className=\"relative group/search\">\r\n                    <Search className=\"absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400 group-focus-within/search:text-primary group-focus-within/search:scale-110 transition-all duration-300\" />\r\n                    <Input\r\n                        type=\"search\"\r\n                        placeholder=\"Buscar en STV Global Enterprise...\"\r\n                        className=\"w-full h-12 rounded-2xl bg-slate-100/50 dark:bg-white/5 pl-11 pr-12 border-transparent focus:bg-white dark:focus:bg-slate-900 focus:border-primary/20 focus:ring-8 focus:ring-primary/5 transition-all duration-500 shadow-sm hover:bg-slate-100 dark:hover:bg-white/10\"\r\n                    />\r\n                    <div className=\"absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none flex items-center gap-1.5\">\r\n                        <kbd className=\"h-6 px-2 rounded-md border border-slate-200 dark:border-white/10 bg-white/50 dark:bg-white/5 flex items-center justify-center shadow-xs\">\r\n                            <span className=\"text-[10px] text-slate-500 font-bold uppercase tracking-tighter\">Ôîÿ</span>\r\n                        </kbd>\r\n                        <kbd className=\"h-6 px-2 rounded-md border border-slate-200 dark:border-white/10 bg-white/50 dark:bg-white/5 flex items-center justify-center shadow-xs\">\r\n                            <span className=\"text-[10px] text-slate-500 font-bold uppercase tracking-tighter\">K</span>\r\n                        </kbd>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <div className=\"flex-1 md:hidden\" />\r\n\r\n            {/* Actions */}\r\n            <div className=\"flex items-center gap-3 sm:gap-5\">\r\n                {/* Notifications */}\r\n                <Button variant=\"ghost\" size=\"icon\" className=\"relative h-11 w-11 rounded-2xl hover:bg-slate-100 dark:hover:bg-white/5 text-slate-500 hover:text-primary transition-all duration-300 group\">\r\n                    <Bell className=\"h-5 w-5 group-hover:rotate-12\" />\r\n                    <span className=\"absolute top-3 right-3 h-2.5 w-2.5 rounded-full bg-linear-to-tr from-red-500 to-orange-400 ring-2 ring-white dark:ring-slate-900 shadow-[0_0_8px_rgba(239,68,68,0.5)]\" />\r\n                    <span className=\"sr-only\">Notificaciones</span>\r\n                </Button>\r\n\r\n                {/* Theme Toggle */}\r\n                <Button variant=\"ghost\" size=\"icon\" onClick={toggleTheme} className=\"h-11 w-11 rounded-2xl hover:bg-slate-100 dark:hover:bg-white/5 text-slate-500 hover:text-primary transition-all duration-300 group\">\r\n                    {isDark ? (\r\n                        <Sun className=\"h-5 w-5 group-hover:rotate-45\" />\r\n                    ) : (\r\n                        <Moon className=\"h-5 w-5 group-hover:-rotate-12\" />\r\n                    )}\r\n                    <span className=\"sr-only\">Toggle theme</span>\r\n                </Button>\r\n\r\n                {/* Company Selector (RFC-025) */}\r\n                <EmpresaSelector variant=\"header\" />\r\n\r\n                <div className=\"h-8 w-px bg-slate-200/50 dark:bg-white/10 mx-1 hidden sm:block\" />\r\n\r\n                {/* User Dropdown */}\r\n                <UserDropdown user={user} />\r\n            </div>\r\n        </header>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\components\\dashboard\\sidebar.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":23,"column":11,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":23,"endColumn":14,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[458,461],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[458,461],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":27,"column":15,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":27,"endColumn":18,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[538,541],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[538,541],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport Link from 'next/link'\r\nimport { usePathname } from 'next/navigation'\r\nimport Image from 'next/image'\r\nimport { cn } from '@/lib/utils'\r\nimport { useState, useEffect } from 'react'\r\nimport {\r\n    LayoutDashboard,\r\n    ShoppingCart,\r\n    Receipt,\r\n    Users,\r\n    CreditCard,\r\n    BarChart3,\r\n    Settings,\r\n    ChevronDown,\r\n    ChevronRight,\r\n} from 'lucide-react'\r\n\r\ninterface NavItem {\r\n    name: string\r\n    href: string\r\n    icon: any\r\n    submenu?: {\r\n        name: string\r\n        href: string\r\n        icon: any\r\n    }[]\r\n}\r\n\r\nconst navigation: NavItem[] = [\r\n    {\r\n        name: 'Dashboard',\r\n        href: '/dashboard',\r\n        icon: LayoutDashboard,\r\n    },\r\n    {\r\n        name: 'Ventas',\r\n        href: '/ventas',\r\n        icon: ShoppingCart,\r\n        submenu: [\r\n            { name: 'Facturas', href: '/ventas/facturas', icon: Receipt },\r\n            { name: 'Clientes', href: '/ventas/clientes', icon: Users },\r\n            { name: 'Pagos', href: '/ventas/pagos', icon: CreditCard },\r\n            { name: 'Informes', href: '/ventas/informes', icon: BarChart3 },\r\n        ]\r\n    },\r\n]\r\n\r\nconst tools: NavItem[] = [\r\n    {\r\n        name: 'Configuraci├│n',\r\n        href: '/ventas/configuracion/empresa',\r\n        icon: Settings,\r\n    },\r\n]\r\n\r\ninterface SidebarProps {\r\n    className?: string\r\n    userEmail?: string\r\n}\r\n\r\nexport function Sidebar({ className, userEmail }: SidebarProps) {\r\n    const pathname = usePathname()\r\n    // State to track open submenus. Default open if pathname matches.\r\n    const [openMenus, setOpenMenus] = useState<string[]>([])\r\n\r\n    // Auto-open menu if child is active\r\n    useEffect(() => {\r\n        navigation.forEach(item => {\r\n            if (item.submenu) {\r\n                const isActive = item.submenu.some(sub => pathname.startsWith(sub.href))\r\n                if (isActive && !openMenus.includes(item.name)) {\r\n                    setOpenMenus(prev => [...prev, item.name])\r\n                }\r\n            }\r\n        })\r\n    }, [pathname, openMenus])\r\n\r\n    const toggleMenu = (name: string) => {\r\n        setOpenMenus(prev =>\r\n            prev.includes(name)\r\n                ? prev.filter(n => n !== name)\r\n                : [...prev, name]\r\n        )\r\n    }\r\n\r\n    const renderNavItem = (item: NavItem) => {\r\n        const isActive = pathname === item.href || (item.submenu && item.submenu.some(sub => pathname.startsWith(sub.href)))\r\n        const isOpen = openMenus.includes(item.name)\r\n        const Icon = item.icon\r\n\r\n        if (item.submenu) {\r\n            return (\r\n                <div key={item.name} className=\"space-y-1\">\r\n                    <button\r\n                        onClick={() => toggleMenu(item.name)}\r\n                        className={cn(\r\n                            'w-full group flex items-center justify-between gap-3 rounded-xl px-4 py-3 text-sm font-semibold transition-all duration-500 relative overflow-hidden',\r\n                            isActive\r\n                                ? 'bg-white/5 text-primary shadow-[inset_0_0_20px_rgba(var(--primary),0.05)]'\r\n                                : 'text-slate-400 hover:bg-white/5 hover:text-slate-100 hover:translate-x-1'\r\n                        )}\r\n                    >\r\n                        <div className=\"flex items-center gap-3\">\r\n                            <Icon className={cn(\"h-5 w-5 shrink-0 transition-colors\", isActive ? \"text-primary drop-shadow-[0_0_5px_rgba(var(--primary),0.5)]\" : \"group-hover:text-primary\")} />\r\n                            {item.name}\r\n                        </div>\r\n                        {isOpen ? <ChevronDown className=\"h-4 w-4\" /> : <ChevronRight className=\"h-4 w-4\" />}\r\n                    </button>\r\n\r\n                    {isOpen && (\r\n                        <div className=\"pl-4 space-y-1 animate-in slide-in-from-top-2 duration-200\">\r\n                            {item.submenu.map(sub => {\r\n                                const SubIcon = sub.icon\r\n                                return (\r\n                                    <Link\r\n                                        key={sub.name}\r\n                                        href={sub.href}\r\n                                        className={cn(\r\n                                            'group flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium transition-all duration-300 relative',\r\n                                            pathname === sub.href\r\n                                                ? 'bg-white/5 text-primary'\r\n                                                : 'text-slate-400 hover:bg-white/5 hover:text-slate-100'\r\n                                        )}\r\n                                    >\r\n                                        <SubIcon className={cn(\"h-4 w-4 shrink-0 transition-colors\", pathname === sub.href ? \"text-primary\" : \"group-hover:text-primary\")} />\r\n                                        {sub.name}\r\n                                    </Link>\r\n                                )\r\n                            })}\r\n                        </div>\r\n                    )}\r\n                </div>\r\n            )\r\n        }\r\n\r\n        return (\r\n            <Link\r\n                key={item.name}\r\n                href={item.href}\r\n                className={cn(\r\n                    'group flex items-center gap-3 rounded-lg px-3 py-3 text-sm font-medium transition-all duration-300 relative overflow-hidden',\r\n                    isActive\r\n                        ? 'bg-linear-to-r from-primary/20 to-transparent text-primary'\r\n                        : 'text-slate-400 hover:bg-white/5 hover:text-slate-100 hover:translate-x-1'\r\n                )}\r\n            >\r\n                {isActive && (\r\n                    <div className=\"absolute left-0 top-0 bottom-0 w-1 bg-primary shadow-[0_0_10px_2px_rgba(var(--primary),0.5)]\" />\r\n                )}\r\n                <Icon className={cn(\"h-5 w-5 shrink-0 transition-colors\", isActive ? \"text-primary drop-shadow-[0_0_5px_rgba(var(--primary),0.5)]\" : \"group-hover:text-primary\")} />\r\n                {item.name}\r\n            </Link>\r\n        )\r\n    }\r\n\r\n    return (\r\n        <aside\r\n            className={cn(\r\n                'fixed left-0 top-0 z-40 h-screen w-64 flex-col bg-[#1a2332]/95 backdrop-blur-xl text-slate-200 border-r border-white/5 shadow-[20px_0_40px_-15px_rgba(0,0,0,0.5)] transition-all duration-500 overflow-y-auto',\r\n                className\r\n            )}\r\n        >\r\n            {/* Logo Section */}\r\n            <div className=\"flex h-20 items-center gap-3 px-6 border-b border-white/5 bg-[#171f2c]\">\r\n                <div className=\"relative h-10 w-10 overflow-hidden rounded-lg bg-white/5 p-1 ring-1 ring-white/10\">\r\n                    <Image\r\n                        src=\"/logo-stv.svg\"\r\n                        alt=\"STV Logistics\"\r\n                        fill\r\n                        className=\"object-contain\"\r\n                    />\r\n                </div>\r\n                <div>\r\n                    <p className=\"font-serif font-bold text-lg text-white tracking-wide\">STV Global</p>\r\n                    <p className=\"text-[10px] font-bold text-primary tracking-[0.2em] uppercase\">Enterprise</p>\r\n                </div>\r\n            </div>\r\n\r\n            {/* Navigation */}\r\n            <nav className=\"flex-1 space-y-1 overflow-y-auto px-3 py-6 scrollbar-thin scrollbar-thumb-slate-700 scrollbar-track-transparent\">\r\n                {/* Principal */}\r\n                <div className=\"space-y-1\">\r\n                    <p className=\"px-3 text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-2\">Principal</p>\r\n                    {navigation.map(renderNavItem)}\r\n                </div>\r\n\r\n                {/* Herramientas */}\r\n                <div className=\"pt-6 space-y-1\">\r\n                    <p className=\"px-3 text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-2\">\r\n                        Herramientas\r\n                    </p>\r\n                    {tools.map(renderNavItem)}\r\n                </div>\r\n            </nav>\r\n\r\n            {/* User Info Footer */}\r\n            <div className=\"border-t border-white/5 p-4 bg-[#171f2c]/50 backdrop-blur-md\">\r\n                <div className=\"flex items-center gap-3 p-3 rounded-xl bg-white/5 border border-white/5 hover:bg-white/10 transition-all duration-300 cursor-pointer group shadow-inner\">\r\n                    <div className=\"flex h-10 w-10 items-center justify-center rounded-lg bg-linear-to-br from-primary to-yellow-600 text-white text-xs font-black shadow-lg shadow-primary/20 group-hover:scale-110 transition-transform\">\r\n                        AU\r\n                    </div>\r\n                    <div className=\"flex-1 overflow-hidden\">\r\n                        <p className=\"text-sm font-bold text-white truncate\">Admin Usuario</p>\r\n                        <p className=\"text-[10px] font-medium text-slate-400 truncate\">{userEmail || 'admin@stvls.com'}</p>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </aside>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\components\\dashboard\\user-dropdown.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\components\\date-range-picker.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\components\\empresa-selector.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Link' is defined but never used.","line":16,"column":8,"nodeType":"Identifier","messageId":"unusedVar","endLine":16,"endColumn":12,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"Link"},"fix":{"range":[534,562],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":161,"column":33,"nodeType":"JSXOpeningElement","endLine":165,"endColumn":35},{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":231,"column":41,"nodeType":"JSXOpeningElement","endLine":235,"endColumn":43}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useState, useEffect } from 'react'\r\nimport { Building2, ChevronDown, Check, Plus } from 'lucide-react'\r\nimport { Button } from '@/components/ui/button'\r\nimport {\r\n    DropdownMenu,\r\n    DropdownMenuContent,\r\n    DropdownMenuItem,\r\n    DropdownMenuSeparator,\r\n    DropdownMenuTrigger,\r\n} from '@/components/ui/dropdown-menu'\r\nimport { listarEmpresasUsuarioAction, cambiarEmpresaActivaAction } from '@/app/actions/usuarios-empresas'\r\nimport { toast } from 'sonner'\r\nimport { useRouter } from 'next/navigation'\r\nimport Link from 'next/link'\r\nimport Image from 'next/image'\r\nimport { ConfirmDialog } from '@/components/ui/confirm-dialog'\r\n\r\n/**\r\n * Selector de empresas con dise├▒o Premium y optimizaci├│n t├íctil.\r\n * Soporta variantes para el Header (global) y Formularios (local).\r\n */\r\n\r\ninterface Empresa {\r\n    id: string\r\n    razon_social: string\r\n    nombre_comercial?: string | null\r\n    logo_url?: string | null\r\n    tipo_empresa: string\r\n    rol: string\r\n    activa: boolean\r\n}\r\n\r\ninterface EmpresaSelectorProps {\r\n    variant?: 'header' | 'form'\r\n    onSelect?: (empresaId: string) => void\r\n    selectedId?: string\r\n}\r\n\r\nexport function EmpresaSelector({ variant = 'header', onSelect, selectedId }: EmpresaSelectorProps) {\r\n    const router = useRouter()\r\n    const [empresas, setEmpresas] = useState<Empresa[]>([])\r\n    const [empresaActiva, setEmpresaActiva] = useState<Empresa | null>(null)\r\n    const [isLoading, setIsLoading] = useState(true)\r\n    const [showConfirm, setShowConfirm] = useState(false)\r\n    const [pendingEmpresaId, setPendingEmpresaId] = useState<string | null>(null)\r\n    const [isAdmin, setIsAdmin] = useState(false)\r\n\r\n    useEffect(() => {\r\n        const loadEmpresas = async () => {\r\n            const result = await listarEmpresasUsuarioAction()\r\n            if (result.success && result.data) {\r\n                setEmpresas(result.data.empresas)\r\n                setIsAdmin(!!result.data.isAdmin) // Cast to boolean\r\n\r\n                // Determine active company\r\n                if (result.data.isGlobal) {\r\n                    setEmpresaActiva({\r\n                        id: 'ALL',\r\n                        razon_social: 'Todas las Empresas',\r\n                        nombre_comercial: 'Visi├│n Global',\r\n                        tipo_empresa: 'Corporaci├│n',\r\n                        rol: 'admin',\r\n                        activa: true\r\n                    })\r\n                } else {\r\n                    const activa = result.data.empresas.find((e: Empresa) => e.activa) || result.data.empresas[0]\r\n                    setEmpresaActiva(activa)\r\n                }\r\n            }\r\n            setIsLoading(false)\r\n        }\r\n        loadEmpresas()\r\n    }, [])\r\n\r\n    const handleSelectEmpresa = (empresaOrId: Empresa | string) => {\r\n        const id = typeof empresaOrId === 'string' ? empresaOrId : empresaOrId.id\r\n\r\n        if (variant === 'form') {\r\n            if (id === 'ALL') return // Form variant usually doesn't support ALL unless specific requirement\r\n            onSelect?.(id)\r\n            const emp = empresas.find(e => e.id === id)\r\n            if (emp) setEmpresaActiva(emp)\r\n        } else {\r\n            // En el header, el cambio es global y requiere confirmaci├│n\r\n            if (id === empresaActiva?.id) return\r\n            setPendingEmpresaId(id)\r\n            setShowConfirm(true)\r\n        }\r\n    }\r\n\r\n    const confirmCambioEmpresa = async () => {\r\n        if (!pendingEmpresaId) return\r\n\r\n        const result = await cambiarEmpresaActivaAction(pendingEmpresaId)\r\n        if (result.success) {\r\n            toast.success('Entorno de trabajo actualizado')\r\n            router.refresh()\r\n            await loadEmpresas()\r\n        } else {\r\n            toast.error(result.error || 'Error al cambiar de empresa')\r\n        }\r\n        setPendingEmpresaId(null) // Clear pending ID\r\n    }\r\n\r\n    // Loader minimalista con animaci├│n pulsante\r\n    if (isLoading) {\r\n        return (\r\n            <div className=\"h-10 w-[200px] bg-slate-100 dark:bg-slate-800 rounded-xl animate-pulse flex items-center px-3 gap-2\">\r\n                <div className=\"w-6 h-6 rounded bg-slate-200 dark:bg-slate-700\" />\r\n                <div className=\"h-3 w-24 bg-slate-200 dark:bg-slate-700 rounded\" />\r\n            </div>\r\n        )\r\n    }\r\n\r\n    if (empresas.length === 0 && !isAdmin) return null\r\n\r\n    // Caso de empresa ├║nica en selector de formulario (Simplificado)\r\n    if (empresas.length === 1 && !isAdmin && variant === 'form') {\r\n        const emp = empresas[0]\r\n        return (\r\n            <div className=\"flex items-center gap-3 px-4 py-3 bg-white/50 dark:bg-slate-900/50 backdrop-blur rounded-xl border border-slate-200 dark:border-slate-800\">\r\n                {emp.logo_url ? (\r\n                    <Image\r\n                        src={emp.logo_url}\r\n                        alt={emp.razon_social}\r\n                        width={32}\r\n                        height={32}\r\n                        className=\"w-8 h-8 rounded-lg object-cover shadow-sm\"\r\n                    />\r\n                ) : (\r\n                    <div className=\"w-8 h-8 rounded-lg bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center\">\r\n                        <Building2 className=\"w-4 h-4 text-white\" />\r\n                    </div>\r\n                )}\r\n                <span className=\"font-bold text-slate-700 dark:text-slate-300\">{emp.razon_social}</span>\r\n            </div>\r\n        )\r\n    }\r\n\r\n    return (\r\n        <>\r\n            <DropdownMenu>\r\n                <DropdownMenuTrigger asChild>\r\n                    <Button\r\n                        variant={variant === 'header' ? 'ghost' : 'outline'}\r\n                        className={`\r\n                            group transition-all duration-300 active:scale-95 touch-manipulation\r\n                            ${variant === 'header'\r\n                                ? 'h-11 px-3 gap-3 bg-white/40 dark:bg-slate-900/40 backdrop-blur-md rounded-2xl hover:bg-white/60 dark:hover:bg-slate-900/60 border border-white/20 dark:border-slate-800/20'\r\n                                : 'w-full justify-between h-12 bg-white/70 dark:bg-slate-900/70 backdrop-blur-xl border-slate-200 dark:border-slate-800 rounded-2xl shadow-sm'}\r\n                        `}\r\n                    >\r\n                        <div className=\"flex items-center gap-3\">\r\n                            {empresaActiva?.id === 'ALL' ? (\r\n                                <div className=\"w-8 h-8 rounded-lg bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center shadow-md\">\r\n                                    <Building2 className=\"w-4 h-4 text-white\" />\r\n                                </div>\r\n                            ) : empresaActiva?.logo_url ? (\r\n                                <img\r\n                                    src={empresaActiva.logo_url}\r\n                                    alt={empresaActiva.razon_social}\r\n                                    className=\"w-8 h-8 rounded-lg object-cover shadow-sm group-hover:scale-105 transition-transform\"\r\n                                />\r\n                            ) : (\r\n                                <div className=\"w-8 h-8 rounded-lg bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center shadow-md\">\r\n                                    <Building2 className=\"w-4 h-4 text-white\" />\r\n                                </div>\r\n                            )}\r\n                            <span className=\"font-black text-sm tracking-tight truncate max-w-[140px] md:max-w-[200px] text-slate-800 dark:text-slate-200 uppercase\">\r\n                                {empresaActiva?.nombr