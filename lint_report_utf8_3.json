ear(serie.id)} className=\"focus:bg-white/10 focus:text-white cursor-pointer\">\r\n                                        <RotateCcw className=\"h-4 w-4 mr-2 text-blue-400\" />\r\n                                        Resetear Numeraci├│n\r\n                                    </DropdownMenuItem>\r\n                                    <DropdownMenuItem className=\"text-red-400 focus:bg-red-500/10 focus:text-red-300 cursor-pointer\" onClick={() => handleEliminar(serie.id)}>\r\n                                        <Trash2 className=\"h-4 w-4 mr-2\" />\r\n                                        Eliminar\r\n                                    </DropdownMenuItem>\r\n                                </DropdownMenuContent>\r\n                            </DropdownMenu>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            ))}\r\n\r\n            {series.length === 0 && (\r\n                <div className=\"text-center py-20 bg-white/5 rounded-3xl border-2 border-dashed border-white/10\">\r\n                    <div className=\"text-6xl mb-4\">­ƒô¡</div>\r\n                    <h3 className=\"text-2xl font-bold text-white mb-2\">No hay series configuradas</h3>\r\n                    <p className=\"text-slate-400\">Crea tu primera serie para empezar a organizar tu facturaci├│n.</p>\r\n                    <Link href=\"/ventas/configuracion/series/nueva\" className=\"mt-6 inline-block\">\r\n                        <Button className=\"bg-primary text-secondary-foreground font-bold px-8\">Crear Serie</Button>\r\n                    </Link>\r\n                </div>\r\n            )}\r\n        </div>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\components\\ui\\alert-dialog.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users