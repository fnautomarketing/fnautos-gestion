rCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useEffect, useState, use } from 'react'\r\nimport Link from 'next/link'\r\nimport { createClient } from '@/lib/supabase/client'\r\nimport { PdfLayoutPreview } from '@/components/ventas/pdf/pdf-layout-preview'\r\nimport { PdfOptionsPanel, PdfOptions } from '@/components/ventas/pdf/pdf-options-panel'\r\nimport { Button } from '@/components/ui/button'\r\nimport { ArrowLeft, Loader2 } from 'lucide-react'\r\n\r\n// Mock enterprise data for now as requested\r\nconst MOCK_EMPRESA = {\r\n    nombre_fiscal: 'STV Logistics SL',\r\n    direccion: 'Calle Principal 123, Pol. Ind. Norte',\r\n    ciudad: 'Madrid',\r\n    codigo_postal: '28001',\r\n    cif: 'B12345678'\r\n}\r\n\r\ninterface PageProps {\r\n    params: Promise<{ id: string }>\r\n}\r\n\r\nexport default function FacturaPdfPage({ params }: PageProps) {\r\n    const { id } = use(params)\r\n    const [factura, setFactura] = useState<any>(null)\r\n    const [loading, setLoading] = useState(true)\r\n    const [options, setOptions] = useState<PdfOptions>({\r\n        plantilla: 'estandar',\r\n        idioma: 'es',\r\n        formatoPagina: 'A4-vertical',\r\n        incluirLogo: true,\r\n        mostrarDesgloseIva: true,\r\n        // Let the template decide the default colors based on brand logic\r\n        colorAcento: '',\r\n        notasPie: 'Gracias por su confianza.',\r\n        incluirTerminos: false,\r\n        incluirDatosBancarios: true\r\n    })\r\n\r\n    // Using standard Client wrapper for consistency with recent changes\r\n    const supabase = createClient()\r\n\r\n    useEffect(() => {\r\n        async function loadData() {\r\n            try {\r\n                const { data: { user } } = await supabase.auth.getUser()\r\n                if (!user) return // middleware handles redirect\r\n\r\n                const { data: perfil } = await supabase\r\n                    .from('perfiles')\r\n                    .select('empresa_id')\r\n                    .eq('user_id', user.id)\r\n                    .single()\r\n\r\n                if (!perfil?.empresa_id) return\r\n\r\n                const { data: fac, error } = await supabase\r\n                    .from('facturas')\r\n                    .select(`\r\n                *,\r\n                cliente:clientes(*),\r\n                lineas:lineas_factura(*)\r\n            `)\r\n                    .eq('id', id)\r\n                    .eq('empresa_id', perfil.empresa_id)\r\n                    .single()\r\n\r\n                if (error || !fac) {\r\n                    console.error('Error loading invoice', error)\r\n                    return\r\n                }\r\n\r\n                setFactura(fac)\r\n            } catch (e) {\r\n                console.error(e)\r\n            } finally {\r\n                setLoading(false)\r\n            }\r\n        }\r\n        loadData()\r\n    }, [id, supabase])\r\n\r\n    const handleDownload = () => {\r\n        // Construct query params from options\r\n        const params = new URLSearchParams()\r\n        Object.entries(options).forEach(([key, value]) => {\r\n            params.append(key, String(value))\r\n        })\r\n\r\n        // Trigger download in new tab\r\n        window.open(`/api/facturas/${id}/pdf?${params.toString()}`, '_blank')\r\n    }\r\n\r\n    if (loading) {\r\n        return (\r\n            <div className=\"flex h-[80vh] items-center justify-center\">\r\n                <Loader2 className=\"h-8 w-8 animate-spin text-slate-400\" />\r\n            </div>\r\n        )\r\n    }\r\n\r\n    if (!factura) {\r\n        return <div>Factura no encontrada o acceso denegado.</div>\r\n    }\r\n\r\n    return (\r\n        <div className=\"space-y-6\">\r\n            {/* Breadcrumbs & Header */}\r\n            <div className=\"flex flex-col gap-4 md:flex-row md:items-center md:justify-between animate-in slide-in-from-top-4 duration-500\">\r\n                <div className=\"space-y-1\">\r\n                    <div className=\"flex items-center gap-2 text-sm text-slate-500\">\r\n                        <Link href=\"/ventas/facturas\" className=\"hover:text-slate-900 transition-colors\">Facturas</Link>\r\n                        <span>ÔÇ║</span>\r\n                        <Link href={`/ventas/facturas/${id}`} className=\"hover:text-slate-900 transition-colors\">\r\n                            {factura.serie}-{factura.numero}\r\n                        </Link>\r\n                        <span>ÔÇ║</span>\r\n                        <span className=\"font-medium text-slate-900 dark:text-slate-100\">Generar PDF</span>\r\n                    </div>\r\n                    <h1 className=\"text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100\">\r\n                        Generar Documento\r\n                    </h1>\r\n                </div>\r\n                <div className=\"flex gap-3\">\r\n                    <Button variant=\"outline\" asChild>\r\n                        <Link href={`/ventas/facturas/${id}`}>\r\n                            <ArrowLeft className=\"mr-2 h-4 w-4\" />\r\n                            Volver\r\n                        </Link>\r\n                    </Button>\r\n                    <Button onClick={handleDownload}>\r\n                        Descargar PDF\r\n                    </Button>\r\n                </div>\r\n            </div>\r\n\r\n            <div className=\"grid lg:grid-cols-12 gap-8 items-start\">\r\n                {/* Left: Preview (8 cols) */}\r\n                <div className=\"lg:col-span-8 space-y-4\">\r\n                    <PdfLayoutPreview\r\n                        factura={factura}\r\n                        empresa={MOCK_EMPRESA}\r\n                        options={options}\r\n                    />\r\n                </div>\r\n\r\n                {/* Right: Options (4 cols) */}\r\n                <div className=\"lg:col-span-4 space-y-6 lg:sticky lg:top-6\">\r\n                    <PdfOptionsPanel\r\n                        options={options}\r\n                        onChange={setOptions}\r\n                        onDownload={handleDownload}\r\n                    />\r\n                </div>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\app\\(dashboard)\\ventas\\facturas\\nueva\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'createAdminClient' is defined but never used.","line":2,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":2,"endColumn":27,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"createAdminClient"},"fix":{"range":[60,116],"text":""},"desc":"Remove unused import declaration."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { createServerClient } from '@/lib/supabase/server'\r\nimport { createAdminClient } from '@/lib/supabase/admin'\r\nimport { redirect } from 'next/navigation'\r\nimport { NuevaFacturaForm } from '@/components/ventas/nueva-factura-form'\r\n\r\nexport default async function NuevaFacturaPage() {\r\n    const supabase = await createServerClient()\r\n\r\n    const {\r\n        data: { user },\r\n    } = await supabase.auth.getUser()\r\n\r\n    if (!user) {\r\n        redirect('/login')\r\n    }\r\n\r\n    // Obtener empresa_id\r\n    const { data: perfil } = await supabase\r\n        .from('perfiles')\r\n        .select('empresa_id')\r\n        .eq('user_id', user.id)\r\n        .single()\r\n\r\n    if (!perfil?.empresa_id) {\r\n        throw new Error('Usuario sin empresa asignada')\r\n    }\r\n\r\n    // Obtener configuraci├│n de empresa\r\n    const { data: empresa } = await supabase\r\n        .from('empresas')\r\n        .select('*')\r\n        .eq('id', perfil.empresa_id)\r\n        .single()\r\n\r\n    // Obtener clientes para el selector\r\n    const { data: clientes } = await supabase\r\n        .from('clientes')\r\n        .select('*')\r\n        .eq('empresa_id', perfil.empresa_id)\r\n        .eq('activo', true)\r\n        .order('nombre_fiscal')\r\n\r\n    return (\r\n        <div className=\"space-y-6\">\r\n            {/* Breadcrumbs */}\r\n            <div className=\"flex items-center gap-2 text-sm text-slate-500\">\r\n                <span className=\"hover:text-slate-700 dark:hover:text-slate-300 cursor-pointer\">Ventas</span>\r\n                <span>ÔÇ║</span>\r\n                <span className=\"hover:text-slate-700 dark:hover:text-slate-300 cursor-pointer\">Facturas</span>\r\n                <span>ÔÇ║</span>\r\n                <span className=\"text-slate-900 dark:text-slate-100 font-medium\">Nueva Factura</span>\r\n            </div>\r\n\r\n            {/* Page Header */}\r\n            <div>\r\n                <h1 className=\"text-3xl font-serif font-bold text-slate-900 dark:text-slate-100 tracking-tight\">\r\n                    Nueva Factura\r\n                </h1>\r\n                <p className=\"text-slate-600 dark:text-slate-400 mt-1 text-lg\">\r\n                    Completa los datos para generar una nueva factura de venta\r\n                </p>\r\n            </div>\r\n\r\n            {/* Formulario */}\r\n            <NuevaFacturaForm\r\n                clientes={clientes || []}\r\n                empresaId={perfil.empresa_id}\r\n                empresaConfig={empresa}\r\n            />\r\n        </div>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\app\\(dashboard)\\ventas\\facturas\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\app\\(dashboard)\\v