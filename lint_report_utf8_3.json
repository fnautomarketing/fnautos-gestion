    const result = await establecerPredeterminadaAction(serieId)\r\n        if (result.success) {\r\n            toast.success('Serie establecida como predeterminada')\r\n            router.refresh()\r\n        } else {\r\n            toast.error(result.error)\r\n        }\r\n    }\r\n\r\n    const handleEliminar = async (serieId: string) => {\r\n        if (!confirm('┬┐Eliminar esta serie? Esta acci├│n no se puede deshacer.')) return\r\n\r\n        const result = await eliminarSerieAction(serieId)\r\n        if (result.success) {\r\n            toast.success('Serie eliminada')\r\n            router.refresh()\r\n        } else {\r\n            toast.error(result.error)\r\n        }\r\n    }\r\n\r\n    const handleResetear = async (serieId: string) => {\r\n        if (!confirm('┬┐Resetear la numeraci├│n de esta serie? El contador volver├í al n├║mero inicial.')) return\r\n\r\n        const result = await resetearNumeracionAction(serieId)\r\n        if (result.success) {\r\n            toast.success('Numeraci├│n reseteada')\r\n            router.refresh()\r\n        } else {\r\n            toast.error(result.error)\r\n        }\r\n    }\r\n\r\n    return (\r\n        <div className=\"grid gap-6\">\r\n            {series.map((serie) => (\r\n                <div\r\n                    key={serie.id}\r\n                    className=\"group rounded-2xl bg-white/5 backdrop-blur-xl border border-white/10 p-6 shadow-xl hover:shadow-2xl hover:shadow-primary/20 hover:scale-[1.01] transition-all duration-300\"\r\n                >\r\n                    <div className=\"flex flex-col md:flex-row items-start justify-between gap-6\">\r\n                        {/* Izquierda: Info */}\r\n                        <div className=\"flex items-start gap-5 flex-1 w-full\">\r\n                            {/* Icono */}\r\n                            <div className=\"text-6xl bg-white/5 p-4 rounded-2xl border border-white/5 shadow-inner group-hover:scale-110 transition-transform duration-500\">\r\n                                {serie.icono || '­ƒôä'}\r\n                            </div>\r\n\r\n                            {/* Contenido */}\r\n                            <div className=\"flex-1 min-w-0\">\r\n                                <div className=\"flex flex-wrap items-center gap-3 mb-2\">\r\n                                    <h2 className=\"text-3xl font-bold tracking-tight text-white\">{serie.codigo}</h2>\r\n                                    <Badge className={serie.activa ? 'bg-green-500/10 text-green-400 border-green-500/20' : 'bg-slate-500/10 text-slate-400 border-slate-500/20'}>\r\n                                        {serie.activa ? 'ACTIVA' : 'INACTIVA'}\r\n                                    </Badge>\r\n                                    {serie.predeterminada && (\r\n                                        <Badge className=\"bg-gradient-to-r from-amber-500 to-orange-600 text-white border-none shadow-lg shadow-orange-900/20 animate-pulse\">\r\n                                            Ô¡É PREDETERMINADA\r\n                                        </Badge>\r\n                                    )}\r\n                                </div>\r\n\r\n                                <p className=\"text-slate-400 text-lg mb-5 font-medium\">{serie.nombre}</p>\r\n\r\n                                {/* Stats */}\r\n                                <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-6 text-sm\">\r\n                                    <div className=\"bg-white/5 p-3 rounded-xl border border-white/5\">\r\n                                        <p className=\"text-xs text-slate-500 uppercase tracking-widest font-bold mb-1\">Formato</p>\r\n                                        <p className=\"font-mono text-slate-200\">{serie.prefijo || ''}<span className=\"text-primary\">{'{n}'}</span>{serie.sufijo || ''}</p>\r\n                                    </div>\r\n                                    <div className=\"bg-white/5 