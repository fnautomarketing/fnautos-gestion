')\r\n\r\n    // Cargar facturas vencidas\r\n    let query = supabase\r\n        .from('vista_facturas_vencidas' as any)\r\n        .select('*')\r\n        .eq('empresa_id', perfil.empresa_id)\r\n\r\n    // Filtro por nivel de criticidad\r\n    const nivel = searchParams.nivel || 'todas'\r\n    if (nivel !== 'todas') {\r\n        query = query.eq('nivel_criticidad', nivel)\r\n    }\r\n\r\n    // Filtro de b├║squeda\r\n    if (searchParams.search) {\r\n        query = query.or(`cliente_nombre.ilike.%${searchParams.search}%,serie.ilike.%${searchParams.search}%`)\r\n    }\r\n\r\n    query = query.order('dias_vencido', { ascending: false })\r\n\r\n    const { data: facturas } = await query\r\n\r\n    // Cargar estad├¡sticas\r\n    // Importante: server action para stats\r\n    const { getEstadisticasVencidasAction } = await import('@/app/actions/recordatorios')\r\n    const statsResult = await getEstadisticasVencidasAction()\r\n    const stats = statsResult.success ? statsResult.data : {}\r\n\r\n    return (\r\n        <div className=\"space-y-6\">\r\n            <div className=\"text-sm text-slate-500\">Ventas ÔÇ║ Facturas Vencidas</div>\r\n\r\n            <div className=\"flex items-center justify-between\">\r\n                <div>\r\n                    <h1 className=\"text-4xl font-serif font-bold\">Facturas Vencidas</h1>\r\n                    <p className=\"text-slate-600 dark:text-slate-400\">\r\n                        Control de impagos y gesti├│n de recordatorios de cobro\r\n                    </p>\r\n                </div>\r\n            </div>\r\n\r\n            <VencidasStats stats={stats} />\r\n\r\n            <VencidasTabla facturas={facturas || []} nivel={nivel} />\r\n        </div>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\app\\(dashboard)\\ventas\\facturas\\[id]\\editar\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":81,"column":37,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":81,"endColumn":40,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[2436,2439],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[2436,2439],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { createServerClient } from '@/lib/supabase/server'\r\nimport { redirect, notFound } from 'next/navigation'\r\nimport { EditarFacturaForm } from '@/components/ventas/editar-factura-form'\r\n\r\nexport default async function EditarFacturaPage({\r\n    params,\r\n}: {\r\n    params: Promise<{ id: string }>\r\n}) {\r\n    const { id } = await params\r\n    const supabase = await createServerClient()\r\n\r\n    const {\r\n        data: { user },\r\n    } = await supabase.auth.getUser()\r\n\r\n    if (!user) {\r\n        redirect('/login')\r\n    }\r\n\r\n    // Obtener empresa_id\r\n    const { data: perfil } = await supabase\r\n        .from('perfiles')\r\n        .select('empresa_id')\r\n        .eq('user_id', user.id)\r\n        .single()\r\n\r\n    if (!perfil?.empresa_id) {\r\n        // throw new Error('Usuario sin empresa asignada')\r\n        // Handle gracefully or redirect\r\n        return <div>Usuario sin empresa asignada</div>\r\n    }\r\n\r\n    // Cargar factura completa\r\n    const { data: factura, error } = await supabase\r\n        .from('facturas')\r\n        .select(\r\n            `\r\n      *,\r\n      cliente:clientes(*),\r\n      lineas:lineas_factura(*)\r\n    `\r\n        )\r\n        .eq('id', id)\r\n        .eq('empresa_id', perfil.empresa_id)\r\n        .single()\r\n\r\n    if (error || !factura) {\r\n        notFound()\r\n    }\r\n\r\n    // No permitir editar facturas anuladas\r\n    if (factura.estado === 'anulada') {\r\n        redirect(`/ventas/facturas/${id}?error=no_editable`)\r\n    }\r\n\r\n    // Cargar historial de cambios\r\n    const { data: cambios } = await supabase\r\n        .from('eventos_factura')\r\n        .select('*')\r\n        .eq('factura_id', id)\r\n        .in('tipo', ['modificado', 'creado', 'pagado']) // Include 'pagado' to context\r\n        .order('created_at', { ascending: false })\r\n        .limit(10)\r\n\r\n    return (\r\n        <div className=\"space-y-6\">\r\n            {/* Breadcrumbs */}\r\n            <div className=\"flex items-center gap-2 text-sm text-slate-500 animate-in slide-in-from-top-4 duration-500\">\r\n                <span>Ventas</span>\r\n                <span>ÔÇ║</span>\r\n                <span>Facturas</span>\r\n                <span>ÔÇ║</span>\r\n                <span>{factura.serie}-{factura.numero}</span>\r\n                <span>ÔÇ║</span>\r\n                <span className=\"text-slate-900 dark:text-slate-100 font-medium\">Editar</span>\r\n            </div>\r\n\r\n            {/* Formulario */}\r\n            <EditarFacturaForm\r\n                factura={factura as any}\r\n                empresaId={perfil.empresa_id}\r\n                cambios={cambios || []}\r\n            />\r\n        </div>\r\n    )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\jebol\\Desktop\\STVLS-ERP\\stvls-erp\\src\\app\\(dashboard)\\ventas\\facturas\\[id]\\email\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":19,"column":44,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":19,"endColumn":47,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[785,788],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[785,788],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":20,"column":44,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":20,"endColumn":47,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[840,843],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[840,843],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useState, use, useEffect } from 'react'\r\nimport { createClient } from '@/lib/supabase/client'\r\nimport Link from 'next/link'\r\nimport { ArrowLeft, Loader2 } from 'lucide-react'\r\nimport { Button } from '@/components/ui/button'\r\nimport { EmailSendForm } from '@/components/ventas/email/email-send-form'\r\nimport { EmailSummaryCard } from '@/components/ventas/email/email-summary-card'\r\nimport { EmailActivityCard } from '@/components/ventas/email/email-activity-card'\r\nimport { EmailTemplatesPanel } from '@/components/ventas/email/email-templates-panel'\r\n\r\ninterface PageProps {\r\n    params: Promise<{ id: string }>\r\n}\r\n\r\nexport default function FacturaEmailPage({ params }: PageProps) {\r\n    const { id } = use(params)\r\n    const [factura, setFactura] = useState<any>(null)\r\n    const [history, setHistory] = useState<any[]>([])\r\n    const [loading, setLoading] = useState(true)\r\n\r\n    // Template State\r\n    const [template, setTemplate] = useState('estandar')\r\n    const [includeLogo, setIncludeLogo] = useState(true)\r\n    const [message, setMessage] = useState('')\r\n\r\n    const supabase = createClient()\r\n\r\n    // Generate welcome message based on template\r\n    useEffect(() => {\r\n        if (!factura) return\r\n\r\n        const getTemplateMessage = () => {\r\n            const clienteName = factura.cliente.nombre_fiscal || 'Cliente'\r\n            const invoiceRef = `${factura.serie}-${factura.numero}`\r\n            const total = new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR' }).format(factura.total)\r\n\r\n            switch (template) {\r\n                case 'informal':\r\n                    return `Hola ${clienteName},\\n\\nTe adjunto la factura ${invoiceRef} por valor de ${total}.\\n\\nCualquier cosa me dices.\\n\\nSaludos,\\nSTV Logistics`\r\n                case 'recordatorio':\r\n                    return `Estimado cliente,\\n\\nLe recordamos que la factura ${invoiceRef} con importe ${total} est├í pendiente de pago.\\n\\nAgradecer├¡amos que realizara el abono lo antes posible.\\n\\nAtentamente,\\nDepartamento de Facturaci├│n`\r\n                case 'estandar':\r\n                default:\r\n                    return `Estimados ${clienteName},\\n\\nAdjuntamos la factura ${invoiceRef} correspondiente a los servicios prestados, por un importe total de ${total}.\\n\\nQuedamos a su disposici├│n para cualquier consulta.\\n\\nAtentamente,\\nSTV Logistics`\r\n            }\r\n        }\r\n        setMessage(getTemplateMessage())\r\n    }, [template, factura])\r\n\r\n\r\n    useEffect(() => {\r\n        async function loadData() {\r\n            try {\r\n                const { data: { user } } = await supabase.auth.getUser()\r\n                if (!user) return\r\n\r\n                const { data: perfil } = await supabase\r\n                    .from('perfiles')\r\n                    .select('empresa_id')\r\n                    .eq('user_id', user.id)\r\n                    .single()\r\n\r\n                if (!perfil?.empresa_id) return\r\n\r\n                // Fetch Invoice\r\n                const { data: fac } = await supabase\r\n                    .from('facturas')\r\n                    .select(`\r\n                *,\r\n                cliente:clientes(*),\r\n                lineas:lineas_factura(*)\r\n            `)\r\n                    .eq('id', id)\r\n                    .eq('empresa_id', perfil.empresa_id)\r\n                    .single()\r\n\r\n                if (fac) {\r\n                    setFactura(fac)\r\n\r\n                    // Fetch Email History\r\n                    const { data: emails } = await supabase\r\n                        .from('emails_factura')\r\n                        .select('*')\r\n                        .eq('factura_id', id)\r\n                        .order('created_at', { ascending: false })\r\n                        .limit(5)\r\n\r\n                    setHistory(emails || [])\r\n                }\r\n\r\n            } catch (e) {\r\n                console.error(e)\r\n            } finally {\r\n                setLoading(false)\r\n            }\r\n        }\r\n        loadData()\r\n    }, [id, supabase])\r\n\r\n    if (loading) {\r\n        return (\r\n            <div className=\"flex h-[80vh] items-center justify-center\">\r\n                <Loader2 className=\"h-8 w-8 animate-spin text-slate-400\" />\r\n            </div>\r\n        )\r\n    }\r\n\r\n    if (!factura) return <div>Factura no encontrada</div>\r\n\r\n    return (\r\n        <div className=\"space-y-6\">\r\n            {/* Breadcrumbs & Header */}\r\n            <div className=\"flex flex-col gap-4 md:flex-row md:items-center md:justify-between animate-in slide-in-from-top-4 duration-500\">\r\n                <div className=\"space-y-1\">\r\n                    <div className=\"flex items-center gap-2 text-sm text-slate-500\">\r\n                        <Link href=\"/ventas/facturas\" className=\"hover:text-slate-900 transition-colors\">Facturas</Link>\r\n                        <span>ÔÇ║</span>\r\n                        <Link href={`/ventas/facturas/${id}`} className=\"hover:text-slate-900 transition-colors\">\r\n                            {factura.serie}-{factura.numero}\r\n                        </Link>\r\n                        <span>ÔÇ║</span>\r\n                        <span className=\"font-medium text-slate-900 dark:text-slate-100\">Enviar por Email</span>\r\n                    </div>\r\n                    <h1 className=\"text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100\">\r\n                        Enviar Documento\r\n                    </h1>\r\n                </div>\r\n                <div className=\"flex gap-3\">\r\n                    <Button variant=\"outline\" asChild>\r\n                        <Link href={`/ventas/facturas/${id}`}>\r\n                            <ArrowLeft className=\"mr-2 h-4 w-4\" />\r\n                            Cancelar y Volver\r\n                        </Link>\r\n                    </Button>\r\n                </div>\r\n            </div>\r\n\r\n            <div className=\"grid lg:grid-cols-12 gap-8 items-start\">\r\n                <div className=\"lg:col-span-7 space-y-6\">\r\n                    <EmailSendForm\r\n                        factura={factura}\r\n                        cliente={factura.cliente}\r\n                        messageTemplate={message}\r\n                        incluirLogo={includeLogo}\r\n                    />\r\n                </div>\r\n                <div className=\"lg:col-span-5 space-y-6\">\r\n                    <EmailSummaryCard factura={factura} />\r\n                    <EmailTemplatesPanel\r\n                        onTemplateChange={setTemplate}\r\n                        incluirLogo={includeLogo}\r\n                        onLogoChange={setIncludeLogo}\r\n                    />\r\n                    <EmailActivityCard historial={history} />\r\n                </div>\r\n            </div>\r\n